c\u5730\u5740\u662fMarktgasse 5, Basel\u3002\u4fe1\u4ef6\u5185\u5bb9\u63d0\u5230\u4ed6\u4eec\u6536\u5230\u4e86\u5bf9\u65b912\u670815\u65e5\u7684\u4fe1\uff0c\u5e76\u786e\u8ba4\u4e86\u5408\u540c\u8349\u6848\u4e2d\u7684\u5ef6\u8fdf\u6761\u6b3e\uff0c\u5408\u540c\u5728\u6628\u5929\u7684\u80a1\u4e1c\u5927\u4f1a\u4e0a\u672a\u7ecf\u4fee\u6539\u901a\u8fc7\u3002\u8fd8\u63d0\u5230\u822a\u8fd0\u534f\u4f1a\u5e0c\u671b\u83b7\u5f97\u5ba2\u8fd0\u8239\u53ea\u7684\u9891\u7387\u6570\u636e\u7528\u4e8e\u5ba3\u4f20\u3002\\n\\n\u63a5\u4e0b\u6765\uff0c\u6211\u9700\u8981\u786e\u5b9a\u5404\u4e2a\u5b57\u6bb5\u3002\u4fe1\u4ef6\u6807\u9898\uff08letter_title\uff09\u5728\u56fe\u7247\u4e2d\u6ca1\u6709\u660e\u786e\u7ed9\u51fa\uff0c\u901a\u5e38\u6b63\u5f0f\u4fe1\u4ef6\u53ef\u80fd\u6ca1\u6709\u6807\u9898\uff0c\u6240\u4ee5\u8fd9\u91cc\u5e94\u8be5\u662fnull\u3002\u53d1\u4ef6\u4eba\uff08sender_persons\uff09\u662fBasler Personenschiffahrtsgesellschaft\uff0c\u4f46\u5177\u4f53\u4eba\u540d\u6ca1\u6709\u63d0\u5230\uff0c\u53ea\u6709\u516c\u53f8\u540d\u79f0\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u3002\u4e0d\u8fc7\u7528\u6237\u8981\u6c42\u7684\u662f\u4eba\u540d\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\uff0c\u53ea\u6709\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u7b7e\u540d\u90e8\u5206\u3002\u56fe\u7247\u5e95\u90e8\u6709\u201cDer Pr\u00e4sident\u201d\u548c\u201cDer Gesch\u00e4ftsf\u00fchrer\u201d\u7684\u7b7e\u540d\u4f4d\u7f6e\uff0c\u4f46\u540d\u5b57\u88ab\u6a21\u7cca\u5904\u7406\u4e86\uff0c\u65e0\u6cd5\u8fa8\u8ba4\uff0c\u6240\u4ee5\u53d1\u4ef6\u4eba\u53ef\u80fd\u53ea\u80fd\u586b\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u53ef\u80fd\u5e94\u8be5\u7528\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u662f\u4e2a\u4eba\u540d\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u3002\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0c\u6bd4\u5982\u201cLisa Simpson\u201d\u662f\u4e2a\u4eba\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u671f\u671b\u4eba\u540d\uff0c\u4f46\u5982\u679c\u6ca1\u6709\u7684\u8bdd\uff0c\u53ef\u80fd\u53ea\u80fd\u586bnull\uff1f\u6216\u8005\u53ef\u80fd\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff1f\\n\\n\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0c\u6bd4\u5982\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u4f46\u8fd9\u91cc\u7684\u60c5\u51b5\u662f\u516c\u53f8\u53d1\u51fa\u7684\u4fe1\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u5177\u4f53\u7684\u4eba\u540d\uff0c\u4f46\u56fe\u7247\u4e2d\u6ca1\u6709\u663e\u793a\u5177\u4f53\u7684\u4eba\u540d\uff0c\u53ea\u6709\u804c\u4f4d\u3002\u6240\u4ee5\u53ef\u80fd\u53d1\u4ef6\u4eba\u5e94\u8be5\u662fnull\uff0c\u6216\u8005\u7528\u516c\u53f8\u540d\u79f0\u3002\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u56fe\u7247\u3002\u5728\u4fe1\u4ef6\u7684\u672b\u5c3e\uff0c\u6709\u201cBasler Personenschiffahrtsgesellschaft\u201d\u4f5c\u4e3a\u53d1\u4ef6\u516c\u53f8\uff0c\u4e0b\u9762\u6709\u201cDer Pr\u00e4sident\u201d\u548c\u201cDer Gesch\u00e4ftsf\u00fchrer\u201d\u7684\u7b7e\u540d\uff0c\u4f46\u540d\u5b57\u88ab\u6a21\u7cca\u4e86\uff0c\u65e0\u6cd5\u8bc6\u522b\u3002\u56e0\u6b64\uff0c\u53d1\u4ef6\u4eba\u53ef\u80fd\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u7684\u4eba\u540d\uff0c\u53ea\u80fd\u586b\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u8981\u6c42\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u586bnull\uff0c\u6216\u8005\u7528\u516c\u53f8\u540d\u3002\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u8fd9\u91cc\u5e94\u8be5\u586bnull\uff0c\u56e0\u4e3a\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\u3002\u6216\u8005\u53ef\u80fd\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5224\u65ad\u3002\\n\\n\u6536\u4ef6\u4eba\uff08receiver_persons\uff09\u662fBasler Rheinschiffahrt A.-G.\uff0c\u5730\u5740\u662fMarktgasse 5, Basel\uff0c\u6240\u4ee5\u6536\u4ef6\u4eba\u662f\u8fd9\u4e2a\u516c\u53f8\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u4eba\u540d\uff0c\u4f46\u8fd9\u91cc\u4e5f\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586b\u516c\u53f8\u540d\uff0c\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u6536\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6bd4\u5982\u5e02\u957f\u548c\u6821\u957f\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u586b\u516c\u53f8\u540d\u4f5c\u4e3a\u6536\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u671f\u671b\u7684\u662f\u4eba\u540d\uff0c\u4f46\u5982\u679c\u6ca1\u6709\u7684\u8bdd\uff0c\u53ef\u80fd\u586bnull\uff1f\u6216\u8005\u53ef\u80fd\u516c\u53f8\u540d\u4f5c\u4e3a\u6536\u4ef6\u4eba\u3002\u9700\u8981\u770b\u7528\u6237\u7684\u8981\u6c42\uff0c\u7528\u6237\u8bf4\u201cName(s) of the person(s)\u201d\uff0c\u6240\u4ee5\u5982\u679c\u662f\u516c\u53f8\u7684\u8bdd\uff0c\u53ef\u80fd\u4e0d\u7b26\u5408\uff0c\u4f46\u53ef\u80fd\u5728\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u53ea\u80fd\u586b\u516c\u53f8\u540d\uff0c\u6216\u8005null\u3002\u4f46\u6839\u636e\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\uff0c\u6536\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586b\u516c\u53f8\u540d\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u586bnull\u3002\u4e0d\u8fc7\u53ef\u80fd\u7528\u6237\u5141\u8bb8\u516c\u53f8\u540d\u4f5c\u4e3a\u6536\u4ef6\u4eba\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u90fd\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u518d\u786e\u8ba4\u3002\\n\\n\u53d1\u9001\u65e5\u671f\uff08send_date\uff09\u662f1922\u5e7412\u670816\u65e5\uff0c\u6240\u4ee5\u5e94\u8be5\u8f6c\u6362\u4e3aISO\u683c\u5f0f1922-12-16\u3002\\n\\n\u73b0\u5728\uff0c\u6574\u7406\u4e00\u4e0b\uff1a\\n\\nletter_title\uff1a\u4fe1\u4ef6\u4e2d\u6ca1\u6709\u6807\u9898\uff0c\u6240\u4ee5null\u3002\\n\\nsender_persons\uff1a\u53d1\u4ef6\u516c\u53f8\u662fBasler Personenschiffahrtsgesellschaft\uff0c\u4f46\u5177\u4f53\u4eba\u540d\u672a\u77e5\uff0c\u6240\u4ee5\u53ef\u80fd\u586bnull\uff0c\u6216\u8005\u516c\u53f8\u540d\u3002\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u586bnull\uff0c\u4f46\u53ef\u80fd\u7528\u6237\u63a5\u53d7\u516c\u53f8\u540d\u3002\u9700\u8981\u770b\u7528\u6237\u7684\u8981\u6c42\uff0c\u7528\u6237\u8bf4\u201cName(s) of the person(s)\u201d\uff0c\u6240\u4ee5\u5982\u679c\u662f\u516c\u53f8\u7684\u8bdd\uff0c\u53ef\u80fd\u4e0d\u7b26\u5408\uff0c\u6240\u4ee5\u586bnull\u3002\\n\\nreceiver_persons\uff1a\u6536\u4ef6\u4eba\u662fBasler Rheinschiffahrt A.-G.\uff0c\u540c\u6837\u662f\u4e00\u4e2a\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u586bnull\uff0c\u6216\u8005\u516c\u53f8\u540d\u3002\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u6536\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u586bnull\u3002\\n\\n\u4f46\u53ef\u80fd\u7528\u6237\u5141\u8bb8\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u90fd\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u518d\u8003\u8651\u3002\u6216\u8005\u53ef\u80fd\u5728\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u90fd\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u5e94\u8be5\u586b\u516c\u53f8\u540d\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u53ef\u80fd\u586bnull\u3002\u4f46\u6839\u636e\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\uff0c\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u90fd\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586b\u516c\u53f8\u540d\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u5b58\u5728\u77db\u76fe\u3002\\n\\n\u6216\u8005\uff0c\u53ef\u80fd\u7528\u6237\u5141\u8bb8\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\uff0c\u5373\u4f7f\u793a\u4f8b\u4e2d\u662f\u4e2a\u4eba\u3002\u4f8b\u5982\uff0c\u5728\u5546\u4e1a\u4fe1\u51fd\u4e2d\uff0c\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u901a\u5e38\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586b\u516c\u53f8\u540d\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u90fd\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u6839\u636e\u5177\u4f53\u60c5\u51b5\u5904\u7406\u3002\\n\\n\u73b0\u5728\uff0c\u518d\u4ed4\u7ec6\u770b\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\uff1a\\n\\n\u53d1\u4ef6\u65b9\u662fBasler Personenschiffahrtsgesellschaft\uff0c\u4f4d\u4e8e\u4fe1\u5934\u3002\u6536\u4ef6\u65b9\u662fBasler Rheinschiffahrt A.-G.\uff0c\u5730\u5740\u5728Marktgasse 5, Basel\u3002\u6240\u4ee5\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u90fd\u662f\u516c\u53f8\uff0c\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\u3002\u56e0\u6b64\uff0csender_persons\u548creceiver_persons\u5e94\u8be5\u586b\u516c\u53f8\u540d\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586bnull\u3002\u4f46\u6839\u636e\u7528\u6237\u7684\u8981\u6c42\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u5c31\u586bnull\u3002\u4f46\u8fd9\u91cc\u7684\u4fe1\u606f\u5b58\u5728\uff0c\u53ea\u662f\u516c\u53f8\u540d\u800c\u4e0d\u662f\u4eba\u540d\u3002\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u671f\u671b\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5224\u65ad\u3002\\n\\n\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0c\u6bd4\u5982\u53d1\u4ef6\u4eba\u662fLisa Simpson\uff0c\u6536\u4ef6\u4eba\u662f\u5e02\u957f\u548c\u6821\u957f\uff0c\u90fd\u662f\u4e2a\u4eba\u3002\u6240\u4ee5\u5728\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u5982\u679c\u4fe1\u4ef6\u4e2d\u7684\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u53ef\u80fd\u5e94\u8be5\u586bnull\uff0c\u56e0\u4e3a\u7528\u6237\u8981\u6c42\u7684\u662f\u4eba\u540d\u3002\u4f46\u53ef\u80fd\u7528\u6237\u5141\u8bb8\u516c\u53f8\u540d\uff0c\u4f46\u9700\u8981\u770b\u7528\u6237\u7684\u5177\u4f53\u8981\u6c42\u3002\u7528\u6237\u7684\u95ee\u9898\u63cf\u8ff0\u4e2d\u8bf4\u201cName(s) of the person(s)\u201d\uff0c\u6240\u4ee5\u5982\u679c\u662f\u516c\u53f8\u7684\u8bdd\uff0c\u53ef\u80fd\u4e0d\u7b26\u5408\uff0c\u6240\u4ee5\u5e94\u8be5\u586bnull\u3002\\n\\n\u4f46\u53ef\u80fd\u5728\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u90fd\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u65e0\u6cd5\u63d0\u4f9b\u4eba\u540d\uff0c\u56e0\u6b64\u586bnull\u3002\u4f46\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5373\u4f7f\u516c\u53f8\u540d\u4e5f\u586b\u8fdb\u53bb\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u90fd\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586bnull\u3002\\n\\n\u73b0\u5728\uff0c\u518d\u68c0\u67e5\u65e5\u671f\uff1a\u56fe\u7247\u4e2d\u7684\u65e5\u671f\u662f16. Dezember 1922\uff0c\u8f6c\u6362\u4e3aISO\u683c\u5f0f\u662f1922-12-16\u3002\\n\\n\u6240\u4ee5\uff0c\u6700\u7ec8\u7684JSON\u5e94\u8be5\u662f\uff1a\\n\\n{\\n    \\\"letter_title\\\": [null],\\n    \\\"send_date\\\": [\\\"1922-12-16\\\"],\\n    \\\"sender_persons\\\": [null],\\n    \\\"receiver_persons\\\": [null]\\n}\\n\\n\u4f46\u53ef\u80fd\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u5e94\u8be5\u586b\u516c\u53f8\u540d\uff0c\u4f46\u7528\u6237\u8981\u6c42\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u586bnull\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u63a5\u53d7\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u90fd\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586bnull\u3002\\n\\n\u4e0d\u8fc7\uff0c\u53ef\u80fd\u7528\u6237\u5141\u8bb8\u516c\u53f8\u540d\uff0c\u4f46\u9700\u8981\u770b\u5177\u4f53\u60c5\u51b5\u3002\u4f8b\u5982\uff0c\u5728\u5546\u4e1a\u4fe1\u51fd\u4e2d\uff0c\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u901a\u5e38\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586b\u516c\u53f8\u540d\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684\u60c5\u51b5\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u6839\u636e\u7528\u6237\u7684\u8981\u6c42\u6765\u5224\u65ad\u3002\u7528\u6237\u7684\u95ee\u9898\u63cf\u8ff0\u4e2d\u8bf4\u201cName(s) of the person(s)\u201d\uff0c\u6240\u4ee5\u5982\u679c\u662f\u516c\u53f8\u7684\u8bdd\uff0c\u53ef\u80fd\u4e0d\u7b26\u5408\uff0c\u6240\u4ee5\u586bnull\u3002\\n\\n\u56e0\u6b64\uff0c\u6700\u7ec8\u7684JSON\u5e94\u8be5\u662f\uff1a\\n\\n{\\n    \\\"letter_title\\\": [null],\\n    \\\"send_date\\\": [\\\"1922-12-16\\\"],\\n    \\\"sender_persons\\\": [null],\\n    \\\"receiver_persons\\\": [null]\\n}\\n\\n\u4f46\u9700\u8981\u518d\u786e\u8ba4\u662f\u5426\u6709\u5176\u4ed6\u4fe1\u606f\u3002\u4f8b\u5982\uff0c\u4fe1\u4ef6\u4e2d\u662f\u5426\u6709\u63d0\u5230\u5177\u4f53\u7684\u4eba\u540d\uff1f\u5728\u5185\u5bb9\u4e2d\uff0c\u6ca1\u6709\u63d0\u5230\u5177\u4f53\u7684\u4eba\u540d\uff0c\u53ea\u6709\u516c\u53f8\u540d\u79f0\u548c\u804c\u4f4d\uff08\u5982Der Pr\u00e4sident\uff0cDer Gesch\u00e4ftsf\u00fchrer\uff09\uff0c\u4f46\u540d\u5b57\u88ab\u6a21\u7cca\u4e86\uff0c\u65e0\u6cd5\u8bc6\u522b\u3002\u56e0\u6b64\uff0c\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u90fd\u662f\u516c\u53f8\uff0c\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\uff0c\u6240\u4ee5\u586bnull\u3002\\n\\n\u56e0\u6b64\uff0c\u6700\u7ec8\u7684JSON\u5e94\u8be5\u5982\u4e0a\u8ff0\u6240\u793a\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u5386\u53f2\u4fe1\u4ef6\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u51fa\u6307\u5b9a\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u6211\u5f97\u4ed4\u7ec6\u770b\u770b\u7528\u6237\u7684\u8981\u6c42\u3002\u7528\u6237\u5e0c\u671b\u6211\u4f5c\u4e3a20\u4e16\u7eaa\u745e\u58eb\u5386\u53f2\u7684\u4e13\u5bb6\uff0c\u4ece\u4fe1\u4ef6\u4e2d\u63d0\u53d6\u56db\u4e2a\u5173\u952e\u4fe1\u606f\uff1a\u4fe1\u4ef6\u6807\u9898\u3001\u53d1\u4ef6\u4eba\u3001\u6536\u4ef6\u4eba\u548c\u53d1\u9001\u65e5\u671f\uff0c\u5e76\u4ee5JSON\u683c\u5f0f\u8fd4\u56de\uff0c\u6bcf\u4e2a\u503c\u90fd\u662f\u5217\u8868\u5f62\u5f0f\uff0c\u5373\u4f7f\u53ea\u6709\u4e00\u4e2a\u5143\u7d20\u3002\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u5c31\u8bbe\u4e3anull\u3002\\n\\n\u9996\u5148\uff0c\u6211\u9700\u8981\u4ed4\u7ec6\u67e5\u770b\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\u3002\u56fe\u7247\u663e\u793a\u7684\u662fBasler Personenschiffahrtsgesellschaft\uff08\u5df4\u585e\u5c14\u5ba2\u8fd0\u822a\u8fd0\u516c\u53f8\uff09\u7684\u4fe1\u5934\uff0c\u65e5\u671f\u662f1922\u5e7412\u670816\u65e5\uff0c\u5730\u70b9\u662f\u5df4\u585e\u5c14\u3002\u6536\u4ef6\u4eba\u662fBasler Rheinschiffahrt A.-G.\uff0c\u5730\u5740\u662fMarktgasse 5, Basel\u3002\u4fe1\u4ef6\u5185\u5bb9\u63d0\u5230\u4ed6\u4eec\u6536\u5230\u4e86\u5bf9\u65b912\u670815\u65e5\u7684\u4fe1\uff0c\u5e76\u786e\u8ba4\u4e86\u5408\u540c\u8349\u6848\u4e2d\u7684\u5ef6\u8fdf\u6761\u6b3e\uff0c\u5408\u540c\u5728\u6628\u5929\u7684\u80a1\u4e1c\u5927\u4f1a\u4e0a\u672a\u7ecf\u4fee\u6539\u901a\u8fc7\u3002\u8fd8\u63d0\u5230\u822a\u8fd0\u534f\u4f1a\u5e0c\u671b\u83b7\u5f97\u5ba2\u8fd0\u8239\u53ea\u7684\u9891\u7387\u6570\u636e\u7528\u4e8e\u5ba3\u4f20\u3002\\n\\n\u63a5\u4e0b\u6765\uff0c\u6211\u9700\u8981\u786e\u5b9a\u5404\u4e2a\u5b57\u6bb5\u3002\u4fe1\u4ef6\u6807\u9898\uff08letter_title\uff09\u5728\u56fe\u7247\u4e2d\u6ca1\u6709\u660e\u786e\u7ed9\u51fa\uff0c\u901a\u5e38\u6b63\u5f0f\u4fe1\u4ef6\u53ef\u80fd\u6ca1\u6709\u6807\u9898\uff0c\u6240\u4ee5\u8fd9\u91cc\u5e94\u8be5\u662fnull\u3002\u53d1\u4ef6\u4eba\uff08sender_persons\uff09\u662fBasler Personenschiffahrtsgesellschaft\uff0c\u4f46\u5177\u4f53\u4eba\u540d\u6ca1\u6709\u63d0\u5230\uff0c\u53ea\u6709\u516c\u53f8\u540d\u79f0\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u3002\u4e0d\u8fc7\u7528\u6237\u8981\u6c42\u7684\u662f\u4eba\u540d\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\uff0c\u53ea\u6709\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u7b7e\u540d\u90e8\u5206\u3002\u56fe\u7247\u5e95\u90e8\u6709\u201cDer Pr\u00e4sident\u201d\u548c\u201cDer Gesch\u00e4ftsf\u00fchrer\u201d\u7684\u7b7e\u540d\u4f4d\u7f6e\uff0c\u4f46\u540d\u5b57\u88ab\u6a21\u7cca\u5904\u7406\u4e86\uff0c\u65e0\u6cd5\u8fa8\u8ba4\uff0c\u6240\u4ee5\u53d1\u4ef6\u4eba\u53ef\u80fd\u53ea\u80fd\u586b\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u53ef\u80fd\u5e94\u8be5\u7528\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u662f\u4e2a\u4eba\u540d\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u3002\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0c\u6bd4\u5982\u201cLisa Simpson\u201d\u662f\u4e2a\u4eba\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u671f\u671b\u4eba\u540d\uff0c\u4f46\u5982\u679c\u6ca1\u6709\u7684\u8bdd\uff0c\u53ef\u80fd\u53ea\u80fd\u586bnull\uff1f\u6216\u8005\u53ef\u80fd\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff1f\\n\\n\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0c\u6bd4\u5982\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u4f46\u8fd9\u91cc\u7684\u60c5\u51b5\u662f\u516c\u53f8\u53d1\u51fa\u7684\u4fe1\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u5177\u4f53\u7684\u4eba\u540d\uff0c\u4f46\u56fe\u7247\u4e2d\u6ca1\u6709\u663e\u793a\u5177\u4f53\u7684\u4eba\u540d\uff0c\u53ea\u6709\u804c\u4f4d\u3002\u6240\u4ee5\u53ef\u80fd\u53d1\u4ef6\u4eba\u5e94\u8be5\u662fnull\uff0c\u6216\u8005\u7528\u516c\u53f8\u540d\u79f0\u3002\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u56fe\u7247\u3002\u5728\u4fe1\u4ef6\u7684\u672b\u5c3e\uff0c\u6709\u201cBasler Personenschiffahrtsgesellschaft\u201d\u4f5c\u4e3a\u53d1\u4ef6\u516c\u53f8\uff0c\u4e0b\u9762\u6709\u201cDer Pr\u00e4sident\u201d\u548c\u201cDer Gesch\u00e4ftsf\u00fchrer\u201d\u7684\u7b7e\u540d\uff0c\u4f46\u540d\u5b57\u88ab\u6a21\u7cca\u4e86\uff0c\u65e0\u6cd5\u8bc6\u522b\u3002\u56e0\u6b64\uff0c\u53d1\u4ef6\u4eba\u53ef\u80fd\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u7684\u4eba\u540d\uff0c\u53ea\u80fd\u586b\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u8981\u6c42\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u586bnull\uff0c\u6216\u8005\u7528\u516c\u53f8\u540d\u3002\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u8fd9\u91cc\u5e94\u8be5\u586bnull\uff0c\u56e0\u4e3a\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\u3002\u6216\u8005\u53ef\u80fd\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5224\u65ad\u3002\\n\\n\u6536\u4ef6\u4eba\uff08receiver_persons\uff09\u662fBasler Rheinschiffahrt A.-G.\uff0c\u5730\u5740\u662fMarktgasse 5, Basel\uff0c\u6240\u4ee5\u6536\u4ef6\u4eba\u662f\u8fd9\u4e2a\u516c\u53f8\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u4eba\u540d\uff0c\u4f46\u8fd9\u91cc\u4e5f\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586b\u516c\u53f8\u540d\uff0c\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u6536\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6bd4\u5982\u5e02\u957f\u548c\u6821\u957f\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u586b\u516c\u53f8\u540d\u4f5c\u4e3a\u6536\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u671f\u671b\u7684\u662f\u4eba\u540d\uff0c\u4f46\u5982\u679c\u6ca1\u6709\u7684\u8bdd\uff0c\u53ef\u80fd\u586bnull\uff1f\u6216\u8005\u53ef\u80fd\u516c\u53f8\u540d\u4f5c\u4e3a\u6536\u4ef6\u4eba\u3002\u9700\u8981\u770b\u7528\u6237\u7684\u8981\u6c42\uff0c\u7528\u6237\u8bf4\u201cName(s) of the person(s)\u201d\uff0c\u6240\u4ee5\u5982\u679c\u662f\u516c\u53f8\u7684\u8bdd\uff0c\u53ef\u80fd\u4e0d\u7b26\u5408\uff0c\u4f46\u53ef\u80fd\u5728\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u53ea\u80fd\u586b\u516c\u53f8\u540d\uff0c\u6216\u8005null\u3002\u4f46\u6839\u636e\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\uff0c\u6536\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586b\u516c\u53f8\u540d\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u586bnull\u3002\u4e0d\u8fc7\u53ef\u80fd\u7528\u6237\u5141\u8bb8\u516c\u53f8\u540d\u4f5c\u4e3a\u6536\u4ef6\u4eba\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u90fd\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u518d\u786e\u8ba4\u3002\\n\\n\u53d1\u9001\u65e5\u671f\uff08send_date\uff09\u662f1922\u5e7412\u670816\u65e5\uff0c\u6240\u4ee5\u5e94\u8be5\u8f6c\u6362\u4e3aISO\u683c\u5f0f1922-12-16\u3002\\n\\n\u73b0\u5728\uff0c\u6574\u7406\u4e00\u4e0b\uff1a\\n\\nletter_title\uff1a\u4fe1\u4ef6\u4e2d\u6ca1\u6709\u6807\u9898\uff0c\u6240\u4ee5null\u3002\\n\\nsender_persons\uff1a\u53d1\u4ef6\u516c\u53f8\u662fBasler Personenschiffahrtsgesellschaft\uff0c\u4f46\u5177\u4f53\u4eba\u540d\u672a\u77e5\uff0c\u6240\u4ee5\u53ef\u80fd\u586bnull\uff0c\u6216\u8005\u516c\u53f8\u540d\u3002\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u586bnull\uff0c\u4f46\u53ef\u80fd\u7528\u6237\u63a5\u53d7\u516c\u53f8\u540d\u3002\u9700\u8981\u770b\u7528\u6237\u7684\u8981\u6c42\uff0c\u7528\u6237\u8bf4\u201cName(s) of the person(s)\u201d\uff0c\u6240\u4ee5\u5982\u679c\u662f\u516c\u53f8\u7684\u8bdd\uff0c\u53ef\u80fd\u4e0d\u7b26\u5408\uff0c\u6240\u4ee5\u586bnull\u3002\\n\\nreceiver_persons\uff1a\u6536\u4ef6\u4eba\u662fBasler Rheinschiffahrt A.-G.\uff0c\u540c\u6837\u662f\u4e00\u4e2a\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u586bnull\uff0c\u6216\u8005\u516c\u53f8\u540d\u3002\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u6536\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u586bnull\u3002\\n\\n\u4f46\u53ef\u80fd\u7528\u6237\u5141\u8bb8\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u90fd\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u518d\u8003\u8651\u3002\u6216\u8005\u53ef\u80fd\u5728\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u90fd\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u5e94\u8be5\u586b\u516c\u53f8\u540d\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u53ef\u80fd\u586bnull\u3002\u4f46\u6839\u636e\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\uff0c\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u90fd\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586b\u516c\u53f8\u540d\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u5b58\u5728\u77db\u76fe\u3002\\n\\n\u6216\u8005\uff0c\u53ef\u80fd\u7528\u6237\u5141\u8bb8\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\uff0c\u5373\u4f7f\u793a\u4f8b\u4e2d\u662f\u4e2a\u4eba\u3002\u4f8b\u5982\uff0c\u5728\u5546\u4e1a\u4fe1\u51fd\u4e2d\uff0c\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u901a\u5e38\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586b\u516c\u53f8\u540d\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u90fd\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u6839\u636e\u5177\u4f53\u60c5\u51b5\u5904\u7406\u3002\\n\\n\u73b0\u5728\uff0c\u518d\u4ed4\u7ec6\u770b\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\uff1a\\n\\n\u53d1\u4ef6\u65b9\u662fBasler Personenschiffahrtsgesellschaft\uff0c\u4f4d\u4e8e\u4fe1\u5934\u3002\u6536\u4ef6\u65b9\u662fBasler Rheinschiffahrt A.-G.\uff0c\u5730\u5740\u5728Marktgasse 5, Basel\u3002\u6240\u4ee5\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u90fd\u662f\u516c\u53f8\uff0c\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\u3002\u56e0\u6b64\uff0csender_persons\u548creceiver_persons\u5e94\u8be5\u586b\u516c\u53f8\u540d\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586bnull\u3002\u4f46\u6839\u636e\u7528\u6237\u7684\u8981\u6c42\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u5c31\u586bnull\u3002\u4f46\u8fd9\u91cc\u7684\u4fe1\u606f\u5b58\u5728\uff0c\u53ea\u662f\u516c\u53f8\u540d\u800c\u4e0d\u662f\u4eba\u540d\u3002\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u671f\u671b\u7684\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5224\u65ad\u3002\\n\\n\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0c\u6bd4\u5982\u53d1\u4ef6\u4eba\u662fLisa Simpson\uff0c\u6536\u4ef6\u4eba\u662f\u5e02\u957f\u548c\u6821\u957f\uff0c\u90fd\u662f\u4e2a\u4eba\u3002\u6240\u4ee5\u5728\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u5982\u679c\u4fe1\u4ef6\u4e2d\u7684\u53d1\u4ef6\u4eba\u548c\u6536\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u53ef\u80fd\u5e94\u8be5\u586bnull\uff0c\u56e0\u4e3a\u7528\u6237\u8981\u6c42\u7684\u662f\u4eba\u540d\u3002\u4f46\u53ef\u80fd\u7528\u6237\u5141\u8bb8\u516c\u53f8\u540d\uff0c\u4f46\u9700\u8981\u770b\u7528\u6237\u7684\u5177\u4f53\u8981\u6c42\u3002\u7528\u6237\u7684\u95ee\u9898\u63cf\u8ff0\u4e2d\u8bf4\u201cName(s) of the person(s)\u201d\uff0c\u6240\u4ee5\u5982\u679c\u662f\u516c\u53f8\u7684\u8bdd\uff0c\u