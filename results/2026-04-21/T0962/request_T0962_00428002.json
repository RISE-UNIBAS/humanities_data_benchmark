9700\u8981\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u3002\u4f8b\u5982\uff0c\u5728\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u5982\u4f55\u5904\u7406\uff1f\\n\\n\u5047\u8bbe\u5728\u793a\u4f8b\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u4f46\u6839\u636e\u5e38\u89c1\u7684\u5b66\u672f\u5f15\u7528\uff0c\u6807\u9898\u524d\u7684\u540d\u5b57\u901a\u5e38\u662f\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u5728\u53c2\u8003\u5361\u7247\u4e2d\uff0c\u53ef\u80fd\u5f15\u7528\u7684\u662fSchomerus\u7684\u4f5c\u54c1\uff0c\u6240\u4ee5author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u7d22\u5f15\u5361\u7684\u5236\u4f5c\u8005\uff1f\\n\\n\u4f46\u6839\u636e\u89c4\u5219\uff0cauthor\u5e94\u8be5\u4ece\u5361\u7247\u4e2d\u63d0\u53d6\uff0c\u53ef\u80fd\u8fd9\u91cc\u7684author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u56fe\u4e66\u9986\u7684\u7f16\u76ee\u8005\uff1f\\n\\n\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u6839\u636e\u89c4\u5219\u4e2d\u7684\u4f8b\u5b50\u6765\u5224\u65ad\u3002\u4f8b\u5982\uff0c\u5728\u89c4\u5219\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u4f46\u6839\u636e\u5e38\u89c1\u7684\u5b66\u672f\u5f15\u7528\uff0c\u6807\u9898\u524d\u7684\u540d\u5b57\u901a\u5e38\u662f\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u5728\u53c2\u8003\u5361\u7247\u4e2d\uff0c\u53ef\u80fd\u5f15\u7528\u7684\u662fSchomerus\u7684\u4f5c\u54c1\uff0c\u6240\u4ee5author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u7d22\u5f15\u5361\u7684\u5236\u4f5c\u8005\uff1f\\n\\n\u4f46\u6839\u636e\u89c4\u5219\uff0cauthor\u5e94\u8be5\u4ece\u5361\u7247\u4e2d\u63d0\u53d6\uff0c\u53ef\u80fd\u8fd9\u91cc\u7684author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u56fe\u4e66\u9986\u7684\u7f16\u76ee\u8005\uff1f\\n\\n\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u3002\u4f8b\u5982\uff0c\u5728\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u5982\u4f55\u5904\u7406\uff1f\\n\\n\u5047\u8bbe\u5728\u793a\u4f8b\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u4f46\u6839\u636e\u5e38\u89c1\u7684\u5b66\u672f\u5f15\u7528\uff0c\u6807\u9898\u524d\u7684\u540d\u5b57\u901a\u5e38\u662f\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u5728\u53c2\u8003\u5361\u7247\u4e2d\uff0c\u53ef\u80fd\u5f15\u7528\u7684\u662fSchomerus\u7684\u4f5c\u54c1\uff0c\u6240\u4ee5author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u7d22\u5f15\u5361\u7684\u5236\u4f5c\u8005\uff1f\\n\\n\u4f46\u6839\u636e\u89c4\u5219\uff0cauthor\u5e94\u8be5\u4ece\u5361\u7247\u4e2d\u63d0\u53d6\uff0c\u53ef\u80fd\u8fd9\u91cc\u7684author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u56fe\u4e66\u9986\u7684\u7f16\u76ee\u8005\uff1f\\n\\n\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u6839\u636e\u89c4\u5219\u4e2d\u7684\u4f8b\u5b50\u6765\u5224\u65ad\u3002\u4f8b\u5982\uff0c\u5728\u89c4\u5219\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u4f46\u6839\u636e\u5e38\u89c1\u7684\u5b66\u672f\u5f15\u7528\uff0c\u6807\u9898\u524d\u7684\u540d\u5b57\u901a\u5e38\u662f\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u5728\u53c2\u8003\u5361\u7247\u4e2d\uff0c\u53ef\u80fd\u5f15\u7528\u7684\u662fSchomerus\u7684\u4f5c\u54c1\uff0c\u6240\u4ee5author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u7d22\u5f15\u5361\u7684\u5236\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u7d22\u5f15\u5361\uff0c\u5e76\u63d0\u53d6\u51fa\u7ed3\u6784\u5316\u7684JSON\u6570\u636e\u3002\u9996\u5148\uff0c\u6211\u5f97\u4ed4\u7ec6\u770b\u770b\u7528\u6237\u7ed9\u7684\u6307\u4ee4\u548c\u793a\u4f8b\uff0c\u786e\u4fdd\u81ea\u5df1\u7406\u89e3\u6b63\u786e\u3002\\n\\n\u9996\u5148\uff0c\u7528\u6237\u8981\u6c42\u6839\u636e\u7d22\u5f15\u5361\u7684\u4fe1\u606f\u751f\u6210\u4e00\u4e2a\u7b26\u5408\u7279\u5b9aJSON Schema\u7684\u54cd\u5e94\u3002\u8fd9\u4e2aSchema\u5305\u62ec\u56db\u4e2a\u4e3b\u8981\u90e8\u5206\uff1atype\u3001author\u3001publication\u548clibrary_reference\u3002\u6bcf\u4e2a\u90e8\u5206\u90fd\u6709\u5177\u4f53\u7684\u5b57\u6bb5\u8981\u6c42\uff0c\u6bd4\u5982type\u53ea\u80fd\u662f\u201cDissertation or thesis\u201d\u6216\u201cReference\u201d\uff0c\u800cauthor\u9700\u8981last_name\u548cfirst_name\uff0c\u5982\u679c\u53ea\u6709\u4e00\u4e2a\u540d\u5b57\u7684\u8bdd\uff0c\u5c31\u653e\u5728last_name\u91cc\uff0cfirst_name\u7559\u7a7a\u3002\\n\\n\u63a5\u4e0b\u6765\uff0c\u6211\u9700\u8981\u5206\u6790\u7528\u6237\u63d0\u4f9b\u7684\u7d22\u5f15\u5361\u5185\u5bb9\u3002\u56fe\u7247\u4e2d\u7684\u6587\u5b57\u662f\uff1a\\n\\nN a g e l, Martin\\ns.\\nS c h o m e r u s, Justus Christoph. Disputatio theologica de collegiali dicendi libertate...\\n\\n\u9996\u5148\uff0c\u6839\u636e\u89c4\u52191\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u5355\u72ec\u7684\u201cs.\u201d\u884c\uff0c\u90a3\u4e48type\u5c31\u662f\u201cReference\u201d\uff0c\u5426\u5219\u662f\u201cDissertation or thesis\u201d\u3002\u8fd9\u91cc\u786e\u5b9e\u6709\u4e00\u4e2a\u5355\u72ec\u7684\u201cs.\u201d\uff0c\u6240\u4ee5type\u5e94\u8be5\u662f\u201cReference\u201d\u3002\\n\\n\u7136\u540e\u5904\u7406author\u90e8\u5206\u3002\u8fd9\u91cc\u6709\u4e24\u4e2a\u540d\u5b57\uff1aNagel, Martin \u548c Schomerus, Justus Christoph\u3002\u4f46\u6839\u636e\u89c4\u5219\uff0cauthor\u5e94\u8be5\u53ea\u63d0\u53d6\u4e00\u4e2a\u4f5c\u8005\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5224\u65ad\u54ea\u4e2a\u662f\u4e3b\u8981\u4f5c\u8005\u3002\u901a\u5e38\uff0c\u7d22\u5f15\u5361\u4e0a\u7684\u7b2c\u4e00\u4e2a\u540d\u5b57\u53ef\u80fd\u662f\u4f5c\u8005\uff0c\u4f46\u6709\u65f6\u5019\u53ef\u80fd\u7b2c\u4e8c\u4e2a\u624d\u662f\u3002\u4e0d\u8fc7\u6839\u636e\u793a\u4f8b\u4e2d\u7684\u60c5\u51b5\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u540d\u5b57\u662f\u4f5c\u8005\uff0c\u800c\u7b2c\u4e8c\u4e2a\u662f\u4f5c\u54c1\u7684\u76f8\u5173\u4fe1\u606f\u3002\u4e0d\u8fc7\u9700\u8981\u4ed4\u7ec6\u770b\u5185\u5bb9\u3002\\n\\n\u4e0d\u8fc7\u4ed4\u7ec6\u770b\uff0c\u7b2c\u4e00\u884c\u662f\u201cNagel, Martin\u201d\uff0c\u7136\u540e\u4e0b\u4e00\u884c\u662f\u201cs.\u201d\uff0c\u63a5\u7740\u662f\u201cSchomerus, Justus Christoph. Disputatio...\u201d\u3002\u53ef\u80fd\u8fd9\u91cc\u7684\u7ed3\u6784\u662f\uff0cNagel\u662f\u4f5c\u8005\uff0c\u800cSchomerus\u662f\u53e6\u4e00\u4e2a\u76f8\u5173\u4eba\u7269\uff0c\u6bd4\u5982\u88ab\u5f15\u7528\u7684\u4eba\uff1f\u6216\u8005\u53ef\u80fdSchomerus\u662f\u4f5c\u8005\uff0c\u800cNagel\u662f\u5176\u4ed6\u4fe1\u606f\uff1f\\n\\n\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u66f4\u591a\u7684\u4e0a\u4e0b\u6587\uff0c\u4f46\u6839\u636e\u5e38\u89c1\u7684\u7d22\u5f15\u5361\u683c\u5f0f\uff0c\u901a\u5e38\u4f5c\u8005\u4f1a\u5728\u6700\u524d\u9762\u3002\u4f46\u8fd9\u91cc\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\u4f8b\u5982\uff0c\u53ef\u80fdNagel\u662f\u4f5c\u8005\uff0c\u800cSchomerus\u662f\u8bba\u6587\u7684\u4e3b\u9898\u6216\u76f8\u5173\u4eba\u7269\uff1f\u6216\u8005\u53ef\u80fdSchomerus\u662f\u4f5c\u8005\uff0c\u800cNagel\u662f\u5176\u4ed6\u4fe1\u606f\uff1f\\n\\n\u4e0d\u8fc7\u6839\u636e\u89c4\u52192\uff0c\u5982\u679c\u53ea\u6709\u4e00\u4e2a\u540d\u5b57\uff0c\u5c31\u653e\u5728last_name\uff0c\u5426\u5219\u5206\u5f00\u3002\u4f46\u8fd9\u91cc\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u9700\u8981\u786e\u5b9a\u54ea\u4e2a\u662f\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u53ef\u80fd\u201cSchomerus, Justus Christoph\u201d\u662f\u4f5c\u8005\uff0c\u800c\u201cNagel, Martin\u201d\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u5bfc\u5e08\u6216\u8005\u76f8\u5173\u4eba\u7269\uff1f\u6216\u8005\u53ef\u80fdNagel\u662f\u4f5c\u8005\uff0c\u800cSchomerus\u662f\u8bba\u6587\u4e2d\u8ba8\u8bba\u7684\u4eba\u7269\uff1f\\n\\n\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u6839\u636e\u5e38\u89c1\u7684\u5b66\u672f\u5f15\u7528\u683c\u5f0f\u6765\u5224\u65ad\u3002\u901a\u5e38\uff0c\u8bba\u6587\u7684\u6807\u9898\u524d\u4f1a\u6709\u4f5c\u8005\u7684\u540d\u5b57\u3002\u4f8b\u5982\uff0c\u5728\u201cSchomerus, Justus Christoph. Disputatio...\u201d\u8fd9\u91cc\uff0c\u53ef\u80fdSchomerus\u662f\u4f5c\u8005\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u7d22\u5f15\u5361\u7684\u5236\u4f5c\u8005\u6216\u8005\u76f8\u5173\u4eba\u7269\uff1f\\n\\n\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u540d\u5b57\u662f\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u5728\u793a\u4f8b\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u9700\u8981\u770b\u54ea\u4e2a\u662f\u4e3b\u8981\u7684\u3002\u4f46\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u66f4\u591a\u7684\u7ebf\u7d22\u3002\u4f8b\u5982\uff0c\u5982\u679c\u201cs.\u201d\u8868\u793a\u53c2\u8003\uff0c\u90a3\u4e48\u53ef\u80fdSchomerus\u662f\u88ab\u5f15\u7528\u7684\u4f5c\u8005\uff0c\u800cNagel\u662f\u5f53\u524d\u5361\u7247\u7684\u4f5c\u8005\uff1f\u6216\u8005\u53ef\u80fdNagel\u662f\u4f5c\u8005\uff0c\u800cSchomerus\u662f\u8bba\u6587\u7684\u4e3b\u9898\uff1f\\n\\n\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u89c4\u5219\u3002\u89c4\u52192\u8bf4\uff0c\u5982\u679c\u53ea\u6709\u4e00\u4e2a\u540d\u5b57\uff0c\u653e\u5728last_name\uff0c\u5426\u5219\u5206\u5f00\u3002\u4f46\u8fd9\u91cc\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u9700\u8981\u786e\u5b9a\u54ea\u4e2a\u662f\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u540d\u5b57\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5176\u4ed6\u4fe1\u606f\uff1f\\n\\n\u6216\u8005\uff0c\u53ef\u80fd\u8fd9\u91cc\u7684\u7ed3\u6784\u662f\uff0cNagel\u662f\u4f5c\u8005\uff0c\u800cSchomerus\u662f\u8bba\u6587\u4e2d\u8ba8\u8bba\u7684\u4eba\u7269\uff0c\u6240\u4ee5author\u5e94\u8be5\u662fNagel, Martin\u3002\u4f46\u8fd9\u6837\u7684\u8bdd\uff0cpublication\u7684title\u5e94\u8be5\u662f\u201cDisputatio theologica de collegiali dicendi libertate...\u201d\uff0c\u800cauthor\u662fNagel\u3002\u4f46\u901a\u5e38\uff0c\u8bba\u6587\u7684\u6807\u9898\u524d\u7684\u540d\u5b57\u662f\u4f5c\u8005\uff0c\u6240\u4ee5\u53ef\u80fdSchomerus\u662f\u4f5c\u8005\uff0c\u800cNagel\u662f\u5176\u4ed6\u4fe1\u606f\uff1f\\n\\n\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u66f4\u591a\u7684\u4e0a\u4e0b\u6587\uff0c\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0c\u53ef\u80fd\u5e94\u8be5\u5c06\u7b2c\u4e00\u4e2a\u540d\u5b57\u4f5c\u4e3a\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u5728\u793a\u4f8b\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u4f46\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\\n\\n\u6216\u8005\uff0c\u53ef\u80fd\u8fd9\u91cc\u7684\u201cs.\u201d\u8868\u793a\u53c2\u8003\uff0c\u6240\u4ee5type\u662fReference\uff0c\u800cauthor\u662fSchomerus\uff0c\u56e0\u4e3a\u6807\u9898\u524d\u7684\u540d\u5b57\u901a\u5e38\u662f\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u5728\u53c2\u8003\u5361\u7247\u4e2d\uff0c\u53ef\u80fd\u5f15\u7528\u7684\u662fSchomerus\u7684\u4f5c\u54c1\uff0c\u800cNagel\u53ef\u80fd\u662f\u5f53\u524d\u5361\u7247\u7684\u5236\u4f5c\u8005\u6216\u8005\u76f8\u5173\u4eba\u7269\uff1f\\n\\n\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u6839\u636e\u89c4\u5219\u4e2d\u7684\u4f8b\u5b50\u6765\u5224\u65ad\u3002\u4f8b\u5982\uff0c\u5728\u89c4\u5219\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u201cs.\u201d\uff0c\u5219type\u662fReference\uff0c\u800cauthor\u53ef\u80fd\u662f\u88ab\u5f15\u7528\u7684\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u5728\u53c2\u8003\u5361\u7247\u4e2d\uff0cauthor\u5e94\u8be5\u662f\u88ab\u5f15\u7528\u7684\u4f5c\u54c1\u7684\u4f5c\u8005\uff0c\u5373Schomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u7d22\u5f15\u5361\u7684\u4f5c\u8005\uff1f\\n\\n\u4f46\u6839\u636e\u89c4\u52192\uff0cauthor\u5e94\u8be5\u4ece\u5361\u7247\u4e2d\u63d0\u53d6\uff0c\u53ef\u80fd\u8fd9\u91cc\u7684author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u56fe\u4e66\u9986\u7684\u7f16\u76ee\u8005\uff1f\\n\\n\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u3002\u4f8b\u5982\uff0c\u5728\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u5982\u4f55\u5904\u7406\uff1f\\n\\n\u5047\u8bbe\u5728\u793a\u4f8b\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u4f46\u6839\u636e\u5e38\u89c1\u7684\u5b66\u672f\u5f15\u7528\uff0c\u6807\u9898\u524d\u7684\u540d\u5b57\u901a\u5e38\u662f\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u201cSchomerus, Justus Christoph. Disputatio...\u201d\u4e2d\u7684Schomerus\u5e94\u8be5\u662f\u4f5c\u8005\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u5bfc\u5e08\u6216\u8005\u76f8\u5173\u4eba\u7269\uff1f\\n\\n\u4f46\u6839\u636e\u89c4\u5219\uff0cauthor\u5e94\u8be5\u4ece\u5361\u7247\u4e2d\u63d0\u53d6\uff0c\u53ef\u80fd\u8fd9\u91cc\u7684author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u56fe\u4e66\u9986\u7684\u7f16\u76ee\u8005\uff1f\\n\\n\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u6839\u636e\u89c4\u5219\u4e2d\u7684\u4f8b\u5b50\u6765\u5224\u65ad\u3002\u4f8b\u5982\uff0c\u5728\u89c4\u5219\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u4f46\u6839\u636e\u5e38\u89c1\u7684\u5b66\u672f\u5f15\u7528\uff0c\u6807\u9898\u524d\u7684\u540d\u5b57\u901a\u5e38\u662f\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u5728\u53c2\u8003\u5361\u7247\u4e2d\uff0c\u53ef\u80fd\u5f15\u7528\u7684\u662fSchomerus\u7684\u4f5c\u54c1\uff0c\u6240\u4ee5author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u7d22\u5f15\u5361\u7684\u5236\u4f5c\u8005\uff1f\\n\\n\u4f46\u6839\u636e\u89c4\u5219\uff0cauthor\u5e94\u8be5\u4ece\u5361\u7247\u4e2d\u63d0\u53d6\uff0c\u53ef\u80fd\u8fd9\u91cc\u7684author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u56fe\u4e66\u9986\u7684\u7f16\u76ee\u8005\uff1f\\n\\n\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u3002\u4f8b\u5982\uff0c\u5728\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u5982\u4f55\u5904\u7406\uff1f\\n\\n\u5047\u8bbe\u5728\u793a\u4f8b\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u4f46\u6839\u636e\u5e38\u89c1\u7684\u5b66\u672f\u5f15\u7528\uff0c\u6807\u9898\u524d\u7684\u540d\u5b57\u901a\u5e38\u662f\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u5728\u53c2\u8003\u5361\u7247\u4e2d\uff0c\u53ef\u80fd\u5f15\u7528\u7684\u662fSchomerus\u7684\u4f5c\u54c1\uff0c\u6240\u4ee5author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u7d22\u5f15\u5361\u7684\u5236\u4f5c\u8005\uff1f\\n\\n\u4f46\u6839\u636e\u89c4\u5219\uff0cauthor\u5e94\u8be5\u4ece\u5361\u7247\u4e2d\u63d0\u53d6\uff0c\u53ef\u80fd\u8fd9\u91cc\u7684author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u56fe\u4e66\u9986\u7684\u7f16\u76ee\u8005\uff1f\\n\\n\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u6839\u636e\u89c4\u5219\u4e2d\u7684\u4f8b\u5b50\u6765\u5224\u65ad\u3002\u4f8b\u5982\uff0c\u5728\u89c4\u5219\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u4f46\u6839\u636e\u5e38\u89c1\u7684\u5b66\u672f\u5f15\u7528\uff0c\u6807\u9898\u524d\u7684\u540d\u5b57\u901a\u5e38\u662f\u4f5c\u8005\u3002\u4f8b\u5982\uff0c\u5728\u53c2\u8003\u5361\u7247\u4e2d\uff0c\u53ef\u80fd\u5f15\u7528\u7684\u662fSchomerus\u7684\u4f5c\u54c1\uff0c\u6240\u4ee5author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u7d22\u5f15\u5361\u7684\u5236\u4f5c\u8005\uff1f\\n\\n\u4f46\u6839\u636e\u89c4\u5219\uff0cauthor\u5e94\u8be5\u4ece\u5361\u7247\u4e2d\u63d0\u53d6\uff0c\u53ef\u80fd\u8fd9\u91cc\u7684author\u662fSchomerus\uff0c\u800cNagel\u53ef\u80fd\u662f\u5176\u4ed6\u4fe1\u606f\uff0c\u6bd4\u5982\u56fe\u4e66\u9986\u7684\u7f16\u76ee\u8005\uff1f\\n\\n\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u3002\u4f8b\u5982\uff0c\u5728\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u5982\u4f55\u5904\u7406\uff1f\\n\\n\u5047\u8bbe\u5728\u793a\u4f8b\u4e2d\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u7b2c\u4e00\u4e2a\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u4f46\u6839\u636e\u5e38\u89c1\u7684\u5b66\u672f\u5f15\u7528\uff0c\u6807\u9898\u524d\u7684\u540d\u5b57\u901a\u5