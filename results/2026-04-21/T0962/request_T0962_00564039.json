u5bf9\u5e948\u00b0\uff0c\u6240\u4ee5\u53ef\u80fd\u683c\u5f0f\u5b57\u6bb5\u586b8\u00b0\u3002\u4f46\u9700\u8981\u786e\u8ba4\u3002\u6216\u8005\u53ef\u80fd\u539f\u6587\u4e2d\u76848\u00b0\u662f\u683c\u5f0f\uff0c\u800cIn-8\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u66f4\u4ed4\u7ec6\u5730\u770b\u539f\u6587\u7ed3\u6784\u3002\u4f8b\u5982\uff0c\u539f\u6587\u4e2d\u7684\u201cIn-8, 179 p. [349] 8\u00b0 F. 36509\u201d\u53ef\u80fd\u8868\u793a\u5f00\u672c\u662fIn-8\uff0c\u9875\u6570179\uff0c\u603b\u9875\u6570349\uff0c\u683c\u5f0f8\u00b0\uff0c\u7136\u540eF.36509\u662f\u4e66\u67b6\u53f7\u3002\u6240\u4ee5\u683c\u5f0f\u5b57\u6bb5\u5e94\u586b8\u00b0\u3002\u56e0\u6b64\uff0c\u683c\u5f0f\u662f8\u00b0\u3002\\n\\n\u7136\u540e\u662f\u56fe\u4e66\u9986\u53c2\u8003\u4fe1\u606f\u3002\u4e66\u67b6\u53f7\u53ef\u80fd\u4ee5Diss.\u6216AT\u5f00\u5934\uff0c\u6216\u8005\u6807\u8bb0\u4e3aStandort\u3002\u8fd9\u91cc\u770b\u5230\u7684\u662fF. 36509\uff0c\u53ef\u80fd\u5c5e\u4e8e\u4e66\u67b6\u53f7\u3002\u4f46\u89c4\u52194\u63d0\u5230\u4e66\u67b6\u53f7\u53ef\u80fd\u4ee5Diss.\u6216AT\u5f00\u5934\uff0c\u4f46\u8fd9\u91cc\u6ca1\u6709\uff0c\u6240\u4ee5\u53ef\u80fd\u76f4\u63a5\u53d6F. 36509\u3002\u4e0d\u8fc7\u9700\u8981\u770b\u662f\u5426\u6709\u5176\u4ed6\u90e8\u5206\u3002\u4f8b\u5982\uff0c\u539f\u6587\u4e2d\u7684\u201c8\u00b0 F. 36509\u201d\u53ef\u80fdF.36509\u662f\u4e66\u67b6\u53f7\u3002\u6240\u4ee5shelfmark\u586bF. 36509\u3002\u4e3b\u9898\u90e8\u5206\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u7ed9\u51fa\uff0c\u4f46\u53ef\u80fd\u4ece\u6807\u9898\u6216\u5185\u5bb9\u4e2d\u63d0\u53d6\u5173\u952e\u8bcd\u3002\u4f8b\u5982\uff0c\u6807\u9898\u4e2d\u7684\u201cautorit\u00e9 de la chose jug\u00e9e\u201d\u548c\u201csolidarit\u00e9 passive\u201d\u53ef\u80fd\u4f5c\u4e3a\u4e3b\u9898\uff0c\u4f46\u89c4\u52195\u63d0\u5230\u5982\u679c\u7f3a\u5931\u5219\u7559\u7a7a\u3002\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u7684\u4e3b\u9898\u5206\u7c7b\uff0c\u6240\u4ee5subjects\u7559\u7a7a\u3002\\n\\n\u73b0\u5728\u9700\u8981\u68c0\u67e5\u6bcf\u4e2a\u5b57\u6bb5\u662f\u5426\u7b26\u5408\u8981\u6c42\uff1a\\n\\n\u7c7b\u578b\uff1aDissertation or thesis\uff0c\u6b63\u786e\u3002\\n\\n\u4f5c\u8005\uff1alast_name\u662fSEILER\uff0cfirst_name\u662fPierre\uff0c\u6b63\u786e\u3002\\n\\n\u51fa\u7248\u4fe1\u606f\uff1a\\n\u6807\u9898\u6b63\u786e\uff0c\u5e74\u4efd1933\u4f5c\u4e3a\u6574\u6570\uff0c\u5730\u70b9Paris\uff0c\u9875\u6570179\uff0c\u51fa\u7248\u793eF. Loviton\uff0c\u683c\u5f0f8\u00b0\u3002\u8fd9\u91cc\u9700\u8981\u6ce8\u610f\u9875\u6570\u662f\u5426\u8981\u5904\u7406\uff0c\u539f\u6587\u662f179 p.\uff0c\u6240\u4ee5\u76f4\u63a5\u53d6179\uff0c\u53bb\u6389p.\u3002\u4f46\u89c4\u52193\u63d0\u5230\u9875\u6570\u8981\u79fb\u9664\u201cS.\u201d\u540e\u7f00\uff0c\u8fd9\u91cc\u6ca1\u6709\uff0c\u6240\u4ee5\u6ca1\u95ee\u9898\u3002\\n\\n\u56fe\u4e66\u9986\u53c2\u8003\uff1ashelfmark\u662fF. 36509\uff0csubjects\u7559\u7a7a\u3002\\n\\n\u73b0\u5728\u9700\u8981\u786e\u4fdd\u6240\u6709\u5b57\u6bb5\u90fd\u6b63\u786e\uff0c\u5e76\u4e14\u6ca1\u6709\u9057\u6f0f\u3002\u4f8b\u5982\uff0c\u662f\u5426\u6709\u5176\u4ed6\u53ef\u80fd\u7684\u4e66\u67b6\u53f7\uff1f\u6bd4\u5982\u539f\u6587\u4e2d\u7684\u201c[349]\u201d\u53ef\u80fd\u662f\u6307\u603b\u9875\u6570\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u9875\u6570\u662f179\uff0c\u6240\u4ee5\u6ca1\u95ee\u9898\u3002\u53e6\u5916\uff0c\u662f\u5426\u6709\u5176\u4ed6\u4e3b\u9898\u4fe1\u606f\uff1f\u53ef\u80fd\u6ca1\u6709\uff0c\u6240\u4ee5subjects\u7559\u7a7a\u3002\\n\\n\u6700\u540e\uff0c\u68c0\u67e5JSON\u7ed3\u6784\u662f\u5426\u7b26\u5408\u63d0\u4f9b\u7684Schema\uff0c\u786e\u4fdd\u6240\u6709\u5fc5\u586b\u5b57\u6bb5\u90fd\u5b58\u5728\uff0c\u7c7b\u578b\u6b63\u786e\uff0c\u6ca1\u6709\u989d\u5916\u5c5e\u6027\u3002\u4f8b\u5982\uff0c\u5e74\u4efd\u662f\u6574\u6570\uff0c\u5176\u4ed6\u5b57\u7b26\u4e32\u5b57\u6bb5\u6b63\u786e\uff0c\u7a7a\u5b57\u7b26\u4e32\u5904\u7406\u6b63\u786e\u3002\\n\\n\u53ef\u80fd\u9700\u8981\u6ce8\u610f\u7684\u5730\u65b9\uff1a\\n- \u683c\u5f0f\u5b57\u6bb5\u662f\u5426\u6b63\u786e\uff0c\u662f\u5426\u5e94\u8be5\u53d6In-8\u8fd8\u662f8\u00b0\u3002\u6839\u636e\u89c4\u5219\uff0c\u683c\u5f0f\u901a\u5e38\u662f8\u00b0\u30018'\u62164\u00b0\uff0c\u6240\u4ee5\u8fd9\u91cc\u5e94\u53d68\u00b0\u3002\\n- \u4e66\u67b6\u53f7\u662f\u5426\u6b63\u786e\uff0cF. 36509\u662f\u5426\u7b26\u5408\u8981\u6c42\uff0c\u867d\u7136\u89c4\u5219\u63d0\u5230\u53ef\u80fd\u4ee5Diss.\u6216AT\u5f00\u5934\uff0c\u4f46\u8fd9\u91cc\u6ca1\u6709\uff0c\u6240\u4ee5\u76f4\u63a5\u586b\u5199\u3002\\n- \u4e3b\u9898\u90e8\u5206\u662f\u5426\u6709\u53ef\u80fd\u4ece\u6807\u9898\u4e2d\u63d0\u53d6\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u5982\u679c\u6ca1\u6709\u660e\u786e\u7684\u4e3b\u9898\u5206\u7c7b\uff0c\u5c31\u7559\u7a7a\u3002\\n\\n\u786e\u8ba4\u6240\u6709\u90e8\u5206\u540e\uff0c\u751f\u6210\u6b63\u786e\u7684JSON\u5bf9\u8c61\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u5386\u53f2\u8bba\u6587\u7d22\u5f15\u5361\uff0c\u5e76\u63d0\u53d6\u51fa\u7ed3\u6784\u5316\u7684JSON\u6570\u636e\u3002\u9996\u5148\uff0c\u6211\u5f97\u4ed4\u7ec6\u9605\u8bfb\u7528\u6237\u7ed9\u7684\u6307\u4ee4\u548c\u793a\u4f8b\uff0c\u786e\u4fdd\u81ea\u5df1\u5b8c\u5168\u7406\u89e3\u6bcf\u4e2a\u6b65\u9aa4\u7684\u8981\u6c42\u3002\\n\\n\u9996\u5148\uff0c\u7528\u6237\u8981\u6c42\u6839\u636e\u7d22\u5f15\u5361\u7684\u4fe1\u606f\u751f\u6210\u4e00\u4e2a\u7b26\u5408\u7279\u5b9aJSON Schema\u7684\u54cd\u5e94\u3002\u6211\u9700\u8981\u6309\u7167\u7ed9\u5b9a\u7684\u89c4\u5219\u6765\u63d0\u53d6\u5404\u4e2a\u5b57\u6bb5\u3002\u8ba9\u6211\u5148\u770b\u4e00\u4e0b\u7528\u6237\u63d0\u4f9b\u7684\u7d22\u5f15\u5361\u5185\u5bb9\uff1a\\n\\nSEILER (Pierre). \u2014 Universit\u00e9 de Paris, Facult\u00e9 de droit. L'Autorit\u00e9 de la chose jug\u00e9e en mati\u00e8re de solidarit\u00e9 passive. Th\u00e8se pour le doctorat pr\u00e9sent\u00e9e... par Pierre Seiler... \u2014 Paris, F. Loviton, 1933. In-8, 179 p. [349] 8\u00b0 F. 36509\\n\\n\u63a5\u4e0b\u6765\uff0c\u6211\u9700\u8981\u6309\u7167\u63d0\u53d6\u89c4\u5219\u9010\u4e00\u5904\u7406\u6bcf\u4e2a\u90e8\u5206\u3002\\n\\n\u9996\u5148\u662f\u786e\u5b9a\u5361\u7247\u7c7b\u578b\u3002\u89c4\u52191\u6307\u51fa\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u5355\u72ec\u7684\u201cs.\u201d\u884c\uff0c\u5219\u662f\u201cReference\u201d\uff0c\u5426\u5219\u662f\u201cDissertation or thesis\u201d\u3002\u8fd9\u91cc\u6ca1\u6709\u770b\u5230\u201cs.\u201d\uff0c\u6240\u4ee5\u7c7b\u578b\u5e94\u8be5\u662f\u201cDissertation or thesis\u201d\u3002\\n\\n\u7136\u540e\u662f\u4f5c\u8005\u4fe1\u606f\u3002\u89c4\u52192\u8981\u6c42\u63d0\u53d6\u59d3\u6c0f\u548c\u540d\u5b57\u3002\u8fd9\u91cc\u4f5c\u8005\u663e\u793a\u4e3aSEILER (Pierre)\uff0c\u6240\u4ee5\u59d3\u6c0f\u662fSEILER\uff0c\u540d\u5b57\u662fPierre\u3002\u9700\u8981\u786e\u4fdd\u540d\u5b57\u548c\u59d3\u6c0f\u6b63\u786e\u5206\u5f00\uff0c\u8fd9\u91cc\u5e94\u8be5\u6ca1\u95ee\u9898\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u51fa\u7248\u4fe1\u606f\u3002\u6807\u9898\u662f\u201cL'Autorit\u00e9 de la chose jug\u00e9e en mati\u00e8re de solidarit\u00e9 passive\u201d\u3002\u5e74\u4efd\u662f1933\uff0c\u9700\u8981\u4f5c\u4e3a\u6574\u6570\u3002\u51fa\u7248\u5730\u662fParis\uff0c\u51fa\u7248\u793e\u662fF. Loviton\u3002\u9875\u6570\u662f179 p.\uff0c\u4f46\u89c4\u52193\u63d0\u5230\u8981\u79fb\u9664\u201cS.\u201d\u540e\u7f00\uff0c\u8fd9\u91cc\u6ca1\u6709\uff0c\u6240\u4ee5\u76f4\u63a5\u4fdd\u7559179\u3002\u683c\u5f0f\u662fIn-8\uff0c\u4f46\u89c4\u52193\u63d0\u5230\u683c\u5f0f\u901a\u5e38\u662f8\u00b0\u30018'\u62164\u00b0\uff0c\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u6ce8\u610f\u3002\u539f\u6587\u4e2d\u7684\u683c\u5f0f\u662fIn-8\uff0c\u4f46\u540e\u9762\u8fd8\u67098\u00b0 F. 36509\uff0c\u53ef\u80fd\u8fd9\u91cc\u76848\u00b0\u662f\u683c\u5f0f\uff0c\u800cIn-8\u53ef\u80fd\u6307\u7684\u662f\u5f00\u672c\u3002\u9700\u8981\u786e\u8ba4\u54ea\u4e2a\u662f\u6b63\u786e\u7684\u3002\u6839\u636e\u89c4\u5219\uff0c\u683c\u5f0f\u5e94\u53d6\u5355\u4e2a\u503c\uff0c\u53ef\u80fd\u8fd9\u91cc\u5e94\u8be5\u53d68\u00b0\uff0c\u56e0\u4e3a\u540e\u9762\u660e\u786e\u5199\u4e868\u00b0\uff0c\u800cIn-8\u53ef\u80fd\u5c5e\u4e8e\u5176\u4ed6\u4fe1\u606f\u3002\u4e0d\u8fc7\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u4e00\u4e0b\u539f\u6587\u3002\u539f\u6587\u4e2d\u7684\u63cf\u8ff0\u662f\u201cIn-8, 179 p. [349] 8\u00b0 F. 36509\u201d\uff0c\u53ef\u80fd\u8fd9\u91cc\u7684In-8\u662f\u5f00\u672c\uff0c\u800c8\u00b0\u662f\u683c\u5f0f\u3002\u4f46\u6839\u636e\u89c4\u5219\uff0c\u683c\u5f0f\u5b57\u6bb5\u5e94\u586b\u5199\u59828\u00b0\u8fd9\u6837\u7684\u503c\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u53d68\u00b0\u3002\u4e0d\u8fc7\u9700\u8981\u786e\u8ba4\u3002\u6216\u8005\u53ef\u80fdIn-8\u662f\u683c\u5f0f\uff0c\u800c8\u00b0\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\u4f8b\u5982\uff0cIn-8\u53ef\u80fd\u6307\u7684\u662f\u5f00\u672c\u5927\u5c0f\uff0c\u800c8\u00b0\u53ef\u80fd\u4e5f\u662f\u540c\u6837\u7684\u610f\u601d\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u683c\u5f0f\u5b57\u6bb5\u5e94\u586b\u5199\u59828\u00b0\u8fd9\u6837\u7684\u503c\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u53d68\u00b0\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\u4e2d\uff0c\u683c\u5f0f\u662fIn-8\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u5e94\u8be5\u8f6c\u6362\u4e3a8\u00b0\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u6839\u636e\u5e38\u89c1\u683c\u5f0f\u6765\u5224\u65ad\u3002\u4f8b\u5982\uff0cIn-8\u901a\u5e38\u5bf9\u5e948\u00b0\uff0c\u6240\u4ee5\u53ef\u80fd\u683c\u5f0f\u5b57\u6bb5\u586b8\u00b0\u3002\u4f46\u9700\u8981\u786e\u8ba4\u3002\u6216\u8005\u53ef\u80fd\u539f\u6587\u4e2d\u76848\u00b0\u662f\u683c\u5f0f\uff0c\u800cIn-8\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u66f4\u4ed4\u7ec6\u5730\u770b\u539f\u6587\u7ed3\u6784\u3002\u4f8b\u5982\uff0c\u539f\u6587\u4e2d\u7684\u201cIn-8, 179 p. [349] 8\u00b0 F. 36509\u201d\u53ef\u80fd\u8868\u793a\u5f00\u672c\u662fIn-8\uff0c\u9875\u6570179\uff0c\u603b\u9875\u65