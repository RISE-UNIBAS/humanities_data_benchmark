u4e8e\u8bba\u6587\u7684\u63d0\u4ea4\u65e5\u671f\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u51fa\u7248\u5e74\u4efd\u5df2\u7ecf\u63d0\u53d6\u4e3a1935\uff0c\u6240\u4ee5\u4e0d\u9700\u8981\u989d\u5916\u5904\u7406\u3002\u53e6\u5916\uff0cBonn, Med. Diss.\u53ef\u80fd\u8868\u793a\u8fd9\u662f\u6ce2\u6069\u5927\u5b66\u7684\u533b\u5b66\u8bba\u6587\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u8fd9\u4e9b\u4fe1\u606f\u53ef\u80fd\u4e0d\u9700\u8981\u5305\u542b\u5728JSON\u4e2d\uff0c\u9664\u975e\u6709\u7279\u5b9a\u7684\u5b57\u6bb5\u3002\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684Schema\uff0cpublication\u4e2d\u7684publisher\u662fBecher\uff0c\u800c\u5730\u70b9\u662fBr\u00fchl-K\u00f6ln\uff0c\u53ef\u80fdBonn\u662f\u53e6\u4e00\u4e2a\u5730\u70b9\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0cplace\u5e94\u53d6\u51fa\u7248\u5730\uff0c\u5373Br\u00fchl-K\u00f6ln\u3002\\n\\n\u6700\u540e\uff0c\u786e\u4fdd\u6240\u6709\u5fc5\u586b\u5b57\u6bb5\u90fd\u5b58\u5728\uff0c\u6ca1\u6709\u4f7f\u7528null\uff0c\u800c\u662f\u7528\u7a7a\u5b57\u7b26\u4e32\u3002\u4f8b\u5982\uff0csubjects\u548cpublisher\u5982\u679c\u6709\u7684\u8bdd\u8981\u586b\uff0c\u5426\u5219\u7559\u7a7a\u3002\u8fd9\u91ccpublisher\u662fBecher\uff0c\u6240\u4ee5\u586b\u4e0a\u3002shelfmark\u662fU 35. 3723\uff0csubjects\u6ca1\u6709\u660e\u786e\u63d0\u5230\uff0c\u6240\u4ee5\u7559\u7a7a\u3002\\n\\n\u73b0\u5728\uff0c\u628a\u8fd9\u4e9b\u4fe1\u606f\u6574\u7406\u6210JSON\u7ed3\u6784\uff0c\u786e\u4fdd\u7b26\u5408\u7528\u6237\u63d0\u4f9b\u7684Schema\u3002\u68c0\u67e5\u6bcf\u4e2a\u5b57\u6bb5\u662f\u5426\u6b63\u786e\uff0c\u7279\u522b\u662f\u7c7b\u578b\u662f\u5426\u6b63\u786e\uff0c\u6bd4\u5982year\u662f\u6574\u6570\uff0c\u5176\u4ed6\u5b57\u7b26\u4e32\u662f\u5426\u6b63\u786e\u5904\u7406\u3002\u786e\u8ba4\u6ca1\u6709\u591a\u4f59\u7684\u4fe1\u606f\uff0c\u6bd4\u5982\u65e5\u671f\u4e2d\u7684\u5177\u4f53\u6708\u4efd\u548c\u65e5\u5b50\u4e0d\u9700\u8981\u5305\u542b\u5728year\u91cc\uff0c\u53ea\u53d6\u5e74\u4efd1935\u3002\\n\\n\u53ef\u80fd\u9700\u8981\u6ce8\u610f\u7684\u5730\u65b