230\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u5355\u72ec\u7684\u201cs.\u201d\u884c\uff0c\u5c31\u662f\u53c2\u8003\u6587\u732e\uff0c\u5426\u5219\u662f\u8bba\u6587\u3002\u73b0\u5728\u770b\u7528\u6237\u63d0\u4f9b\u7684\u56fe\u7247\u63cf\u8ff0\uff0c\u91cc\u9762\u6ca1\u6709\u63d0\u5230\u201cs.\u201d\uff0c\u6240\u4ee5\u5e94\u8be5\u5f52\u7c7b\u4e3a\u201cDissertation or thesis\u201d\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u4f5c\u8005\u90e8\u5206\u3002\u5361\u7247\u4e0a\u5199\u7684\u662f\u201cSP\u00c9DER.\u201d\uff0c\u770b\u8d77\u6765\u53ea\u6709\u59d3\u6c0f\uff0c\u6ca1\u6709\u540d\u5b57\u3002\u6839\u636e\u89c4\u5219\uff0c\u5982\u679c\u53ea\u6709\u4e00\u4e2a\u540d\u5b57\uff0c\u5c31\u653e\u5728last_name\uff0cfirst_name\u7559\u7a7a\u3002\u6240\u4ee5\u4f5c\u8005\u5e94\u8be5\u662flast_name: \\\"SP\u00c9DER\\\", first_name: \\\"\\\"\u3002\\n\\n\u7136\u540e\u662f\u51fa\u7248\u4fe1\u606f\u3002\u6807\u9898\u662f\u201cDe l\u2019hydrate de chloral.\u201d\uff0c\u5e74\u4efd\u662f1887\uff0c\u5730\u70b9\u662fMontpellier\u3002\u9875\u6570\u662f34\u9875\uff0c\u6ce8\u610f\u8981\u53bb\u6389\u201cS.\u201d\u540e\u7f00\uff0c\u8fd9\u91cc\u5df2\u7ecf\u662f\u6570\u5b57\uff0c\u6240\u4ee5\u76f4\u63a5\u5199\u201c34\u201d\u3002\u51fa\u7248\u793e\u662f\u201cTh. pharm.\u201d\uff0c\u4e5f\u5c31\u662fTh\u00e8se de pharmacie\uff0c\u53ef\u80fd\u6307\u7684\u662f\u836f\u5b66\u8bba\u6587\uff0c\u6240\u4ee5publisher\u586b\u201cTh. pharm.\u201d\u3002\u683c\u5f0f\u662f\u201cin-4\u00b0\u201d\uff0c\u4e5f\u5c31\u662f4\u5f00\u672c\uff0c\u6240\u4ee5format\u662f\u201c4\u00b0\u201d\u3002\\n\\n\u56fe\u4e66\u9986\u53c2\u8003\u90e8\u5206\uff0cshelfmark\u53ef\u80fd\u6765\u81ea\u201cN\u00b0 405\u201d\uff0c\u4f46\u901a\u5e38shelfmark\u4f1a\u6709\u524d\u7f00\u5982Diss.\u6216AT\uff0c\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u7559\u7a7a\u3002\u4e0d\u8fc7\u7528\u6237\u4f8b\u5b50\u4e2d\u7684shelfmark\u6709\u65f6\u662f\u7f16\u53f7\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u586b\u201cN\u00b0 405\u201d\u