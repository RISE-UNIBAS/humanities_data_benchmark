u53d6\u3002\\n\\n\u7136\u540e\u662f\u51fa\u7248\u4fe1\u606f\u3002\u6807\u9898\u662f\u201cEl Mariale de Saint-Evroul.\u201d\uff0c\u6ce8\u610f\u540e\u9762\u7684\u53e5\u53f7\u53ef\u80fd\u9700\u8981\u4fdd\u7559\u3002\u5e74\u4efd\u662f1961\uff0c\u4f5c\u4e3a\u6574\u6570\u3002\u51fa\u7248\u5730\u662fFriburgo (Suiza)\uff0c\u4f46\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u91cd\u590d\u3002\u539f\u6587\u4e2d\u6709\u4e24\u6b21\u63d0\u5230Friburgo\uff0c\u53ef\u80fd\u7b2c\u4e00\u6b21\u662f\u8bba\u6587\u6240\u5728\u5730\uff0c\u7b2c\u4e8c\u6b21\u662f\u51fa\u7248\u5730\u3002\u6839\u636e\u89c4\u5219\uff0cplace\u5e94\u8be5\u662f\u51fa\u7248\u5730\uff0c\u6240\u4ee5\u53d6\u7b2c\u4e8c\u4e2aFriburgo (Suiza)\u3002\u4e0d\u8fc7\u53ef\u80fd\u9700\u8981\u786e\u8ba4\uff0c\u4f46\u6839\u636e\u793a\u4f8b\u4e2d\u7684\u5904\u7406\uff0c\u53ef\u80fd\u76f4\u63a5\u53d6\u51fa\u73b0\u7684\u7b2c\u4e00\u4e2a\u5730\u70b9\u3002\u6216\u8005\u770b\u539f\u6587\u7ed3\u6784\uff1a\u201cExtracto de la Tesis Friburgo (Suiza). -- Friburgo (Suiza) 1961.\u201d \u8fd9\u91cc\u53ef\u80fd\u7b2c\u4e00\u4e2aFriburgo\u662f\u8bba\u6587\u63d0\u4ea4\u5730\uff0c\u7b2c\u4e8c\u4e2a\u662f\u51fa\u7248\u5730\u3002\u6240\u4ee5place\u5e94\u8be5\u662fFriburgo (Suiza)\u3002\\n\\n\u9875\u6570\u662f71 S.\uff0c\u6839\u636e\u89c4\u52193\uff0c\u53bb\u6389\u201cS.\u201d\u540e\u7f00\uff0c\u6240\u4ee5pages\u662f71\u3002\u51fa\u7248\u793e\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u63d0\u5230\uff0c\u4f46\u539f\u6587\u4e2d\u7684\u201cExtracto de la Tesis\u201d\u53ef\u80fd\u8868\u793a\u8fd9\u662f\u8bba\u6587\u7684\u6458\u5f55\uff0c\u6240\u4ee5\u51fa\u7248\u793e\u53ef\u80fd\u7559\u7a7a\u3002\u683c\u5f0f\u662f8'\uff0c\u6839\u636e\u89c4\u52193\uff0c\u683c\u5f0f\u901a\u5e38\u662f8\u00b0\u30018'\u62164\u00b0\uff0c\u6240\u4ee5\u8fd9\u91cc\u53d68'\u3002\\n\\n\u56fe\u4e66\u9986\u53c2\u8003\u90e8\u5206\uff0cshelfmark\u662fDiss.Fribourg 1961\uff0c\u56e0\u4e3aStandort\u540e\u9762\u8ddf\u7740\u8fd9\u4e2a\u3002subjects\u662fMariale/ Th Diss\uff0c\u53ef\u80fd\u4f5c\u4e3a\u4e3b\u9898\u5206\u7c7b\u3002\\n\\n\u73b0\u5728\u9700\u8981\u68c0\u67e5\u6240\u6709\u5b57\u6bb5\u662f\u5426\u7b26\u5408\u8981\u6c42\u3002\u4f8b\u5982\uff0cyear\u5fc5\u987b\u662f\u6574\u6570\uff0c\u6240\u4ee51961\u6ca1\u95ee\u9898\u3002place\u3001pages\u3001publisher\u3001format\u5982\u679c\u6709\u5c31\u586b\uff0c\u5426\u5219\u7a7a\u5b57\u7b26\u4e32\u3002\u8fd9\u91ccpublisher\u53ef\u80fd\u6ca1\u6709\uff0c\u6240\u4ee5\u7559\u7a7a\u3002format\u662f8'\uff0c\u6b63\u786e\u3002\\n\\n\u6700\u540e\uff0c\u786e\u4fddJSON\u7ed3\u6784\u6b63\u786e\uff0c\u6ca1\u6709\u591a\u4f59\u5b57\u6bb5\uff0c\u6240\u6709\u5fc5\u586b\u9879\u90fd\u5b58\u5728\u3002\u6bd4\u5982type\u7684type\u5b57\u6bb5\uff0cauthor\u7684last\u548cfirst\uff0cpublication\u7684\u5404\u4e2a\u5b57\u6bb5\uff0clibrary_reference\u7684shelfmark\u548csubjects\u3002\\n\\n\u53ef\u80fd\u9700\u8981\u6ce8\u610f\u7684\u5730\u65b9\uff1a\u4f5c\u8005\u540d\u5b57\u662f\u5426\u6b63\u786e\u5206\u5272\uff0c\u662f\u5426\u6709\u62fc\u5199\u9519\u8bef\u3002\u4f8b\u5982\uff0c\u56fe\u7247\u4e2d\u7684\u201cP e d r o s a\u201d\u53ef\u80fd\u6709\u7a7a\u683c\uff0c\u4f46\u5b9e\u9645\u5e94\u4e3aPedrosa\u3002\u53e6\u5916\uff0c\u6807\u9898\u4e2d\u7684\u53e5\u53f7\u662f\u5426\u9700\u8981\u4fdd\u7559\uff0c\u6839\u636e\u793a\u4f8b\u53ef\u80fd\u4fdd\u7559\u3002\u9875\u6570\u5904\u7406\u662f\u5426\u6b63\u786e\uff0c\u53bb\u6389S.\u3002shelfmark\u662f\u5426\u6b63\u786e\u63d0\u53d6Standort\u540e\u7684\u5185\u5bb9\u3002\\n\\n\u73b0\u5728\u628a\u8fd9\u4e9b\u6574\u7406\u6210JSON\u7ed3\u6784\uff0c\u786e\u4fdd\u7b26\u5408\u7528\u6237\u63d0\u4f9b\u7684schema\uff0c\u7279\u522b\u662f\u7c7b\u578b\u548c\u5404\u4e2a\u5b57\u6bb5\u7684\u5fc5\u586b\u9879\u3002\u4f8b\u5982\uff0cpublication\u4e2d\u7684place\u3001pages\u7b49\u5982\u679c\u5b58\u5728\u5c31\u586b\uff0c\u5426\u5219\u7a7a\u5b57\u7b26\u4e32\u3002\u8fd9\u91ccplace\u662fFriburgo (Suiza)\uff0cpages\u662f71\uff0cpublisher\u53ef\u80fd\u6ca1\u6709\uff0c\u6240\u4ee5\u7a7a\u5b57\u7b26\u4e32\uff0cformat\u662f8'\u3002\\n\\