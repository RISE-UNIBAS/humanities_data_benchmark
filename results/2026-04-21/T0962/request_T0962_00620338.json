3002subjects\u53ef\u80fd\u6ca1\u6709\uff0c\u6240\u4ee5\u7559\u7a7a\u3002\\n\\n\u6700\u540e\uff0c\u786e\u4fdd\u6240\u6709\u5fc5\u586b\u5b57\u6bb5\u90fd\u5b58\u5728\uff0c\u6ca1\u6709\u9057\u6f0f\u3002\u4f8b\u5982\uff0ctype\u3001author\u3001publication\u3001library_reference\u90fd\u5fc5\u987b\u5b58\u5728\uff0c\u4e14\u6bcf\u4e2a\u5b50\u5b57\u6bb5\u7b26\u5408\u8981\u6c42\u3002\u68c0\u67e5\u662f\u5426\u6709\u62fc\u5199\u9519\u8bef\uff0c\u6bd4\u5982last_name\u548cfirst_name\u662f\u5426\u6b63\u786e\uff0c\u5e74\u4efd\u662f\u5426\u4e3a\u6574\u6570\uff0c\u5176\u4ed6\u5b57\u6bb5\u662f\u5426\u4e3a\u5b57\u7b26\u4e32\u6216\u7a7a\u5b57\u7b26\u4e32\u3002\\n\\n\u73b0\u5728\u628a\u8fd9\u4e9b\u4fe1\u606f\u6574\u7406\u6210JSON\u7ed3\u6784\uff0c\u786e\u4fdd\u7b26\u5408\u7528\u6237\u63d0\u4f9b\u7684Schema\uff0c\u7279\u522b\u662f\u7c7b\u578b\u548c\u5404\u4e2a\u5b57\u6bb5\u7684\u683c\u5f0f\u3002\u4f8b\u5982\uff0cpublication\u4e2d\u7684year\u662f\u6574\u6570\uff0c\u5176\u4ed6\u5982place\u3001pages\u7b49\u662f\u5b57\u7b26\u4e32\u6216\u7a7a\u3002library_reference\u4e2d\u7684shelfmark\u548csubjects\u4e5f\u662f\u5b57\u7b26\u4e32\u6216\u7a7a\u3002\\n\\n\u53ef\u80fd\u9700\u8981\u6ce8\u610f\u7684\u5730\u65b9\uff1a\u683c\u5f0f\u5b57\u6bb5\u662f\u5426\u6709\u591a\u4e2a\u503c\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u53ea\u53d6\u4e00\u4e2a\uff0c\u6240\u4ee5\u90094\u00b0\u3002shelfmark\u662f\u5426\u6b63\u786e\u63d0\u53d6\uff0c\u53ef\u80fd\u7528\u6237\u793a\u4f8b\u4e2d\u7684shelfmark\u662f\u201cU 22.2158\u201d\uff0c\u4f46\u539f\u5361\u7247\u4e2d\u7684\u5199\u6cd5\u53ef\u80fd\u6709\u7a7a\u683c\u6216\u8fde\u5b57\u7b26\uff0c\u9700\u8981\u4fdd\u6301\u539f\u6837\u3002\u53e6\u5916\uff0csubjects\u53ef\u80fd\u6ca1\u6709\uff0c\u6240\u4ee5\u7559\u7a7a\u3002\\n\\n\u603b\u7ed3\u6240\u6709\u63d0\u53d6\u7684\u4fe1\u606f\uff0c\u751f\u6210\u6b63\u786e\u7684JSON\u5bf9\u8c61\uff0c\u786e\u4fdd\u6ca1\u6709\u591a\u4f59\u7684\u5185\u5bb9\uff0c\u53ea\u8fd4\u56deJSON\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u5386\u53f2\u8bba\u6587\u7d22\u5f15\u5361\uff0c\u5e76\u63d0\u53d6\u51fa\u7ed3\u6784\u5316\u7684JSON\u6570\u636e\u3002\u9996\u5148\uff0c\u6211\u5f97\u4ed4\u7ec6\u9605\u8bfb\u7528\u6237\u7ed9\u7684\u6307\u4ee4\u548c\u793a\u4f8b\uff0c\u786e\u4fdd\u81ea\u5df1\u5b8c\u5168\u7406\u89e3\u6bcf\u4e2a\u6b65\u9aa4\u7684\u8981\u6c42\u3002\\n\\n\u9996\u5148\uff0c\u7528\u6237\u8981\u6c42\u6839\u636e\u7d22\u5f15\u5361\u7684\u4fe1\u606f\u751f\u6210\u4e00\u4e2a\u7b26\u5408\u7279\u5b9aJSON Schema\u7684\u5bf9\u8c61\u3002\u8fd9\u4e2a\u5bf9\u8c61\u5305\u62ec\u7c7b\u578b\u3001\u4f5c\u8005\u3001\u51fa\u7248\u4fe1\u606f\u548c\u56fe\u4e66\u9986\u53c2\u8003\u4fe1\u606f\u3002\u6211\u9700\u8981\u6309\u7167\u7528\u6237\u63d0\u4f9b\u7684\u89c4\u5219\u9010\u4e00\u63d0\u53d6\u6bcf\u4e2a\u90e8\u5206\u7684\u4fe1\u606f\u3002\\n\\n\u9996\u5148\u770b\u5361\u7247\u7c7b\u578b\u3002\u6839\u636e\u89c4\u52191\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u5355\u72ec\u7684\u201cs.\u201d\u884c\uff0c\u5219\u662f\u201cReference\u201d\uff0c\u5426\u5219\u662f\u201cDissertation or thesis\u201d\u3002\u73b0\u5728\u68c0\u67e5\u7528\u6237\u63d0\u4f9b\u7684\u56fe\u7247\u5185\u5bb9\uff0c\u91cc\u9762\u6ca1\u6709\u63d0\u5230\u201cs.\u201d\uff0c\u6240\u4ee5\u7c7b\u578b\u5e94\u8be5\u662f\u201cDissertation or thesis\u201d\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u4f5c\u8005\u90e8\u5206\u3002\u89c4\u52192\u6307\u51fa\uff0c\u5982\u679c\u53ea\u6709\u4e00\u4e2a\u540d\u5b57\uff0c\u653e\u5728last_name\uff0cfirst_name\u7559\u7a7a\u3002\u56fe\u7247\u4e2d\u7684\u4f5c\u8005\u662f\u201cUlmer, Else\u201d\uff0c\u6240\u4ee5last_name\u662fUlmer\uff0cfirst_name\u662fElse\u3002\\n\\n\u7136\u540e\u662f\u51fa\u7248\u4fe1\u606f\u3002\u6807\u9898\u662f\u201cDie T\u00e4tigkeit der Privatnotenbanken w\u00e4hrend des Krieges.\u201d\uff0c\u5e74\u4efd\u662f1922\uff0c\u5730\u70b9\u662fErlangen\uff0c\u9875\u6570\u662f108 S.\uff0c\u9700\u8981\u53bb\u6389\u201cS.\u201d\uff0c\u6240\u4ee5\u662f108\u3002\u51fa\u7248\u793e\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u63d0\u5230\uff0c\u4f46\u6839\u636e\u201cErlangen, Phil. Diss.\u201d\uff0c\u53ef\u80fd\u51fa\u7248\u793e\u662f\u5927\u5b66\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u53ef\u80fd\u7559\u7a7a\u3002\u683c\u5f0f\u662f4\u00b0\uff0c\u4f46\u540e\u9762\u8fd8\u67098\u00b0\uff0c\u9700\u8981\u786e\u8ba4\u3002\u6839\u636e\u89c4\u52193\uff0c\u683c\u5f0f\u901a\u5e38\u662f8\u00b0\u30018'\u62164\u00b0\uff0c\u8fd9\u91cc\u53ef\u80fd\u6709\u4e24\u4e2a\u683c\u5f0f\uff0c\u4f46\u7528\u6237\u8981\u6c42\u5355\u503c\uff0c\u53ef\u80fd\u9700\u8981\u9009\u5176\u4e2d\u4e00\u4e2a\u3002\u4e0d\u8fc7\u539f\u5361\u7247\u4e2d\u5199\u7684\u662f\u201c4\u00b0 [Lag nicht vor.] \u2014 Auszug: o. O. u. J. 1 Bl. 8\u00b0\u201d\uff0c\u53ef\u80fd\u4e3b\u683c\u5f0f\u662f4\u00b0\uff0c\u800cAuszug\u662f8\u00b0\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u5e94\u8be5\u53d6\u4e3b\u8981\u7684\uff0c\u6240\u4ee5\u683c\u5f0f\u662f4\u00b0\u3002\u4e0d\u8fc7\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u3002\u539f\u5361\u7247\u4e2d\u7684\u63cf\u8ff0\u662f\u201c[Maschinenschrift.] 108 S. 4\u00b0\u201d\uff0c\u6240\u4ee5\u683c\u5f0f\u5e94\u8be5\u662f4\u00b0\u3002\\n\\n\u56fe\u4e66\u9986\u53c2\u8003\u90e8\u5206\uff0cshelfmark\u53ef\u80fd\u4ee5Diss.\u6216AT\u5f00\u5934\uff0c\u8fd9\u91cc\u5361\u7247\u4e0a\u6709\u201cErlangen, Phil. Diss. v. 6. Mai 1922\u201d\u548c\u201c[U 22. 2158-\u201d\uff0c\u53ef\u80fdshelfmark\u662fU 22.2158\uff0c\u4f46\u9700\u8981\u786e\u8ba4\u3002\u53e6\u5916\uff0csubjects\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u7ed9\u51fa\uff0c\u4f46\u53ef\u80fd\u6709\u5b66\u79d1\u5206\u7c7b\uff0c\u6bd4\u5982Phil. Diss.\u53ef\u80fd\u5c5e\u4e8e\u54f2\u5b66\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u53ef\u80fd\u7559\u7a7a\u3002\u4e0d\u8fc7\u539f\u5361\u7247\u4e2d\u7684\u201cPhil. Diss.\u201d\u53ef\u80fd\u6307\u54f2\u5b66\u535a\u58eb\u8bba\u6587\uff0c\u4f46subjects\u53ef\u80fd\u9700\u8981\u5176\u4ed6\u5173\u952e\u8bcd\uff0c\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\uff0c\u6240\u4ee5\u7559\u7a7a\u3002\\n\\n\u73b0\u5728\u9700\u8981\u68c0\u67e5\u6bcf\u4e2a\u5b57\u6bb5\u662f\u5426\u7b26\u5408\u89c4\u5219\u3002\u4f8b\u5982\uff0c\u5e74\u4efd\u662f\u6574\u6570\uff0c\u6240\u4ee51922\u6ca1\u95ee\u9898\u3002\u9875\u6570\u53bb\u6389S.\u540e\u662f108\u3002\u51fa\u7248\u793e\u53ef\u80fd\u6ca1\u6709\u660e\u786e\uff0c\u6240\u4ee5\u7559\u7a7a\u3002\u683c\u5f0f\u662f4\u00b0\u3002shelfmark\u53ef\u80fd\u53d6U 22.2158\uff0c\u4f46\u539f\u5361\u7247\u4e2d\u7684\u201c[U 22. 2158-\u201d\u53ef\u80fd\u4e0d\u5b8c\u6574\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u53ef\u80fd\u76f4\u63a5\u53d6\u8fd9\u90e8\u5206\u3002subjects\u53ef\u80fd\u6ca1\u6709\uff0c\u6240\u4ee5\u7559\u7a7a\u3002\\n\\n\u6700\u540e\uff0c\u786e\u4fdd\u6240\u6709\u5fc5\u586b\u5b57\u6bb5\u90fd\u5b58\u5728\uff0c\u6ca1\u6709\u9057\u6f0f\u3002\u4f8b\u5982\uff0ctype\u3001author\u3001publication\u3001library_reference\u90fd\u5fc5\u987b\u5b58\u5728\uff0c\u4e14\u6bcf\u4e2a\u5b50\u5b57\u6bb5\u7b26\u5408\u8981\u6c42\u3002\u68c0\u67e5\u662f\u5426\u6709\u62fc\u5199\u9519\u8bef\uff0c\u6bd4\u5982last_name\u548cfirst_name\u662f\u5426\u6b63\u786e\uff0c\u5e74\u4efd\u662f\u5426\u4e3a\u6574\u6570\uff0c\u5176\u4ed6\u5b57\u6bb5\u662f\u5426\u4e3a\u5b57\u7b26\u4e32\u6216\u7a7a\u5b57\u7b26\u4e32\u3002\\n\\n\u73b0\u5728\u628a\u8fd9\u4e9b\u4fe1\u606f\u6574\u7406\u6210JSON\u7ed3\u6784\uff0c\u786e\u4fdd\u7b26\u5408\u7528\u6237\u63d0\u4f9b\u7684Schema\uff0c\u7279\u522b\u662f\u7c7b\u578b\u548c\u5404\u4e2a\u5b57\u6bb5\u7684\u683c\u5f0f\u3002\u4f8b\u5982\uff0cpublication\u4e2d\u7684year\u662f\u6574\u6570\uff0c\u5176\u4ed6\u5982place\u3001pages\u7b49\u662f\u5b57\u7b26\u4e32\u6216\u7a7a\u3002library_reference\u4e2d\u7684shelfmark\u548csubjects\u4e5f\u662f\u5b57\u7b26\u4e32\u6216\u7a7a\u3002\\n\\n\u53ef\u80fd\u9700\u8981\u6ce8\u610f\u7684\u5730\u65b9\uff1a\u683c\u5f0f\u5b57\u6bb5\u662f\u5426\u6709\u591a\u4e2a\u503c\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u53ea\u53d6\u4e00\u4e2a\uff0c\u6240\u4ee5\u