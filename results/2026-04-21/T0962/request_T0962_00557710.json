f\u53c2\u8003\u6587\u732e\uff0c\u5426\u5219\u662f\u8bba\u6587\u3002\u73b0\u5728\u770b\u7528\u6237\u63d0\u4f9b\u7684\u56fe\u7247\u63cf\u8ff0\uff0c\u91cc\u9762\u6ca1\u6709\u63d0\u5230\u201cs.\u201d\uff0c\u6240\u4ee5\u5e94\u8be5\u5f52\u7c7b\u4e3a\u201cDissertation or thesis\u201d\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u4f5c\u8005\u90e8\u5206\u3002\u5361\u7247\u4e0a\u5199\u7684\u662f\u201cSchuurbeque Boeije, Jacobus. Kellingen.\u201d\u3002\u8fd9\u91cc\u770b\u8d77\u6765\u59d3\u6c0f\u662fSchuurbeque Boeije\uff0c\u540d\u5b57\u662fJacobus\u3002\u4e0d\u8fc7\u6709\u65f6\u5019\u53ef\u80fd\u4f1a\u6709\u590d\u59d3\u7684\u60c5\u51b5\uff0c\u6bd4\u5982Schuurbeque Boeije\u53ef\u80fd\u662f\u4e00\u4e2a\u590d\u5408\u59d3\u6c0f\uff0c\u6240\u4ee5last_name\u5e94\u8be5\u662fSchuurbeque Boeije\uff0cfirst_name\u662fJacobus\u3002\u4e0d\u8fc7\u9700\u8981\u786e\u8ba4\u662f\u5426\u6709\u5176\u4ed6\u53ef\u80fd\uff0c\u6bd4\u5982\u662f\u5426\u4e2d\u95f4\u6709\u9017\u53f7\u5206\u9694\uff0c\u4f46\u6839\u636e\u5e38\u89c1\u7684\u683c\u5f0f\uff0c\u9017\u53f7\u524d\u662f\u59d3\uff0c\u540e\u9762\u662f\u540d\uff0c\u6240\u4ee5\u5e94\u8be5\u6ca1\u95ee\u9898\u3002\\n\\n\u7136\u540e\u662f\u51fa\u7248\u4fe1\u606f\u3002\u6807\u9898\u90e8\u5206\uff0c\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\u4e2d\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u6807\u9898\uff0c\u4f46\u6839\u636e\u5361\u7247\u5185\u5bb9\uff0c\u53ef\u80fd\u6807\u9898\u662f\u201cKellingen.\u201d\uff0c\u4e0d\u8fc7\u9700\u8981\u786e\u8ba4\u3002\u4e0d\u8fc7\u539f\u5361\u7247\u4e0a\u7684\u7b2c\u4e8c\u884c\u662f\u201cUtrecht (den Boer) 1916. 12 S. 8.\u201d\uff0c\u8fd9\u91cc\u53ef\u80fd\u6807\u9898\u662fKellingen\uff0c\u800c\u51fa\u7248\u5730\u662fUtrecht\uff0c\u51fa\u7248\u5546\u662fden Boer\uff0c\u5e74\u4efd1916\uff0c\u9875\u657012\uff0c\u683c\u5f0f8\u00b0\u3002\u6240\u4ee5\u6807\u9898\u5e94\u8be5\u662f\u201cKellingen\u201d\uff0c\u5e74\u4efd1916\uff0c\u5730\u70b9Utrecht\uff0c\u9875\u657012\uff0c\u51fa\u7248\u5546den Boer\uff0c\u683c\u5f0f8\u00b0\u3002\u4e0d\u8fc7\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u5176\u4ed6\u4fe1\u606f\u88ab\u9057\u6f0f\u3002\\n\\n\u56fe\u4e66\u9986\u53c2\u8003\u90e8\u5206\uff0c\u5361\u7247\u4e0a\u6709\u201cAT. Utrecht 4-.\u201d\u548c\u201cAT 17.\u201d\uff0c\u53ef\u80fdshelfmark\u662fAT Utrecht 4-\u6216\u8005AT 17\uff0c\u4f46\u9700\u8981\u786e\u5b9a\u54ea\u4e2a\u662f\u6b63\u786e\u7684\u3002\u901a\u5e38shelfmark\u53ef\u80fd\u4ee5AT\u5f00\u5934\uff0c\u6240\u4ee5\u53ef\u80fd\u53d6AT Utrecht 4-\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684shelfmark\u53ef\u80fd\u5408\u5e76\u8fd9\u4e9b\u4fe1\u606f\u3002\u53e6\u5916\uff0c\u4e3b\u9898\u90e8\u5206\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u7ed9\u51fa\uff0c\u6240\u4ee5\u7559\u7a7a\u3002\\n\\n\u73b0\u5728\u9700\u8981\u6309\u7167\u89c4\u5219\u5904\u7406\u6bcf\u4e2a\u5b57\u6bb5\uff1a\\n\\n\u7c7b\u578b\uff1a\u6ca1\u6709s.\uff0c\u6240\u4ee5\u662fDissertation or thesis\u3002\\n\\n\u4f5c\u8005\uff1alast_name\u662fSchuurbeque Boeije\uff0cfirst_name\u662fJacobus\u3002\\n\\n\u51fa\u7248\u4fe1\u606f\uff1a\\n\u6807\u9898\uff1aKellingen\uff08\u53ef\u80fd\u540e\u9762\u6709\u53e5\u53f7\uff0c\u4f46\u9700\u8981\u53bb\u6389\u6807\u70b9\uff1f\u6216\u8005\u4fdd\u7559\uff1f\u6839\u636e\u89c4\u5219\uff0c\u6807\u9898\u662f\u4e3b\u6807\u9898\uff0c\u53ef\u80fd\u76f4\u63a5\u53d6Kellingen\uff09\\n\u5e74\u4efd\uff1a1916\uff0c\u6574\u6570\u3002\\n\u5730\u70b9\uff1aUtrecht (den Boer)\u4e2d\u7684Utrecht\uff0c\u4f46\u62ec\u53f7\u91cc\u7684\u53ef\u80fd\u662f\u51fa\u7248\u5546\uff0c\u6240\u4ee5place\u662fUtrecht\uff0cpublisher\u662fden Boer\u3002\\n\u9875\u6570\uff1a12 S.\uff0c\u53bb\u6389S.\uff0c\u6240\u4ee5\u662f12\u3002\\n\u683c\u5f0f\uff1a8.\uff0c\u53ef\u80fd\u5bf9\u5e948\u00b0\uff0c\u6240\u4ee5\u586b8\u00b0\u3002\\n\u51fa\u7248\u793e\uff1aden Boer\u3002\\n\\n\u56fe\u4e66\u9986\u53c2\u8003\uff1a\\nshelfmark\uff1aAT Utrecht 4- \u6216\u8005 AT 17\uff1f\u5361\u7247\u4e0a\u6709\u4e24\u4e2aAT\u6807\u8bb0\uff0c\u53ef\u80fd\u9700\u8981\u5408\u5e76\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u53ef\u80fd\u53d6AT Utrecht 4-\uff0c\u6216\u8005\u53ef\u80fdshelfmark\u662fAT 17\uff0c\u800cUtrecht 4-\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u539f\u5361\u7247\u63cf\u8ff0\u3002\u7528\u6237\u63d0\u4f9b\u7684\u56fe\u7247\u63cf\u8ff0\u4e2d\uff0c\u7b2c\u4e8c\u884c\u662f\u201cUtrecht (den Boer) 1916. 12 S. 8.\u201d\uff0c\u7136\u540e\u4e0b\u9762\u6709\u201cAT. Utrecht 4-.\u201d\u548c\u201cAT 17.\u201d\u3002\u53ef\u80fdshelfmark\u662fAT Utrecht 4-\uff0c\u800cAT 17\u53ef\u80fd\u662f\u53e6\u4e00\u4e2a\u7f16\u53f7\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0cshelfmark\u901a\u5e38\u4ee5Diss.\u6216AT\u5f00\u5934\uff0c\u6240\u4ee5\u53ef\u80fd\u53d6AT Utrecht 4-\u3002\u6216\u8005\u53ef\u80fdshelfmark\u662fAT 17\uff0c\u800cUtrecht 4-\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5224\u65ad\uff0c\u4f46\u6839\u636e\u5e38\u89c1\u60c5\u51b5\uff0c\u53ef\u80fdshelfmark\u662fAT Utrecht 4-\uff0c\u800cAT 17\u53ef\u80fd\u662f\u53e6\u4e00\u4e2a\u6807\u8bc6\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u53ef\u80fd\u53ea\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u6216\u8005\u53ef\u80fdshelfmark\u662fAT 17\uff0c\u800cUtrecht 4-\u662f\u4e3b\u9898\uff1f\u4f46\u4e3b\u9898\u90e8\u5206\u9700\u8981\u770b\u662f\u5426\u6709\u5206\u7c7b\u3002\u539f\u5361\u7247\u4e2d\u6ca1\u6709\u660e\u786e\u7684\u4e3b\u9898\u8bcd\uff0c\u6240\u4ee5subjects\u7559\u7a7a\u3002\\n\\n\u73b0\u5728\u9700\u8981\u786e\u8ba4\u5404\u4e2a\u5b57\u6bb5\u662f\u5426\u6b63\u786e\uff1a\\n\\n\u6807\u9898\u662f\u5426\u6b63\u786e\uff1f\u539f\u5361\u7247\u7b2c\u4e00\u884c\u662f\u4f5c\u8005\u548c\u6807\u9898\u5417\uff1f\u53ef\u80fd\u7b2c\u4e00\u884c\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u884c\u5f00\u59cb\u662f\u51fa\u7248\u4fe1\u606f\u3002\u4f8b\u5982\uff0c\u201cSchuurbeque Boeije, Jacobus. Kellingen.\u201d\u53ef\u80fd\u6807\u9898\u662fKellingen\uff0c\u800c\u540e\u9762\u662f\u51fa\u7248\u4fe1\u606f\u3002\u6240\u4ee5\u6807\u9898\u662fKellingen\uff0c\u6b63\u786e\u3002\\n\\n\u9875\u6570\u662f12\uff0c\u6b63\u786e\u3002\u683c\u5f0f\u662f8\u00b0\uff0c\u6b63\u786e\u3002\u51fa\u7248\u5546\u662fden Boer\uff0c\u6b63\u786e\u3002\u5730\u70b9Utrecht\uff0c\u6b63\u786e\u3002\\n\\n\u56fe\u4e66\u9986shelfmark\u53ef\u80fd\u53d6AT Utrecht 4-\uff0c\u4f46\u539f\u5361\u7247\u4e2d\u6709\u201cAT. Utrecht 4-.\u201d\u548c\u201cAT 17.\u201d\uff0c\u53ef\u80fd\u9700\u8981\u5408\u5e76\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0cshelfmark\u901a\u5e38\u662f\u4e00\u4e2a\uff0c\u6240\u4ee5\u53ef\u80fd\u9009AT Utrecht 4-\uff0c\u6216\u8005AT 17\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u770b\u54ea\u4e2a\u66f4\u7b26\u5408\u5e38\u89c4\u3002\u4f8b\u5982\uff0cAT\u53ef\u80fd\u4ee3\u8868\u67d0\u4e2a\u56fe\u4e66\u9986\u7684\u7f29\u5199\uff0cUtrecht\u662f\u5730\u70b9\uff0c4-\u53ef\u80fd\u662f\u7f16\u53f7\uff0c\u800cAT 17\u53ef\u80fd\u662f\u53e6\u4e00\u4e2a\u7f16\u53f7\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0c\u53ef\u80fdshelfmark\u662fAT Utrecht 4-\uff0c\u800cAT 17\u53ef\u80fd\u5c5e\u4e8e\u5176\u4ed6\u4fe1\u606f\uff0c\u4f46\u89c4\u5219\u4e2dshelfmark\u53ef\u80fd\u4ee5AT\u5f00\u5934\uff0c\u6240\u4ee5\u53ef\u80fd\u53d6AT Utrecht 4-\u3002\u6216\u8005\u53ef\u80fdshelfmark\u662fAT 17\uff0c\u800cUtrecht 4-\u662f\u4e3b\u9898\uff1f\u4f46\u4e3b\u9898\u90e8\u5206\u6ca1\u6709\u5185\u5bb9\uff0c\u6240\u4ee5\u53ef\u80fdshelfmark\u662fAT Utrecht 4-\uff0c\u800cAT 17\u53ef\u80fd\u88ab\u5ffd\u7565\uff0c\u6216\u8005\u4f5c\u4e3a\u53e6\u4e00\u4e2ashelfmark\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u53ea\u53d6\u4e00\u4e2a\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5224\u65ad\uff0c\u4f46\u6839\u636e\u5e38\u89c1\u60c5\u51b5\uff0c\u53ef\u80fdshelfmark\u662fAT Utrecht 4-\uff0c\u800cAT 17\u53ef\u80fd\u662f\u53e6\u4e00\u4e2a\u6807\u8bc6\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5408\u5e76\uff0c\u6216\u8005\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u4f8b\u5982\uff0c\u539f\u5361\u7247\u4e2d\u7684\u201cAT. Utrecht 4-.\u201d\u53ef\u80fd\u66f4\u5b8c\u6574\uff0c\u6240\u4ee5shelfmark\u586bAT Utrecht 4-\uff0c\u800cAT 17\u53ef\u80fd\u5c5e\u4e8e\u5176\u4ed6\u4fe1\u606f\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u53ea\u53d6shelfmark\uff0c\u6240\u4ee5\u53ef\u80fd\u9009\u8fd9\u4e2a\u3002\\n\\n\u4e3b\u9898\u90e8\u5206\u6ca1\u6709\u660e\u786e\u4fe1\u606f\uff0c\u6240\u4ee5\u7559\u7a7a\u3002\\n\\n\u73b0\u5728\u68c0\u67e5\u6240\u6709\u5b57\u6bb5\u662f\u5426\u7b26\u5408\u8981\u6c42\uff1a\\n\\n\u7c7b\u578b\u6b63\u786e\uff0c\u4f5c\u8005\u6b63\u786e\uff0c\u51fa\u7248\u4fe1\u606f\u4e2d\u7684\u5404\u4e2a\u5b57\u6bb5\u662f\u5426\u6b63\u786e\uff0c\u56fe\u4e66\u9986\u53c2\u8003\u7684shelfmark\u548csubjects\u662f\u5426\u6b63\u786e\u3002\\n\\n\u53ef\u80fd\u9700\u8981\u6ce8\u610f\u7684\u5730\u65b9\uff1a\\n\\n- \u6807\u9898\u662f\u5426\u5e94\u8be5\u5305\u62ec\u540e\u9762\u7684\u53e5\u53f7\uff1f\u6bd4\u5982\u201cKellingen.\u201d\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u6807\u9898\u662f\u4e3b\u6807\u9898\uff0c\u53ef\u80fd\u53bb\u6389\u6807\u70b9\uff0c\u6240\u4ee5\u586bKellingen\u3002\\n- \u9875\u6570\u662f\u5426\u53bb\u6389S.\uff0c\u662f\u7684\uff0c\u6240\u4ee512\u3002\\n- \u683c\u5f0f\u662f8\u00b0\uff0c\u6b63\u786e\u3002\\n- \u51fa\u7248\u5546\u662fden Boer\uff0c\u6b63\u786e\u3002\\n- shelfmark\u662f\u5426\u6b63\u786e\uff0c\u53ef\u80fd\u9700\u8981\u786e\u8ba4\uff0c\u4f46\u6839\u636e\u73b0\u6709\u4fe1\u606f\uff0c\u586bAT Utrecht 4-\u3002\\n- subjects\u7559\u7a7a\u3002\\n\\n\u73b0\u5728\u5c06\u8fd9\u4e9b\u6574\u7406\u6210JSON\u7ed3\u6784\uff0c\u786e\u4fdd\u7b26\u5408\u63d0\u4f9b\u7684schema\uff0c\u7279\u522b\u662f\u7c7b\u578b\u662f\u5426\u6b63\u786e\uff0c\u5b57\u6bb5\u662f\u5426\u9f50\u5168\uff0c\u7a7a\u503c\u7528\u7a7a\u5b57\u7b26\u4e32\uff0c\u5e74\u4efd\u662f\u6574\u6570\u3002\\n\\n\u6700\u540e\u68c0\u67e5\u662f\u5426\u6709\u9057\u6f0f\u6216\u9519\u8bef\uff0c\u6bd4\u5982\u4f5c\u8005\u7684\u540d\u5b57\u662f\u5426\u6b63\u786e\u5206\u5272\uff0c\u51fa\u7248\u4fe1\u606f\u662f\u5426\u51c6\u786e\uff0c\u56fe\u4e66\u9986\u53c2\u8003\u662f\u5426\u6b63\u786e\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u5386\u53f2\u6587\u732e\u7d22\u5f15\u5361\uff0c\u5e76\u6309\u7167\u4ed6\u4eec\u7684\u8981\u6c42\u63d0\u53d6\u4fe1\u606f\u751f\u6210JSON\u3002\u9996\u5148\uff0c\u6211\u5f97\u4ed4\u7ec6\u770b\u770b\u7528\u6237\u7ed9\u7684\u6307\u4ee4\u548c\u793a\u4f8b\uff0c\u786e\u4fdd\u81ea\u5df1\u7406\u89e3\u6b63\u786e\u3002\\n\\n\u9996\u5148\uff0c\u7528\u6237\u8981\u6c42\u6839\u636e\u7d22\u5f15\u5361\u7684\u5185\u5bb9\u5224\u65ad\u662f\u8bba\u6587\u8fd8\u662f\u53c2\u8003\u6587\u732e\u3002\u89c4\u5219\u91cc\u63d0\u5230\uff0c\u5982\u679c\u5361\u7247\u4e0a\u6709\u5355\u72ec\u7684\u201cs.\u201d\u884c\uff0c\u5c31\u662f\u53c2\u8003\u6587\u732e\uff0c\u5426\u5219\u662f\u8bba\u6587\u3002\u73b0\u5728\u770b\u7528\u6237\u63d0\u4f9b\u7684\u56fe\u7247\u63cf\u8ff0\uff0c\u91cc\u9762\u6ca1\u6709\u63d0\u5230\u201cs.\u201d\uff0c\u6240\u4ee5\u5e94\u8be5\u5f52\u7c7b\u4e3a\u201cDissertation or thesis\u201d\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u4f5c\u8005\u90e8\u5206\u3002\u5361\u7247\u4e0a\u5199\u7684\u662f\u201cSchuurbeque Boeije, Jacobus. Kellingen.\u201d\u3002\u8fd9\u91cc\u770b\u8d77\u6765\u59d3\u6c0f\u662fSchuurbeque Boeije\uff0c\u540d\u5b57\u662fJacobus\u3002\u4e0d\u8fc7\u6709\u65f6\u5019\u53ef\u80fd\u4f1a\u6709\u590d\u59d3\u7684\u60c5\u51b5\uff0c\u6bd4\u5982Schuurbeque Boeije\u53ef\u80fd\u662f\u4e00\u4e2a\u590d\u5408\u59d3\u6c0f\uff0c\u6240\u4ee5last_name\u5e94\u8be5\u662fSchuurbeque Boeije\uff0cfirst_name\u662fJacobus\u3002\u4e0d\u8fc7\u9700\u8981\u786e\u8ba4\u662f\u5426\u6709\u5176\u4ed6\u53ef\u80fd\uff0c\u6bd4\u5982\u662f\u5426\u4e2d\u95f4\u6709\u9017\u53f7\u5206\u9694\uff0c\u4f46\u6839\u636e\u5e38\u89c1\u7684\u683c\u5f0f\uff0c\u9017\u53f7\u524d\u662f\u59d3\uff0c\u540e\u9762\u662f\u540d\uff0c\u6240\u4ee5\u5e94\u8be5\u6ca1\u95ee\u9898\u3002\\n\\n\u7136\u540e\u662f\u51fa\u7248\u4fe1\u606f\u3002\u6807\u9898\u90e8\u5206\uff0c\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\u4e2d\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u6807\u9898\uff0c\u4f46\u6839\u636e\u5361\u7247\u5185\u5bb9\uff0c\u53ef\u80fd\u6807\u9898\u662f\u201cKellingen.\u201d\uff0c\u4e0d\u8fc7\u9700\u8981\u786e\u8ba4\u3002\u4e0d\u8fc7\u539f\u5361\u7247\u4e0a\u7684\u7b2c\u4e8c\u884c\u662f\u201cUtrecht (den Boer) 1916. 12 S. 8.\u201d\uff0c\u8fd9\u91cc\u53ef\u80fd\u6807\u9898\u662fKellingen\uff0c\u800c\u51fa\u7248\u5730\u662fUtrecht\uff0c\u51fa\u7248\u5546\u662fden Boer\uff0c\u5e74\u4efd1916\uff0c\u9875\u657012\uff0c\u683c\u5f0f8\u00b0\u3002\u6240\u4ee5\u6807\u9898\u5e94\u8be5\u662f\u201cKellingen\u201d\uff0c\u5e74\u4efd1916\uff0c\u5730\u70b9Utrecht\uff0c\u9875\u657012\uff0c\u51fa\u7248\u5546den Boer\uff0c\u683c\u5f0f8\u00b0\u3002\u4e0d\u8fc7\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u5176\u4ed6\u4fe1\u606f\u88ab\u9057\u6f0f\u3002\\n\\n\u56fe\u4e66\u9986\u53c2\u8003\u90e8\u5206\uff0c\u5361\u7247\u4e0a\u6709\u201cAT. Utrecht 4-.\u201d\u548c\u201cAT 17.\u201d\uff0c\u53ef\u80fdshelfmark\u662fAT Utrecht 4-\u6216\u8005AT 17\uff0c\u4f46\u9700\u8981\u786e\u5b9a\u54ea\u4e2a\u662f\u6b63\u786e\u7684\u3002\u901a\u5e38shelfmark\u53ef\u80fd\u4ee5AT\u5f00\u5934\uff0c\u6240\u4ee5\u53ef\u80fd\u53d6AT Utrecht 4-\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684shelfmark\u53ef\u80fd\u5408\u5e76\u8fd9\u4e9b\u4fe1\u606f\u3002\u53e6\u5916\uff0c\u4e3b\u9898\u90e8\u5206\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u7ed9\u51fa\uff0c\u6240\u4ee5\u7559\u7a7a\u3002\\n\\n\u73b0\u5728\u9700\u8981\u6309\u7167\u89c4\u5219\u5904\u7406\u6bcf\u4e2a\u5b57\u6bb5\uff1a\\n\\n\u7c7b\u578b\uff1a\u6ca1\u6709s.\uff0c\u6240\u4ee5\u662fDissertation or thesis\u3002\\n\\n\u4f5c\u8005\uff1alast_name\u662fSchuurbeque Boeije\uff0cfirst_name\u662fJacobus\u3002\\n\\n\u51fa\u7248\u4fe1\u606f\uff1a\\n\u6807\u9898\uff1aKellingen\uff08\u53ef\u80fd\u540e\u9762\u6709\u53e5\u53f7\uff0c\u4f46\u9700\u8981\u53bb\u6389\u6807\u70b9\uff1f\u6216\u8005\u4fdd\u7559\uff1f\u6839\u636e\u89c4\u5219\uff0c\u6807\u9898\u662f\u4e3b\u6807\u9898\uff0c\u53ef\u80fd\u76f4\u63a5\u53d6Kellingen\uff09\\n\u5e74\u4efd\uff1a1916\uff0c\u6574\u6570\u3002\\n\u5730\u70b9\uff1aUtrecht (den Boer)\u4e2d\u7684Utrecht\uff0c\u4f46\u62ec\u53f7\u91cc\u7684\u53ef\u80fd\u662f\u51fa\u7248\u5546\uff0c\u6240\u4ee5place\u662fUtrecht\uff0cpublisher\u662fden Boer\u3002\\n\u9875\u6570\uff1a12 S.\uff0c\u53bb\u6389S.\uff0c\u6240\u4ee5\u662f12\u3002\\n\u683c\u5f0f\uff1a8.\uff0c\u53ef\u80fd\u5bf9\u5e948\u00b0\uff0c\u6240\u4ee5\u586b8\u00b0\u3002\\n\u51fa\u7248\u793e\uff1aden Boer\u3002\\n\\n\u56fe\u4e66\u9986\u53c2\u8003\uff1a\\nshelfmark\uff1aAT Utrecht 4- \u6216\u8005 AT 17\uff1f\u5361\u7247\u4e0a\u6709\u4e24\u4e2aAT\u6807\u8bb0\uff0c\u53ef\u80fd\u9700\u8981\u5408\u5e76\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u53ef\u80fd\u53d6AT Utrecht 4-\uff0c\u6216\u8005\u53ef\u80fdshelfmark\u662fAT 17\uff0c\u800cUtrecht 4-\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u539f\u5361\u7247\u63cf\u8ff0\u3002\u7528\u6237\u63d0\u4f9b\u7684\u56fe\u7247\u63cf\u8ff0\u4e2d\uff0c\u7b2c\u4e8c\u884c\u662f\u201cUtrecht (den Boer) 1916. 12 S. 8.\u201d\uff0c\u7136\u540e\u4e0b\u9762\u6709\u201cAT. Utrecht 4-.\u201d\u548c\u201cAT 17.\u201d\u3002\u53ef\u80fdshelfmark\u662fAT Utrecht 4-\uff0c\u800cAT 17\u53ef\u80fd\u662f\u53e6\u4e00\u4e2a\u7f16\u53f7\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0cshelfmark\u901a\u5e38\u4ee5Diss.\u6216AT\u5f00\u5934\uff0c\u6240\u4ee5\u53ef\u80fd\u53d6AT Utrecht 4-\u3002\u6216\u8005\u53ef\u80fdshelfmark\u662fAT 17\uff0c\u800cUtrecht 4-\u662f\u5176\u4ed6\u4fe1\u606f\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5224\u65ad\uff0c\u4f46\u6839\u636e\u5e38\u89c1\u60c5\u51b5\uff0c\u53ef\u80fdshelfmark\u662fAT Utrecht 4-\uff0c\u800cAT 17\u53ef\u80fd\u662f\u53e6\u4e00\u4e2a\u6807\u8bc6\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u53ef\u80fd\u53ea\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u6216\u8005\u53ef\u80fdshelfmark\u662fAT 17\uff0c\u800cUtrecht 4-\u662f\u4e3b\u9898\uff1f\u4f46\u4e3b\u9898\u90e8\u5206\u9700\u8981\u770b\u662f\u5426\u6709\u5206\u7c7b\u3002\u539f\u5361\u7247\u4e2d\u6ca1\u6709\u660e\u786e\u7684\u4e3b\u9898\u8bcd\uff0c\u6240\u4ee5subjects\u7559\u7a7a\u3002\\n\\n\u73b0\u5728\u9700\u8981\u786e\u8ba4\u5404\u4e2a\u5b57\u6bb5\u662f\u5426\u6b63\u786e\uff1a\\n\\n\u6807\u9898\u662f\u5426\u6b63\u786e\uff1f\u539f\u5361\u7247\u7b2c\u4e00\u884c\u662f\u4f5c\u8005\u548c\u6807\u9898\u5417\uff1f\u53ef\u80fd\u7b2c\u4e00\u884c\u662f\u4f5c\u8005\uff0c\u7b2c\u4e8c\u884c\u5f00\u59cb\u662f\u51fa\u7248\u4fe1\u606f\u3002\u4f8b\u5982\uff0c\u201cSchuurbeque Boeije, Jacobus. Kellingen.\u201d\u53ef\u80fd\u6807\u9898\u662fKellingen\uff0c\u800c\u540e\u9762\u662f\u51fa\u7248\u4fe1\u606f\u3002\u6240\u4ee5\u6807\u9898\u662fKellingen\uff0c\u6b63\u786e\u3002\\n\\n\u9875\u6570\u662f12\uff0c\u6b63\u786e\u3002\u683c\u5f0f\u662f8\u00b0\uff0c\u6b63\u786e\u3002\u51fa\u7248\u5546\u662fden Boer\uff0c\u6b63\u786e\u3002\u5730\u70b9Utrecht\uff0c\u6b63\u786e\u3002\\n\\n\u56fe\u4e66\u9986shelfmark\u53ef\u80fd\u53d6AT Utrecht 4-\uff0c\u4f46\u539f\u5361\u7247\u4e2d\u6709\u201cAT. Utrecht 4-.\u201d\u548c\u201cAT 17.\u201d\uff0c\u53ef\u80fd\u9700\u8981\u5408\u5e76\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0cshelfmark\u901a\u5e38\u662f\u4e00\u4e2a\uff0c\u6240\u4ee5\u53ef\u80fd\u9009AT Utrecht 4-\uff0c\u6216\u8005AT 17\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u770b\u54ea\u4e2a\u66f4\u7b26\u5408\u5e38\u89c4\u3002\u4f8b\u5982\uff0cAT\u53ef\u80fd\u4ee3\u8868\u67d0\u4e2a\u56fe\u4e66\u9986\u7684\u7f29\u5199\uff0cUtrecht\u662f\u5730\u70b9\uff0c4-\u53ef\u80fd\u662f\u7f16\u53f7\uff0c\u800cAT 17\u53ef\u80fd\u662f\u53e6\u4e00\u4e2a\u7f16\u53f7\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0c\u53ef\u80fdshelfmark\u662fAT Utrecht 4-\uff0c\u800cAT 17\u53ef\u80fd\u5c5e\u4e8e\u5176\u4ed6\u4fe1\u606f\uff0c\u4f46\u89c4\u5219\u4e2dshelfmark\u53ef\u80fd\u4ee5AT\u5f00\u5934\uff0c\u6240\u4ee5\u53ef\u80fd\u53d6AT Utrecht 4-\u3002\u6216\u8005\u53ef\u80fdshelfmark\u662fAT 17\uff0c\u800cUtrecht 4-\u662f\u4e3b\u9898\uff1f\u4f46\u4e3b\u9898\u90e8\u5206\u6ca1\u6709\u5185\u5bb9\uff0c\u6240\u4ee5\u53ef\u80fdshelfmark\u662fAT Utrecht 4-\uff0c\u800cAT 17\u53ef\u80fd\u88ab\u5ffd\u7565\uff0c\u6216\u8005\u4f5c\u4e3a\u53e6\u4e00\u4e2ashelfmark\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u53ea\u53d6\u4e00\u4e2a\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5224\u65ad\uff0c\u4f46\u6839\u636e\u5e38\u89c1\u60c5\u51b5\uff0c\u53ef\u80fdshelfmark\u662fAT Utrecht 4-\uff0c\u800cAT 17\u53ef\u80fd\u662f\u53e6\u4e00\u4e2a\u6807\u8bc6\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5408\u5e76\uff0c\u6216\u8005\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u4f8b\u5982\uff0c\u539f\u5361\u7247\u4e2d\u7684\u201cAT. Utrecht 4-.\u201d\u53ef\u80fd\u66f4\u5b8c\u6574\uff0c\u6240\u4ee5shelfmark\u586bAT Utrecht 4-\uff0c\u800cAT 17\u53ef\u80fd\u5c5e\u4e8e\u5176\u4ed6\u4fe1\u606f\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u53ea\u53d6shelfmark\uff0c\u6240\u4ee5\u53ef\u80fd\u9009\u8fd9\u4e2a\u3002\\n\\n\u4e3b\u9898\u90e8\u5206\u6ca1\u6709\u660e\u786e\u4fe1\u606f\uff0c\u6240\u4ee5\u7559\u7a7a\u3002\\n\\n\u73b0\u5728\u68c0\u67e5\u6240\u6709\u5b57\u6bb5\u662f\u5426\u7b26\u5408\u8981\u6c42\uff1a\\n\\n\u7c7b\u578b\u6b63\u786e\uff0c\u4f5c\u8005\u6b63\u786e\uff0c\u51fa\u7248\u4fe1\u606f\u4e2d\u7684\u5404\u4e2a\u5b57\u6bb5\u662f\u5426\u6b63\u786e\uff0c\u56fe\u4e66\u9986\u53c2\u8003\u7684shelfmark\u548csubjects\u662f\u5426\u6b63\u786e\u3002\\n\\n\u53ef\u80fd\u9700\u8981\u6ce8\u610f\u7684\u5730\u65b9\uff1a\\n\\n- \u6807\u9898\u662f\u5426\u5e94\u8be5\u5305\u62ec\u540e\u9762\u7684\u53e5\u53f7\uff1f\u6bd4\u5982\u201cKellingen.\u201d\uff0c\u4f46\u6839\u636e\u89c4\u5219\uff0c\u6807\u9898\u662f\u4e3b\u6807\u9898\uff0c\u53ef\u80fd\u53bb\u6389\u6807\u70b9\uff0c\u6240\u4ee5\u586bKellingen\u3002\\n- \u9875\u6570\u662f\u5426\u53bb\u6389S.\uff0c\u662f\u7684\uff0c\u6240\u4ee512\u3002\\n- \u683c\u5f0f\u662f8\u00b0\uff0c\u6b63\u786e\u3002\\n- \u51fa\u7248\u5546\u662fden Boer\uff0c\u6b63\u786e\u3002\\n- shelfmark\u662f\u5426\u6b63\u786e\uff0c\u53ef\u80fd\u9700\u8981\u786e\u8ba4\uff0c\u4f46\u6839\u636e\u73b0\u6709\u4fe1\u606f\uff0c\u586bAT Utrecht 4-\u3002\\n- subjects\u7559\u7a7a\u3002\\n\\n\u73b0\u5728\u5c06\u8fd9\u4e9b\u6574\u7406\u6210JSON\u7ed3\u6784\uff0c\u786e\u4fdd\u7b26\u5408\u63d0\u4f9b\u7684schema\uff0c\u7279\u522b\u662f\u7c7b\u578b\u662f\u5426\u6b63\u786e\uff0c\u5b57\u6bb5\u662f\u5426\u9f50\u5168\uff0c\u7a7a\u503c\u7528\u7a7a\u5b57\u7b26\u4e32\uff0c\u5e74\u4efd\u662f\u6574\u6570\u3002\\n\\n\u6700\u540e\u68c0\u67e5\u662f\u5426\u6709\u9057\u6f0f\u6216\u9519\u8bef\uff0c\u6bd4\u5982\u4f5c\u8005\u7684\u540d\u5b57\u662f\u5426\u6b63\u786e\u5206\u5272\uff0c\u51fa\u7248\u4fe1\u606f\u662f\u5426\u51c6\u786e\uff0c\u56fe\u4e66\u9986\u53c2\u8003\u662f\u5426\u6b63\u786e\u3002\",\"format\":\"unknown\",\"index\":0}]},\"native_finish_reason\":\"stop\"}],\"created\":1776772394,\"model\":\"qwen/qwen3.5-plus-20260216\",\"object\":\"chat.completion\",\"service_tier\":null,\"system_fingerprint\":null,\"usage\":{\"completion_tokens\":1606,\"prompt_tokens\":1819,\"total_tokens\":3425,\"completion_tokens_details\":{\"accepted_prediction_tokens\":null,\"audio_tokens\":0,\"reasoning_tokens\":1445,\"rejected_prediction_tokens\":null,\"image_tokens\":0},\"prompt_tokens_details\":{\"audio_tokens\":0,\"cached_tokens\":0,\"cache_write_tokens\":0,\"video_tokens\":0},\"cost\":0.0029783,\"is_byok\":false,\"cost_details\":{\"upstream_inference_cost\":0.0029783,\"upstream_inference_prompt_cost\":0.00047294,\"upstream_inference_completions_cost\":0.00250536}},\"provider\":\"Alibaba\"}"
