    "raw_response": "{\"id\":\"gen-1776771999-v7dmQqJ53IKXfCJObX3W\",\"choices\":[{\"finish_reason\":\"stop\",\"index\":0,\"logprobs\":null,\"message\":{\"content\":\"{\\n  \\\"metadata\\\": {\\n    \\\"send_date\\\": [\\\"1928-05-10\\\"],\\n    \\\"letter_title\\\": [\\\"Abrechnung\\\"],\\n    \\\"sender_persons\\\": [\\\"Basler Rheinschiffahrt - Aktiengesellschaft\\\"],\\n    \\\"receiver_persons\\\": null\\n  }\\n}\",\"refusal\":null,\"role\":\"assistant\",\"annotations\":null,\"audio\":null,\"function_call\":null,\"tool_calls\":null,\"parsed\":{\"metadata\":{\"send_date\":[\"1928-05-10\"],\"letter_title\":[\"Abrechnung\"],\"sender_persons\":[\"Basler Rheinschiffahrt - Aktiengesellschaft\"],\"receiver_persons\":null}},\"reasoning\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u5386\u53f2\u4fe1\u4ef6\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u51fa\u6307\u5b9a\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u7528\u6237\u8981\u6c42\u63d0\u53d6\u56db\u4e2a\u5b57\u6bb5\uff1aletter_title\u3001sender_persons\u3001send_date\u548creceiver_persons\uff0c\u6bcf\u4e2a\u5b57\u6bb5\u90fd\u662f\u5217\u8868\u5f62\u5f0f\uff0c\u5373\u4f7f\u53ea\u6709\u4e00\u4e2a\u503c\u3002\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u5c31\u8bbe\u4e3anull\u3002\u65e5\u671f\u8981\u7528ISO\u683c\u5f0fYYYY-MM-DD\u3002\\n\\n\u9996\u5148\uff0c\u6211\u9700\u8981\u4ed4\u7ec6\u67e5\u770b\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\u3002\u4fe1\u4ef6\u7684\u9876\u90e8\u6709Basler Rheinschiffahrt-Aktiengesellschaft\u7684\u5730\u5740\u548c\u8054\u7cfb\u65b9\u5f0f\uff0c\u8fd9\u5e94\u8be5\u662f\u53d1\u4ef6\u4eba\u3002\u65e5\u671f\u90e8\u5206\u5728\u53f3\u4e0a\u89d2\uff0c\u5199\u7740\u201cBasel, den 10. Mai /28\u201d\uff0c\u8fd9\u91cc\u7684\u201c/28\u201d\u53ef\u80fd\u662f\u63071928\u5e74\uff0c\u6240\u4ee5\u65e5\u671f\u5e94\u8be5\u662f1928-05-10\u3002\u4e0d\u8fc7\u9700\u8981\u786e\u8ba4\u662f\u5426\u6709\u5176\u4ed6\u53ef\u80fd\u7684\u89e3\u91ca\uff0c\u6bd4\u598228\u65e5\uff0c\u4f46\u7ed3\u5408\u4e0a\u4e0b\u6587\uff0c\u5e74\u4efd\u7684\u53ef\u80fd\u6027\u66f4\u5927\uff0c\u56e0\u4e3a\u901a\u5e38\u65e5\u671f\u683c\u5f0f\u662f\u65e5/\u6708/\u5e74\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u56e0\u4e3a\u6392\u7248\u95ee\u9898\uff0c\u6240\u4ee5\u201cMai /28\u201d\u53ef\u80fd\u63071928\u5e745\u670810\u65e5\u3002\\n\\n\u63a5\u4e0b\u6765\uff0c\u6536\u4ef6\u4eba\u90e8\u5206\uff0c\u4fe1\u4e2d\u63d0\u5230\u201cBasler Personenschiffahrtsgesellschaft Basel\u201d\uff0c\u8fd9\u5e94\u8be5\u662f\u6536\u4ef6\u7684\u516c\u53f8\u540d\u79f0\uff0c\u6240\u4ee5receiver_persons\u5e94\u8be5\u662f\u8fd9\u4e2a\u516c\u53f8\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662f\u4eba\u540d\uff0c\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\uff0c\u53ea\u6709\u516c\u53f8\u540d\u79f0\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u8bbe\u4e3anull\uff0c\u6216\u8005\u5982\u679c\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u7684\u8bdd\uff0c\u53ef\u80fd\u9700\u8981\u586b\u5199\u3002\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u793a\u4f8b\u4e2d\u7684receiver_persons\u662f\u5177\u4f53\u7684\u4eba\u540d\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\uff0c\u6240\u4ee5receiver_persons\u8bbe\u4e3anull\u3002\\n\\n\u4fe1\u4ef6\u7684\u6807\u9898\u90e8\u5206\uff0c\u901a\u5e38\u4f1a\u6709\u201cBetr.\u201d\uff08Betreff\u7684\u7f29\u5199\uff0c\u5373\u4e3b\u9898\uff09\uff0c\u8fd9\u91cc\u5199\u7684\u662f\u201cAbrechnung\u201d\uff0c\u6240\u4ee5letter_title\u5e94\u8be5\u662f\u201cAbrechnung\u201d\u3002\\n\\n\u53d1\u4ef6\u4eba\u65b9\u9762\uff0c\u4fe1\u4ef6\u7684\u843d\u6b3e\u662f\u201cBasler Rheinschiffahrt - Aktiengesellschaft\u201d\uff0c\u5e76\u6709\u7b7e\u540d\uff0c\u4f46\u7b7e\u540d\u770b\u8d77\u6765\u50cf\u662f\u624b\u5199\uff0c\u53ef\u80fd\u65e0\u6cd5\u8fa8\u8ba4\u5177\u4f53\u4eba\u540d\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u53ea\u80fd\u586b\u5199\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u4e2a\u4eba\u7b7e\u540d\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u90e8\u5206\u6709\u4e24\u4e2a\u624b\u5199\u7b7e\u540d\uff0c\u4f46\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u586b\u5199\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u6839\u636e\u7528\u6237\u7684\u8981\u6c42\uff0csender_persons\u5e94\u8be5\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u5982\u679c\u65e0\u6cd5\u8bc6\u522b\uff0c\u53ef\u80fd\u8bbe\u4e3anull\u3002\u4e0d\u8fc7\u539f\u4fe1\u4e2d\u7684\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\uff0c\u4f46\u793a\u4f8b\u4e2d\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5224\u65ad\u3002\\n\\n\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0csender_persons\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u800c\u8fd9\u91cc\u7684\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\uff0c\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b26\u5408\u8981\u6c42\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u53ef\u80fd\u5e94\u8be5\u586b\u5199\u4e2a\u4eba\u540d\u5b57\u3002\u4f46\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u53ef\u80fd\u65e0\u6cd5\u8fa8\u8ba4\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u586b\u5199\u516c\u53f8\u540d\u79f0\uff0c\u6216\u8005\u8bbe\u4e3anull\u3002\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u4e00\u4e0b\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u90e8\u5206\u3002\\n\\n\u5728\u4fe1\u4ef6\u7684\u672b\u5c3e\uff0c\u6709\u201cHochachtend Basler Rheinschiffahrt - Aktiengesellschaft\u201d\u4ee5\u53ca\u4e24\u4e2a\u624b\u5199\u7b7e\u540d\uff0c\u4f46\u7b7e\u540d\u53ef\u80fd\u96be\u4ee5\u8fa8\u8ba4\uff0c\u6240\u4ee5\u53ef\u80fd\u65e0\u6cd5\u63d0\u53d6\u5177\u4f53\u7684\u4eba\u540d\u3002\u56e0\u6b64\uff0csender_persons\u53ef\u80fd\u53ea\u80fd\u586b\u5199\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\uff0c\u6216\u8005\u5982\u679c\u5fc5\u987b\u662f\u4eba\u540d\u7684\u8bdd\uff0c\u53ef\u80fd\u8bbe\u4e3anull\u3002\u4f46\u6839\u636e\u5386\u53f2\u4fe1\u4ef6\u7684\u60c5\u51b5\uff0c\u516c\u53f8\u4fe1\u4ef6\u901a\u5e38\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u9001\uff0c\u6240\u4ee5\u53ef\u80fd\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\u3002\u4f46\u9700\u8981\u770b\u7528\u6237\u7684\u5177\u4f53\u8981\u6c42\u3002\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u4f46\u53ef\u80fd\u5b9e\u9645\u60c5\u51b5\u4e2d\u516c\u53f8\u4e5f\u53ef\u4ee5\u3002\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\uff0c\u5373[\\\"Basler Rheinschiffahrt - Aktiengesellschaft\\\"]\u3002\\n\\n\u4e0d\u8fc7\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0c\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u800c\u8fd9\u91cc\u7684\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u671f\u671b\u7684\u662f\u4eba\u540d\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5224\u65ad\u662f\u5426\u6709\u4e2a\u4eba\u7b7e\u540d\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u90e8\u5206\u6709\u4e24\u4e2a\u624b\u5199\u7b7e\u540d\uff0c\u4f46\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\uff0c\u6240\u4ee5\u53ef\u80fd\u65e0\u6cd5\u63d0\u53d6\u5177\u4f53\u7684\u4eba\u540d\uff0c\u56e0\u6b64sender_persons\u53ef\u80fd\u53ea\u80fd\u8bbe\u4e3anull\uff0c\u6216\u8005\u586b\u5199\u516c\u53f8\u540d\u79f0\u3002\u4f46\u6839\u636e\u5386\u53f2\u4fe1\u4ef6\u7684\u60ef\u4f8b\uff0c\u516c\u53f8\u4fe1\u4ef6\u901a\u5e38\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u9001\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u5199\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\u3002\\n\\n\u73b0\u5728\u6574\u7406\u4e00\u4e0b\uff1a\\n\\nletter_title: \\\"Abrechnung\\\"\uff08\u6765\u81eaBetr. Abrechnung\uff09\\n\\nsend_date: 1928-05-10\uff08\u6839\u636eBasel, den 10. Mai /28\uff0c\u5047\u8bbe/28\u662f\u5e74\u4efd\uff09\\n\\nsender_persons: [\\\"Basler Rheinschiffahrt - Aktiengesellschaft\\\"]\uff08\u516c\u53f8\u540d\u79f0\uff09\\n\\nreceiver_persons: [\\\"Basler Personenschiffahrtsgesellschaft Basel\\\"]\uff08\u6536\u4ef6\u516c\u53f8\u540d\u79f0\uff09\\n\\n\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684receiver_persons\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u800c\u8fd9\u91cc\u7684\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u662f\u5426\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u3002\u6839\u636e\u7528\u6237\u7684\u8981\u6c42\uff0creceiver_persons\u662f\u63a5\u6536\u4fe1\u4ef6\u7684\u4eba\u540d\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\uff0c\u53ea\u6709\u516c\u53f8\u540d\u79f0\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u8bbe\u4e3anull\u3002\u6216\u8005\u5982\u679c\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u7684\u8bdd\uff0c\u5c31\u586b\u5199\u3002\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u7684\u8981\u6c42\u3002\\n\\n\u7528\u6237\u6307\u4ee4\u4e2d\u8bf4\u201creceiver_persons: Name(s) of the person(s) who received the letter.\u201d\uff0c\u6240\u4ee5\u5e94\u8be5\u662f\u4eba\u540d\uff0c\u800c\u4e0d\u662f\u516c\u53f8\u540d\u3002\u56e0\u6b64\uff0c\u5982\u679c\u4fe1\u4e2d\u6ca1\u6709\u63d0\u5230\u5177\u4f53\u7684\u4eba\u540d\uff0creceiver_persons\u5e94\u8be5\u8bbe\u4e3anull\u3002\u540c\u6837\uff0csender_persons\u5982\u679c\u662f\u516c\u53f8\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u4e2a\u4eba\u7b7e\u540d\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u90e8\u5206\u6709\u4e24\u4e2a\u624b\u5199\u7b7e\u540d\uff0c\u4f46\u53ef\u80fd\u65e0\u6cd5\u8fa8\u8ba4\uff0c\u6240\u4ee5\u53ef\u80fd\u65e0\u6cd5\u63d0\u53d6\u5177\u4f53\u7684\u4eba\u540d\uff0c\u56e0\u6b64sender_persons\u53ef\u80fd\u8bbe\u4e3anull\uff0c\u6216\u8005\u586b\u5199\u516c\u53f8\u540d\u79f0\u3002\u4f46\u6839\u636e\u5386\u53f2\u4fe1\u4ef6\u7684\u5904\u7406\uff0c\u516c\u53f8\u4fe1\u4ef6\u901a\u5e38\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u9001\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u5199\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u671f\u671b\u7684\u662f\u4eba\u540d\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5224\u65ad\u3002\\n\\n\u6216\u8005\uff0c\u53ef\u80fd\u4fe1\u4e2d\u7684\u201cBasler Rheinschiffahrt - Aktiengesellschaft\u201d\u662f\u53d1\u4ef6\u516c\u53f8\uff0c\u800c\u7b7e\u540d\u7684\u4eba\u53ef\u80fd\u662f\u516c\u53f8\u7684\u4ee3\u8868\uff0c\u4f46\u7b7e\u540d\u65e0\u6cd5\u8fa8\u8ba4\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u53ea\u80fd\u586b\u5199\u516c\u53f8\u540d\u79f0\uff0c\u6216\u8005\u8bbe\u4e3anull\u3002\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u8fd9\u91cc\u5e94\u8be5\u586b\u5199\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\uff0c\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b26\u5408\u8981\u6c42\u3002\\n\\n\u73b0\u5728\u518d\u4ed4\u7ec6\u770b\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\uff1a\\n\\n\u5728\u4fe1\u4ef6\u7684\u672b\u5c3e\uff0c\u6709\u201cHochachtend Basler Rheinschiffahrt - Aktiengesellschaft\u201d\u4ee5\u53ca\u4e24\u4e2a\u624b\u5199\u7b7e\u540d\uff0c\u53ef\u80fd\u7b7e\u540d\u7684\u4eba\u662f\u516c\u53f8\u7684\u4ee3\u8868\uff0c\u4f46\u540d\u5b57\u65e0\u6cd5\u8fa8\u8ba4\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u65e0\u6cd5\u63d0\u53d6\u5177\u4f53\u7684\u4eba\u540d\uff0c\u56e0\u6b64\u8bbe\u4e3anull\u3002\u4f46\u6839\u636e\u5386\u53f2\u4fe1\u4ef6\u7684\u5904\u7406\uff0c\u901a\u5e38\u516c\u53f8\u4fe1\u4ef6\u4f1a\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u9001\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u5b58\u5728\u77db\u76fe\u3002\\n\\n\u6216\u8005\uff0c\u53ef\u80fd\u7528\u6237\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\uff0c\u5373\u4f7f\u793a\u4f8b\u4e2d\u662f\u4e2a\u4eba\u3002\u56e0\u6b64\uff0c\u53ef\u80fd\u5e94\u8be5\u586b\u5199\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\u3002\\n\\n\u540c\u6837\uff0creceiver_persons\u662f\u201cBasler Personenschiffahrtsgesellschaft Basel\u201d\uff0c\u8fd9\u662f\u4e00\u4e2a\u516c\u53f8\uff0c\u6240\u4ee5\u5982\u679c\u7528\u6237\u8981\u6c42\u7684\u662f\u4eba\u540d\uff0c\u8fd9\u91cc\u5e94\u8be5\u8bbe\u4e3anull\uff0c\u4f46\u5982\u679c\u662f\u5141\u8bb8\u516c\u53f8\u540d\u7684\u8bdd\uff0c\u5c31\u586b\u5199\u3002\u4f46\u6839\u636e\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u63cf\u8ff0\uff0creceiver_persons\u662f\u63a5\u6536\u4fe1\u4ef6\u7684\u4eba\u540d\uff0c\u6240\u4ee5\u5e94\u8be5\u8bbe\u4e3anull\u3002\\n\\n\u73b0\u5728\u9700\u8981\u786e\u5b9a\uff1a\\n\\nletter_title: \\\"Abrechnung\\\"\\n\\nsend_date: 1928-05-10\\n\\nsender_persons: [\\\"Basler Rheinschiffahrt - Aktiengesellschaft\\\"]\\n\\nreceiver_persons: null\\n\\n\u4f46\u9700\u8981\u786e\u8ba4\u65e5\u671f\u662f\u5426\u6b63\u786e\u3002\u539f\u4fe1\u4e2d\u7684\u65e5\u671f\u662f\u201cBasel, den 10. Mai /28\u201d\uff0c\u8fd9\u91cc\u7684\u201c/28\u201d\u53ef\u80fd\u662f\u63071928\u5e74\uff0c\u6240\u4ee5\u65e5\u671f\u662f1928-05-10\u3002\u4f46\u6709\u65f6\u5019\u201c/28\u201d\u53ef\u80fd\u630728\u65e5\uff0c\u4f46\u7ed3\u5408\u4e0a\u4e0b\u6587\uff0c\u6708\u4efd\u662fMai\uff085\u6708\uff09\uff0c\u6240\u4ee510\u65e5\u5df2\u7ecf\u662f\u65e5\u671f\uff0c\u6240\u4ee5\u201c/28\u201d\u66f4\u53ef\u80fd\u662f\u5e74\u4efd\uff0c\u53731928\u5e74\u3002\u56e0\u6b64send_date\u662f1928-05-10\u3002\\n\\n\u7efc\u4e0a\uff0c\u6700\u7ec8\u7684JSON\u5e94\u8be5\u662f\uff1a\\n\\n{\\n  \\\"letter_title\\\": [\\\"Abrechnung\\\"],\\n  \\\"send_date\\\": [\\\"1928-05-10\\\"],\\n  \\\"sender_persons\\\": [\\\"Basler Rheinschiffahrt - Aktiengesellschaft\\\"],\\n  \\\"receiver_persons\\\": null\\n}\\n\\n\u4f46\u9700\u8981\u68c0\u67e5receiver_persons\u662f\u5426\u5e94\u8be5\u4e3a\u516c\u53f8\u540d\u8fd8\u662fnull\u3002\u6839\u636e\u7528\u6237\u6307\u4ee4\uff0creceiver_persons\u662f\u63a5\u6536\u4fe1\u4ef6\u7684\u4eba\u540d\uff0c\u800c\u4fe1\u4e2d\u63d0\u5230\u7684\u6536\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u5e94\u8be5\u8bbe\u4e3anull\u3002\u540c\u6837\uff0csender_persons\u5982\u679c\u662f\u516c\u53f8\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u662f\u4e2a\u4eba\uff0c\u4f46\u53ef\u80fd\u5141\u8bb8\u516c\u53f8\u540d\uff0c\u6240\u4ee5\u586b\u5199\u516c\u53f8\u540d\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u5386\u53f2\u4fe1\u4ef6\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u51fa\u6307\u5b9a\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u7528\u6237\u8981\u6c42\u63d0\u53d6\u56db\u4e2a\u5b57\u6bb5\uff1aletter_title\u3001sender_persons\u3001send_date\u548creceiver_persons\uff0c\u6bcf\u4e2a\u5b57\u6bb5\u90fd\u662f\u5217\u8868\u5f62\u5f0f\uff0c\u5373\u4f7f\u53ea\u6709\u4e00\u4e2a\u503c\u3002\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u5c31\u8bbe\u4e3anull\u3002\u65e5\u671f\u8981\u7528ISO\u683c\u5f0fYYYY-MM-DD\u3002\\n\\n\u9996\u5148\uff0c\u6211\u9700\u8981\u4ed4\u7ec6\u67e5\u770b\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\u3002\u4fe1\u4ef6\u7684\u9876\u90e8\u6709Basler Rheinschiffahrt-Aktiengesellschaft\u7684\u5730\u5740\u548c\u8054\u7cfb\u65b9\u5f0f\uff0c\u8fd9\u5e94\u8be5\u662f\u53d1\u4ef6\u4eba\u3002\u65e5\u671f\u90e8\u5206\u5728\u53f3\u4e0a\u89d2\uff0c\u5199\u7740\u201cBasel, den 10. Mai /28\u201d\uff0c\u8fd9\u91cc\u7684\u201c/28\u201d\u53ef\u80fd\u662f\u63071928\u5e74\uff0c\u6240\u4ee5\u65e5\u671f\u5e94\u8be5\u662f1928-05-10\u3002\u4e0d\u8fc7\u9700\u8981\u786e\u8ba4\u662f\u5426\u6709\u5176\u4ed6\u53ef\u80fd\u7684\u89e3\u91ca\uff0c\u6bd4\u598228\u65e5\uff0c\u4f46\u7ed3\u5408\u4e0a\u4e0b\u6587\uff0c\u5e74\u4efd\u7684\u53ef\u80fd\u6027\u66f4\u5927\uff0c\u56e0\u4e3a\u901a\u5e38\u65e5\u671f\u683c\u5f0f\u662f\u65e5/\u6708/\u5e74\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u56e0\u4e3a\u6392\u7248\u95ee\u9898\uff0c\u6240\u4ee5\u201cMai /28\u201d\u53ef\u80fd\u63071928\u5e745\u670810\u65e5\u3002\\n\\n\u63a5\u4e0b\u6765\uff0c\u6536\u4ef6\u4eba\u90e8\u5206\uff0c\u4fe1\u4e2d\u63d0\u5230\u201cBasler Personenschiffahrtsgesellschaft Basel\u201d\uff0c\u8fd9\u5e94\u8be5\u662f\u6536\u4ef6\u7684\u516c\u53f8\u540d\u79f0\uff0c\u6240\u4ee5receiver_persons\u5e94\u8be5\u662f\u8fd9\u4e2a\u516c\u53f8\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662f\u4eba\u540d\uff0c\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\uff0c\u53ea\u6709\u516c\u53f8\u540d\u79f0\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u8bbe\u4e3anull\uff0c\u6216\u8005\u5982\u679c\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u7684\u8bdd\uff0c\u53ef\u80fd\u9700\u8981\u586b\u5199\u3002\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u793a\u4f8b\u4e2d\u7684receiver_persons\u662f\u5177\u4f53\u7684\u4eba\u540d\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\uff0c\u6240\u4ee5receiver_persons\u8bbe\u4e3anull\u3002\\n\\n\u4fe1\u4ef6\u7684\u6807\u9898\u90e8\u5206\uff0c\u901a\u5e38\u4f1a\u6709\u201cBetr.\u201d\uff08Betreff\u7684\u7f29\u5199\uff0c\u5373\u4e3b\u9898\uff09\uff0c\u8fd9\u91cc\u5199\u7684\u662f\u201cAbrechnung\u201d\uff0c\u6240\u4ee5letter_title\u5e94\u8be5\u662f\u201cAbrechnung\u201d\u3002\\n\\n\u53d1\u4ef6\u4eba\u65b9\u9762\uff0c\u4fe1\u4ef6\u7684\u843d\u6b3e\u662f\u201cBasler Rheinschiffahrt - Aktiengesellschaft\u201d\uff0c\u5e76\u6709\u7b7e\u540d\uff0c\u4f46\u7b7e\u540d\u770b\u8d77\u6765\u50cf\u662f\u624b\u5199\uff0c\u53ef\u80fd\u65e0\u6cd5\u8fa8\u8ba4\u5177\u4f53\u4eba\u540d\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u53ea\u80fd\u586b\u5199\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u4e2a\u4eba\u7b7e\u540d\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u90e8\u5206\u6709\u4e24\u4e2a\u624b\u5199\u7b7e\u540d\uff0c\u4f46\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u586b\u5199\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u6839\u636e\u7528\u6237\u7684\u8981\u6c42\uff0csender_persons\u5e94\u8be5\u662f\u4eba\u540d\uff0c\u6240\u4ee5\u5982\u679c\u65e0\u6cd5\u8bc6\u522b\uff0c\u53ef\u80fd\u8bbe\u4e3anull\u3002\u4e0d\u8fc7\u539f\u4fe1\u4e2d\u7684\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\uff0c\u4f46\u793a\u4f8b\u4e2d\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5224\u65ad\u3002\\n\\n\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0csender_persons\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u800c\u8fd9\u91cc\u7684\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\uff0c\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b26\u5408\u8981\u6c42\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u53ef\u80fd\u5e94\u8be5\u586b\u5199\u4e2a\u4eba\u540d\u5b57\u3002\u4f46\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u53ef\u80fd\u65e0\u6cd5\u8fa8\u8ba4\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u586b\u5199\u516c\u53f8\u540d\u79f0\uff0c\u6216\u8005\u8bbe\u4e3anull\u3002\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u4e00\u4e0b\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u90e8\u5206\u3002\\n\\n\u5728\u4fe1\u4ef6\u7684\u672b\u5c3e\uff0c\u6709\u201cHochachtend Basler Rheinschiffahrt - Aktiengesellschaft\u201d\u4ee5\u53ca\u4e24\u4e2a\u624b\u5199\u7b7e\u540d\uff0c\u4f46\u7b7e\u540d\u53ef\u80fd\u96be\u4ee5\u8fa8\u8ba4\uff0c\u6240\u4ee5\u53ef\u80fd\u65e0\u6cd5\u63d0\u53d6\u5177\u4f53\u7684\u4eba\u540d\u3002\u56e0\u6b64\uff0csender_persons\u53ef\u80fd\u53ea\u80fd\u586b\u5199\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\uff0c\u6216\u8005\u5982\u679c\u5fc5\u987b\u662f\u4eba\u540d\u7684\u8bdd\uff0c\u53ef\u80fd\u8bbe\u4e3anull\u3002\u4f46\u6839\u636e\u5386\u53f2\u4fe1\u4ef6\u7684\u60c5\u51b5\uff0c\u516c\u53f8\u4fe1\u4ef6\u901a\u5e38\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u9001\uff0c\u6240\u4ee5\u53ef\u80fd\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\u3002\u4f46\u9700\u8981\u770b\u7528\u6237\u7684\u5177\u4f53\u8981\u6c42\u3002\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u4f46\u53ef\u80fd\u5b9e\u9645\u60c5\u51b5\u4e2d\u516c\u53f8\u4e5f\u53ef\u4ee5\u3002\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\uff0c\u5373[\\\"Basler Rheinschiffahrt - Aktiengesellschaft\\\"]\u3002\\n\\n\u4e0d\u8fc7\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0c\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u800c\u8fd9\u91cc\u7684\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u671f\u671b\u7684\u662f\u4eba\u540d\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5224\u65ad\u662f\u5426\u6709\u4e2a\u4eba\u7b7e\u540d\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u90e8\u5206\u6709\u4e24\u4e2a\u624b\u5199\u7b7e\u540d\uff0c\u4f46\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\uff0c\u6240\u4ee5\u53ef\u80fd\u65e0\u6cd5\u63d0\u53d6\u5177\u4f53\u7684\u4eba\u540d\uff0c\u56e0\u6b64sender_persons\u53ef\u80fd\u53ea\u80fd\u8bbe\u4e3anull\uff0c\u6216\u8005\u586b\u5199\u516c\u53f8\u540d\u79f0\u3002\u4f46\u6839\u636e\u5386\u53f2\u4fe1\u4ef6\u7684\u60ef\u4f8b\uff0c\u516c\u53f8\u4fe1\u4ef6\u901a\u5e38\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u9001\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u5199\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\u3002\\n\\n\u73b0\u5728\u6574\u7406\u4e00\u4e0b\uff1a\\n\\nletter_title: \\\"Abrechnung\\\"\uff08\u6765\u81eaBetr. Abrechnung\uff09\\n\\nsend_date: 1928-05-10\uff08\u6839\u636eBasel, den 10. Mai /28\uff0c\u5047\u8bbe/28\u662f\u5e74\u4efd\uff09\\n\\nsender_persons: [\\\"Basler Rheinschiffahrt - Aktiengesellschaft\\\"]\uff08\u516c\u53f8\u540d\u79f0\uff09\\n\\nreceiver_persons: [\\\"Basler Personenschiffahrtsgesellschaft Basel\\\"]\uff08\u6536\u4ef6\u516c\u53f8\u540d\u79f0\uff09\\n\\n\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684receiver_persons\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u800c\u8fd9\u91cc\u7684\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u662f\u5426\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u3002\u6839\u636e\u7528\u6237\u7684\u8981\u6c42\uff0creceiver_persons\u662f\u63a5\u6536\u4fe1\u4ef6\u7684\u4eba\u540d\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\uff0c\u53ea\u6709\u516c\u53f8\u540d\u79f0\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u8bbe\u4e3anull\u3002\u6216\u8005\u5982\u679c\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u7684\u8bdd\uff0c\u5c31\u586b\u5199\u3002\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u7684\u8981\u6c42\u3002\\n\\n\u7528\u6237\u6307\u4ee4\u4e2d\u8bf4\u201creceiver_persons: Name(s) of the person(s) who received the letter.\u201d\uff0c\u6240\u4ee5\u5e94\u8be5\u662f\u4eba\u540d\uff0c\u800c\u4e0d\u662f\u516c\u53f8\u540d\u3002\u56e0\u6b64\uff0c\u5982\u679c\u4fe1\u4e2d\u6ca1\u6709\u63d0\u5230\u5177\u4f53\u7684\u4eba\u540d\uff0creceiver_persons\u5e94\u8be5\u8bbe\u4e3anull\u3002\u540c\u6837\uff0csender_persons\u5982\u679c\u662f\u516c\u53f8\uff0