0\u5230\u201c\u6392\u9664\u4f4d\u7f6e\u201d\uff0c\u6240\u4ee5\u53ef\u80fd\u201cZUERICH\u201d\u662f\u4f4d\u7f6e\uff0c\u5e94\u8be5\u653e\u5728location\u5b57\u6bb5\u91cc\u3002\u6240\u4ee5\u516c\u53f8\u5e94\u8be5\u662f\u201cWinterstein & Co., Ernst\u201d\uff0c\u800clocation\u662f\u201cZUERICH\u201d\u3002\\n\\n\u63a5\u4e0b\u6765\u662fb_id\uff0c\u5728\u53f3\u4e0a\u89d2\uff0c\u4ee5B.\u5f00\u5934\u3002\u8fd9\u91cc\u663e\u793a\u7684\u662f\u201cB.51.322.GB.452.\u201d\uff0c\u6240\u4ee5\u76f4\u63a5\u63d0\u53d6\u8fd9\u4e2a\u5b57\u7b26\u4e32\u3002\\n\\n\u65e5\u671f\u90e8\u5206\uff0c\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u76d6\u7ae0\u7684\u65e5\u671f\u3002\u5728\u5361\u7247\u4e2d\u95f4\u90e8\u5206\u6709\u201cAmendment 21, Dezember 1941.\u201d\u548c\u201cgestrichen: Amendment 13, 23.11.1945.\u201d\u3002\u8fd9\u4e24\u4e2a\u65e5\u671f\u5206\u522b\u662f1941\u5e7412\u6708\u548c1945\u5e7411\u670823\u65e5\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662fYYYY-MM-DD\u683c\u5f0f\uff0c\u6240\u4ee5\u9700\u8981\u8f6c\u6362\u3002\u7b2c\u4e00\u4e2a\u65e5\u671f\u662f1941-12\uff0c\u4f46\u5177\u4f53\u65e5\u671f\u4e0d\u660e\u786e\uff0c\u53ef\u80fd\u53ea\u6709\u6708\u4efd\uff0c\u6240\u4ee5\u53ef\u80fd\u65e0\u6cd5\u8f6c\u6362\u4e3a\u5b8c\u6574\u65e5\u671f\u3002\u7b2c\u4e8c\u4e2a\u662f23.11.1945\uff0c\u53731945-11-23\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u63d0\u53d6\u6240\u6709\u65e5\u671f\uff0c\u4f46\u6839\u636e\u6307\u793a\uff0c\u53ef\u80fd\u53ea\u53d6\u4e00\u4e2a\uff1f\u6216\u8005\u9700\u8981\u5408\u5e76\uff1f\u4e0d\u8fc7\u7528\u6237\u8bf4\u201c\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\u201d\uff0c\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5217\u51fa\u6765\u3002\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u53ef\u80fd\u53ea\u80fd\u653e\u4e00\u4e2a\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u591a\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u4f46\u539f\u6307\u793a\u53ef\u80fd\u5e0c\u671b\u5982\u679c\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u5904\u7406\u3002\u4e0d\u8fc7\u539f\u793a\u4f8b\u4e2d\u7684date\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u9009\u62e9\u5176\u4e2d\u4e00\u4e2a\uff0c\u6216\u8005\u5408\u5e76\u3002\u4f46\u6839\u636e\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\uff0c\u53ef\u80fd\u6709\u4e24\u4e2a\u65e5\u671f\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u4e24\u4e2a\u90fd\u63d0\u53d6\u51fa\u6765\uff0c\u4f46\u6839\u636e\u683c\u5f0f\uff0cdate\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u6216\u8005\u53ea\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u4e0d\u8fc7\u4ed4\u7ec6\u770b\u7528\u6237\u6307\u4ee4\uff0c\u53ef\u80fddate\u5b57\u6bb5\u662f\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\uff0c\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5217\u51fa\u6765\uff0c\u4f46JSON\u7ed3\u6784\u4e2ddate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u53ef\u80fd\u65e0\u6cd5\u5904\u7406\u591a\u4e2a\u3002\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u53ef\u80fd\u53ea\u53d6\u4e00\u4e2a\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5728date\u5b57\u6bb5\u91cc\uff0c\u7528\u67d0\u79cd\u5206\u9694\u7b26\uff0c\u4f46\u539f\u6307\u793a\u6ca1\u6709\u8bf4\u660e\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\\n\\n\u4e0d\u8fc7\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\uff0cdate\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u4f46\u56fe\u7247\u4e2d\u6709\u4e24\u4e2a\u65e5\u671f\uff1a1941\u5e7412\u6708\u548c1945\u5e7411\u670823\u65e5\u3002\u4f46\u6839\u636e\u5361\u7247\u5185\u5bb9\uff0c\u53ef\u80fd\u8fd9\u4e24\u4e2a\u65e5\u671f\u90fd\u662f\u76f8\u5173\u7684\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u662f\u5217\u5165\u9ed1\u540d\u5355\u7684\u65e5\u671f\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5220\u9664\u7684\u65e5\u671f\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u4e24\u4e2a\u90fd\u63d0\u53d6\u51fa\u6765\uff0c\u4f46\u6839\u636e\u683c\u5f0f\uff0c\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u53ea\u53d6\u6700\u65b0\u7684\u65e5\u671f\uff1f\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5728date\u5b57\u6bb5\u91cc\uff0c\u7528\u5206\u53f7\u5206\u9694\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684JSON schema\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u4f8b\u5982\uff1a\u201c1941-12; 1945-11-23\u201d\u3002\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b26\u5408\u8981\u6c42\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u53ea\u5e0c\u671b\u63d0\u53d6\u660e\u786e\u7684\u65e5\u671f\uff0c\u6bd4\u5982\u7b2c\u4e8c\u4e2a\u65e5\u671f\u662f\u5b8c\u6574\u7684\uff0c\u800c\u7b2c\u4e00\u4e2a\u53ea\u6709\u6708\u4efd\u3002\u6240\u4ee5\u53ef\u80fd\u7b2c\u4e8c\u4e2a\u65e5\u671f\u66f4\u7b26\u5408YYYY-MM-DD\u683c\u5f0f\uff0c\u800c\u7b2c\u4e00\u4e2a\u65e0\u6cd5\u8f6c\u6362\u3002\u56e0\u6b64\uff0c\u53ef\u80fd\u5c06\u7b2c\u4e8c\u4e2a\u65e5\u671f\u4f5c\u4e3adate\u7684\u503c\uff0c\u53731945-11-23\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u90fd\u63d0\u53d6\uff0c\u4f46\u9700\u8981\u770b\u7528\u6237\u7684\u5177\u4f53\u6307\u793a\u3002\u7528\u6237\u8bf4\u201c\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\u201d\uff0c\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5217\u51fa\u6765\uff0c\u4f46JSON\u7ed3\u6784\u4e2d\u7684date\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u4f8b\u5982\uff0c\u7528\u5206\u53f7\u5206\u9694\u3002\u4f46\u539f\u793a\u4f8b\u4e2d\u6ca1\u6709\u8fd9\u79cd\u60c5\u51b5\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u6839\u636e\u60c5\u51b5\u5904\u7406\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u63d0\u53d6\uff0c\u4f46\u8f6c\u6362\u4e3a\u6b63\u786e\u7684\u683c\u5f0f\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u65e5\u671f\u662fDezember 1941\uff0c\u53731941-12\uff0c\u4f46\u7f3a\u5c11\u65e5\u671f\uff0c\u6240\u4ee5\u53ef\u80fd\u65e0\u6cd5\u8f6c\u6362\u4e3a\u5b8c\u6574\u7684YYYY-MM-DD\u3002\u800c\u7b2c\u4e8c\u4e2a\u662f23.11.1945\uff0c\u53731945-11-23\u3002\u6240\u4ee5\u53ef\u80fddate\u5b57\u6bb5\u5e94\u8be5\u586b\u51991945-11-23\uff0c\u800c\u53e6\u4e00\u4e2a\u65e5\u671f\u53ef\u80fd\u65e0\u6cd5\u5904\u7406\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5728date\u5b57\u6bb5\u91cc\uff0c\u4f46\u9700\u8981\u7b26\u5408\u683c\u5f0f\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5224\u65ad\uff0c\u4f46\u6839\u636e\u7528\u6237\u6307\u4ee4\uff0c\u53ef\u80fd\u53ea\u63d0\u53d6\u660e\u786e\u7684\u65e5\u671f\uff0c\u5373\u7b2c\u4e8c\u4e2a\u3002\u56e0\u6b64\uff0cdate\u5b57\u6bb5\u586b1945-11-23\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u4fe1\u606f\u90e8\u5206\uff0c\u4e3b\u6587\u672c\u5757\u3002\u5361\u7247\u4e2d\u95f4\u90e8\u5206\u6709\u201cBritische schwarze Liste Amendment 21, Dezember 1941.\u201d\u548c\u201cgestrichen: Amendment 13, 23.11.1945.\u201d\u3002\u8fd9\u4e24\u4e2a\u5e94\u8be5\u4f5c\u4e3a\u4e24\u4e2a\u72ec\u7acb\u7684\u4fe1\u606f\u5757\uff0c\u6bcf\u4e2a\u5757\u7528\u6362\u884c\u7b26\u5206\u9694\u3002\u6240\u4ee5information\u6570\u7ec4\u5e94\u8be5\u6709\u4e24\u4e2a\u5143\u7d20\uff0c\u6bcf\u4e2a\u5143\u7d20\u662f\u8fd9\u4e24\u4e2a\u6587\u672c\u5757\uff0c\u4fdd\u6301\u6362\u884c\u3002\u4f46\u6839\u636e\u7528\u6237\u8981\u6c42\uff0c\u6bcf\u4e2a\u5757\u662f\u5355\u72ec\u7684\u5b57\u7b26\u4e32\uff0c\u7528\\\\n\u5206\u9694\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u5757\u662f\u201cBritische schwarze Liste\\\\nAmendment 21, Dezember 1941.\u201d\uff0c\u7b2c\u4e8c\u4e2a\u662f\u201cgestrichen:\\\\nAmendment 13, 23.11.1945.\u201d\u3002\u6216\u8005\u53ef\u80fd\u6bcf\u4e2a\u5757\u662f\u5355\u72ec\u7684\u884c\uff0c\u6240\u4ee5\u6bcf\u4e2a\u5757\u4f5c\u4e3a\u5355\u72ec\u7684\u5b57\u7b26\u4e32\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u5757\u662f\u4e24\u884c\uff0c\u7b2c\u4e8c\u4e2a\u5757\u4e5f\u662f\u4e24\u884c\u3002\u4f46\u7528\u6237\u8981\u6c42\u6bcf\u4e2a\u5757\u662f\u5355\u72ec\u7684\u5b57\u7b26\u4e32\uff0c\u7528\\\\n\u5206\u9694\u3002\u6240\u4ee5\u53ef\u80fd\u6bcf\u4e2a\u5757\u4f5c\u4e3a\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u5305\u542b\u5185\u90e8\u7684\u6362\u884c\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u4fe1\u606f\u5757\u662f\u201cBritische schwarze Liste\\\\nAmendment 21, Dezember 1941.\u201d\uff0c\u7b2c\u4e8c\u4e2a\u662f\u201cgestrichen:\\\\nAmendment 13, 23.11.1945.\u201d\u3002\u8fd9\u6837\u5728JSON\u4e2d\uff0c\u6bcf\u4e2a\u5757\u4f5c\u4e3a\u5355\u72ec\u7684\u5b57\u7b26\u4e32\uff0c\u5305\u542b\u5185\u90e8\u7684\u6362\u884c\u7b26\u3002\\n\\n\u73b0\u5728\u6574\u7406\u6240\u6709\u5b57\u6bb5\uff1a\\n\\ncompany: Winterstein & Co., Ernst \uff08\u6392\u9664ZUERICH\uff0c\u56e0\u4e3alocation\u662fZUERICH\uff09\\nlocation: ZUERICH\\nb_id: B.51.322.GB.452.\\ndate: 1945-11-23 \uff08\u56e0\u4e3a\u7b2c\u4e8c\u4e2a\u65e5\u671f\u662f\u5b8c\u6574\u7684\uff0c\u800c\u7b2c\u4e00\u4e2a\u53ea\u6709\u6708\u4efd\uff09\\ninformation: \u4e24\u4e2a\u5757\uff0c\u6bcf\u4e2a\u5757\u5305\u542b\u6362\u884c\u3002\\n\\n\u4f46\u9700\u8981\u518d\u6b21\u68c0\u67e5\u662f\u5426date\u5b57\u6bb5\u5e94\u8be5\u5305\u542b\u4e24\u4e2a\u65e5\u671f\u3002\u4f8b\u5982\uff0c\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u63d0\u53d6\uff0c\u4f46\u6839\u636e\u683c\u5f0f\uff0c\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u4f8b\u5982\uff0cdate\u5b57\u6bb5\u4e3a\u201c1941-12; 1945-11-23\u201d\u3002\u4f46\u539f\u6307\u793a\u4e2d\u8bf4\u201c\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\u201d\uff0c\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5217\u51fa\u6765\u3002\u4f46JSON\u4e2d\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u4f46\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u4e2ddate\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u4f46\u539f\u95ee\u9898\u4e2d\u7684\u793a\u4f8b\u53ef\u80fd\u6ca1\u6709\u591a\u4e2a\u65e5\u671f\u7684\u60c5\u51b5\uff0c\u6240\u4ee5\u9700\u8981\u6839\u636e\u5b9e\u9645\u60c5\u51b5\u5904\u7406\u3002\u8fd9\u91cc\u53ef\u80fd\u6709\u4e24\u4e2a\u65e5\u671f\uff0c\u4f46\u7b2c\u4e00\u4e2a\u662fDezember 1941\uff0c\u65e0\u6cd5\u8f6c\u6362\u4e3aYYYY-MM-DD\uff0c\u800c\u7b2c\u4e8c\u4e2a\u662f23.11.1945\uff0c\u53ef\u4ee5\u8f6c\u6362\u3002\u6240\u4ee5\u53ef\u80fddate\u5b57\u6bb5\u53ea\u586b\u7b2c\u4e8c\u4e2a\u65e5\u671f\uff0c\u800c\u7b2c\u4e00\u4e2a\u65e5\u671f\u53ef\u80fd\u65e0\u6cd5\u5904\u7406\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u63d0\u53d6\uff0c\u4f46\u7b2c\u4e00\u4e2a\u8f6c\u6362\u4e3a1941-12-01\uff08\u5047\u8bbe\u662f\u6708\u521d\uff09\uff0c\u4f46\u8fd9\u6837\u53ef\u80fd\u4e0d\u51c6\u786e\u3002\u56e0\u6b64\uff0c\u53ef\u80fd\u53ea\u63d0\u53d6\u7b2c\u4e8c\u4e2a\u65e5\u671f\u4f5c\u4e3adate\u7684\u503c\u3002\\n\\n\u7efc\u4e0a\uff0c\u6700\u7ec8\u7684JSON\u5e94\u8be5\u662f\uff1a\\n\\n{\\n  \\\"company\\\": {\\\"transcription\\\": \\\"Winterstein & Co., Ernst\\\"},\\n  \\\"location\\\": {\\\"transcription\\\": \\\"ZUERICH\\\"},\\n  \\\"b_id\\\": {\\\"transcription\\\": \\\"B.51.322.GB.452.\\\"},\\n  \\\"date\\\": \\\"1945-11-23\\\",\\n  \\\"information\\\": [\\n    {\\\"transcription\\\": \\\"Britische schwarze Liste\\\\nAmendment 21, Dezember 1941.\\\"},\\n    {\\\"transcription\\\": \\\"gestrichen:\\\\nAmendment 13, 23.11.1945.\\\"}\\n  ]\\n}\\n\\n\u4f46\u9700\u8981\u518d\u6b21\u68c0\u67e5\u662f\u5426company\u662f\u5426\u6b63\u786e\u3002\u539f\u5361\u7247\u4e0a\u7684\u516c\u53f8\u540d\u662f\u201cWinterstein & Co., Ernst, ZUERICH\u201d\uff0c\u6240\u4ee5\u53ef\u80fd\u516c\u53f8\u540d\u5305\u62ec\u201cWinterstein & Co., Ernst\u201d\uff0c\u800clocation\u662fZUERICH\u3002\u56e0\u6b64\uff0ccompany\u5b57\u6bb5\u6b63\u786e\u3002\\n\\n\u53e6\u5916\uff0c\u68c0\u67e5b_id\u662f\u5426\u6b63\u786e\uff0c\u53f3\u4e0a\u89d2\u7684B.51.322.GB.452.\uff0c\u6240\u4ee5\u6b63\u786e\u3002\\n\\n\u4fe1\u606f\u90e8\u5206\u662f\u5426\u6b63\u786e\uff0c\u4e24\u4e2a\u5757\uff0c\u6bcf\u4e2a\u5757\u5305\u542b\u6362\u884c\u3002\u662f\u7684\u3002\\n\\n\u65e5\u671f\u90e8\u5206\u662f\u5426\u6b63\u786e\uff0c\u7b2c\u4e8c\u4e2a\u65e5\u671f\u662f23.11.1945\uff0c\u8f6c\u6362\u4e3a1945-11-23\uff0c\u6b63\u786e\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u8fd9\u5f20\u7d22\u5f15\u5361\u7684\u56fe\u50cf\uff0c\u63d0\u53d6\u6240\u9700\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u6211\u4f1a\u4ed4\u7ec6\u67e5\u770b\u56fe\u50cf\u7684\u5404\u4e2a\u90e8\u5206\uff0c\u786e\u5b9a\u6bcf\u4e2a\u5b57\u6bb5\u7684\u4f4d\u7f6e\u548c\u5185\u5bb9\u3002\\n\\n\u9996\u5148\u770b\u516c\u53f8\u90e8\u5206\uff0c\u901a\u5e38\u5728\u5de6\u4e0a\u89d2\u3002\u8fd9\u91cc\u663e\u793a\u7684\u662f\u201cWinterstein & Co., Ernst, ZUERICH\u201d\u3002\u4e0d\u8fc7\u6839\u636e\u8981\u6c42\uff0c\u516c\u53f8\u540d\u5e94\u8be5\u6392\u9664\u4f4d\u7f6e\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u9700\u8981\u201cWinterstein & Co., Ernst\u201d\u3002\u4f46\u6709\u65f6\u5019\u53ef\u80fd\u6574\u4e2a\u90e8\u5206\u90fd\u7b97\u516c\u53f8\u540d\uff0c\u9700\u8981\u786e\u8ba4\u3002\u4e0d\u8fc7\u7528\u6237\u8bf4\u660e\u91cc\u63d0\u5230\u201c\u6392\u9664\u4f4d\u7f6e\u201d\uff0c\u6240\u4ee5\u53ef\u80fd\u201cZUERICH\u201d\u662f\u4f4d\u7f6e\uff0c\u5e94\u8be5\u653e\u5728location\u5b57\u6bb5\u91cc\u3002\u6240\u4ee5\u516c\u53f8\u5e94\u8be5\u662f\u201cWinterstein & Co., Ernst\u201d\uff0c\u800clocation\u662f\u201cZUERICH\u201d\u3002\\n\\n\u63a5\u4e0b\u6765\u662fb_id\uff0c\u5728\u53f3\u4e0a\u89d2\uff0c\u4ee5B.\u5f00\u5934\u3002\u8fd9\u91cc\u663e\u793a\u7684\u662f\u201cB.51.322.GB.452.\u201d\uff0c\u6240\u4ee5\u76f4\u63a5\u63d0\u53d6\u8fd9\u4e2a\u5b57\u7b26\u4e32\u3002\\n\\n\u65e5\u671f\u90e8\u5206\uff0c\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u76d6\u7ae0\u7684\u65e5\u671f\u3002\u5728\u5361\u7247\u4e2d\u95f4\u90e8\u5206\u6709\u201cAmendment 21, Dezember 1941.\u201d\u548c\u201cgestrichen: Amendment 13, 23.11.1945.\u201d\u3002\u8fd9\u4e24\u4e2a\u65e5\u671f\u5206\u522b\u662f1941\u5e7412\u6708\u548c1945\u5e7411\u670823\u65e5\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662fYYYY-MM-DD\u683c\u5f0f\uff0c\u6240\u4ee5\u9700\u8981\u8f6c\u6362\u3002\u7b2c\u4e00\u4e2a\u65e5\u671f\u662f1941-12\uff0c\u4f46\u5177\u4f53\u65e5\u671f\u4e0d\u660e\u786e\uff0c\u53ef\u80fd\u53ea\u6709\u6708\u4efd\uff0c\u6240\u4ee5\u53ef\u80fd\u65e0\u6cd5\u8f6c\u6362\u4e3a\u5b8c\u6574\u65e5\u671f\u3002\u7b2c\u4e8c\u4e2a\u662f23.11.1945\uff0c\u53731945-11-23\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u63d0\u53d6\u6240\u6709\u65e5\u671f\uff0c\u4f46\u6839\u636e\u6307\u793a\uff0c\u53ef\u80fd\u53ea\u53d6\u4e00\u4e2a\uff1f\u6216\u8005\u9700\u8981\u5408\u5e76\uff1f\u4e0d\u8fc7\u7528\u6237\u8bf4\u201c\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\u201d\uff0c\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5217\u51fa\u6765\u3002\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u53ef\u80fd\u53ea\u80fd\u653e\u4e00\u4e2a\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u591a\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u4f46\u539f\u6307\u793a\u53ef\u80fd\u5e0c\u671b\u5982\u679c\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u5904\u7406\u3002\u4e0d\u8fc7\u539f\u793a\u4f8b\u4e2d\u7684date\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u9009\u62e9\u5176\u4e2d\u4e00\u4e2a\uff0c\u6216\u8005\u5408\u5e76\u3002\u4f46\u6839\u636e\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\uff0c\u53ef\u80fd\u6709\u4e24\u4e2a\u65e5\u671f\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u4e24\u4e2a\u90fd\u63d0\u53d6\u51fa\u6765\uff0c\u4f46\u6839\u636e\u683c\u5f0f\uff0cdate\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u6216\u8005\u53ea\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u4e0d\u8fc7\u4ed4\u7ec6\u770b\u7528\u6237\u6307\u4ee4\uff0c\u53ef\u80fddate\u5b57\u6bb5\u662f\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\uff0c\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5217\u51fa\u6765\uff0c\u4f46JSON\u7ed3\u6784\u4e2ddate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u53ef\u80fd\u65e0\u6cd5\u5904\u7406\u591a\u4e2a\u3002\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u53ef\u80fd\u53ea\u53d6\u4e00\u4e2a\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5728date\u5b57\u6bb5\u91cc\uff0c\u7528\u67d0\u79cd\u5206\u9694\u7b26\uff0c\u4f46\u539f\u6307\u793a\u6ca1\u6709\u8bf4\u660e\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\\n\\n\u4e0d\u8fc7\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\uff0cdate\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u4f46\u56fe\u7247\u4e2d\u6709\u4e24\u4e2a\u65e5\u671f\uff1a1941\u5e7412\u6708\u548c1945\u5e7411\u670823\u65e5\u3002\u4f46\u6839\u636e\u5361\u7247\u5185\u5bb9\uff0c\u53ef\u80fd\u8fd9\u4e24\u4e2a\u65e5\u671f\u90fd\u662f\u76f8\u5173\u7684\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u662f\u5217\u5165\u9ed1\u540d\u5355\u7684\u65e5\u671f\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5220\u9664\u7684\u65e5\u671f\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u4e24\u4e2a\u90fd\u63d0\u53d6\u51fa\u6765\uff0c\u4f46\u6839\u636e\u683c\u5f0f\uff0c\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u53ea\u53d6\u6700\u65b0\u7684\u65e5\u671f\uff1f\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5728date\u5b57\u6bb5\u91cc\uff0c\u7528\u5206\u53f7\u5206\u9694\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684JSON schema\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u4f8b\u5982\uff1a\u201c1941-12; 1945-11-23\u201d\u3002\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b26\u5408\u8981\u6c42\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u53ea\u5e0c\u671b\u63d0\u53d6\u660e\u786e\u7684\u65e5\u671f\uff0c\u6bd4\u5982\u7b2c\u4e8c\u4e2a\u65e5\u671f\u662f\u5b8c\u6574\u7684\uff0c\u800c\u7b2c\u4e00\u4e2a\u53ea\u6709\u6708\u4efd\u3002\u6240\u4ee5\u53ef\u80fd\u7b2c\u4e8c\u4e2a\u65e5\u671f\u66f4\u7b26\u5408YYYY-MM-DD\u683c\u5f0f\uff0c\u800c\u7b2c\u4e00\u4e2a\u65e0\u6cd5\u8f6c\u6362\u3002\u56e0\u6b64\uff0c\u53ef\u80fd\u5c06\u7b2c\u4e8c\u4e2a\u65e5\u671f\u4f5c\u4e3adate\u7684\u503c\uff0c\u53731945-11-23\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u90fd\u63d0\u53d6\uff0c\u4f46\u9700\u8981\u770b\u7528\u6237\u7684\u5177\u4f53\u6307\u793a\u3002\u7528\u6237\u8bf4\u201c\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\u201d\uff0c\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5217\u51fa\u6765\uff0c\u4f46JSON\u7ed3\u6784\u4e2d\u7684date\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u4f8b\u5982\uff0c\u7528\u5206\u53f7\u5206\u9694\u3002\u4f46\u539f\u793a\u4f8b\u4e2d\u6ca1\u6709\u8fd9\u79cd\u60c5\u51b5\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u6839\u636e\u60c5\u51b5\u5904\u7406\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u63d0\u53d6\uff0c\u4f46\u8f6c\u6362\u4e3a\u6b63\u786e\u7684\u683c\u5f0f\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u65e5\u671f\u662fDezember 1941\uff0c\u53731941-12\uff0c\u4f46\u7f3a\u5c11\u65e5\u671f\uff0c\u6240\u4ee5\u53ef\u80fd\u65e0\u6cd5\u8f6c\u6362\u4e3a\u5b8c\u6574\u