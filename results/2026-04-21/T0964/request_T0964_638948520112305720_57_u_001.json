4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\u6210\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\u3002\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u6bd4\u5982\u201c1943-10, 1945-02\u201d\u6216\u8005\u5206\u522b\u5217\u51fa\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u5355\u72ec\u5904\u7406\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\u6210\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u4f8b\u5982\u201c1943-10, 1945-02\u201d\u3002\u4e0d\u8fc7\u539f\u5361\u7247\u4e2d\u7684\u65e5\u671f\u662f\u5206\u5f00\u7684\uff0c\u53ef\u80fd\u9700\u8981\u5206\u522b\u5904\u7406\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u6ce8\u610f\uff0c\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\\n\\n\u4e0d\u8fc7\uff0c\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u4e2d\uff0cdate\u5b57\u6bb5\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u800cinformation\u5b57\u6bb5\u662f\u4e00\u4e2a\u6570\u7ec4\uff0c\u6bcf\u4e2a\u6761\u76ee\u662f\u6587\u672c\u5757\u3002\u6240\u4ee5\u53ef\u80fd\u65e5\u671f\u5e94\u8be5\u653e\u5728date\u5b57\u6bb5\uff0c\u800c\u5176\u4ed6\u4fe1\u606f\u653e\u5728information\u4e2d\u3002\u4f8b\u5982\uff0c\u539f\u5361\u7247\u4e2d\u7684\u201cBritische schwarze Liste, Amendment 14, Oktober 1943.\u201d\u548c\u201cgestrichen: Amendment 3, Februar 1945.\u201d\u5e94\u8be5\u4f5c\u4e3ainformation\u4e2d\u7684\u4e24\u4e2a\u6761\u76ee\uff0c\u800cdate\u5b57\u6bb5\u53ef\u80fd\u7559\u7a7a\uff0c\u6216\u8005\u63d0\u53d6\u5176\u4e2d\u7684\u65e5\u671f\u3002\u4f46\u7528\u6237\u8bf4\u660e\u4e2d\u63d0\u5230\u201c\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\u201d\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u8fd9\u4e24\u4e2a\u65e5\u671f\u63d0\u53d6\u5230date\u5b57\u6bb5\u3002\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u4f8b\u5982\u201c1943-10, 1945-02\u201d\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u786e\u8ba4\uff0c\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0c\u53ef\u80fd\u5e94\u8be5\u5c06\u65e5\u671f\u5408\u5e76\u6210\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u4f8b\u5982\u201c1943-10, 1945-02\u201d\u3002\\n\\n\u4e0d\u8fc7\uff0c\u539f\u5361\u7247\u4e2d\u7684\u65e5\u671f\u662f\u5206\u5f00\u7684\uff0c\u53ef\u80fd\u5e94\u8be5\u5206\u522b\u5904\u7406\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u65e5\u671f\u662f1943\u5e7410\u6708\uff0c\u7b2c\u4e8c\u4e2a\u662f1945\u5e742\u6708\u3002\u6240\u4ee5date\u5b57\u6bb5\u53ef\u80fd\u9700\u8981\u5305\u542b\u8fd9\u4e24\u4e2a\u65e5\u671f\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u5b83\u4eec\u5408\u5e76\uff0c\u4f8b\u5982\u201c1943-10, 1945-02\u201d\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u6309\u7167\u7528\u6237\u7684\u8981\u6c42\uff0c\u5c06\u65e5\u671f\u63d0\u53d6\u4e3a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u5408\u5e76\u4e24\u4e2a\u65e5\u671f\u3002\\n\\n\u63a5\u4e0b\u6765\u662finformation\u90e8\u5206\uff0c\u9700\u8981\u63d0\u53d6\u4e3b\u6587\u672c\u5757\u3002\u539f\u5361\u7247\u4e2d\u7684\u4e3b\u6587\u672c\u662f\uff1a\\n\\n\u201cBritische schwarze Liste,\\nAmendment 14, Oktober 1943.\\n\\ngestrichen:\\nAmendment 3, Februar 1945.\u201d\\n\\n\u6240\u4ee5\u5e94\u8be5\u5206\u6210\u4e24\u4e2a\u6761\u76ee\uff0c\u6bcf\u4e2a\u6761\u76ee\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u4fdd\u6301\u6362\u884c\u7b26\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u6761\u76ee\u662f\u201cBritische schwarze Liste,\\\\nAmendment 14, Oktober 1943.\u201d\uff0c\u7b2c\u4e8c\u4e2a\u6761\u76ee\u662f\u201cgestrichen:\\\\nAmendment 3, Februar 1945.\u201d\u3002\u6216\u8005\u53ef\u80fd\u6bcf\u4e2a\u6bb5\u843d\u4f5c\u4e3a\u4e00\u4e2a\u6761\u76ee\uff0c\u6240\u4ee5\u53ef\u80fd\u5206\u6210\u4e24\u4e2a\u6761\u76ee\uff0c\u6bcf\u4e2a\u5305\u542b\u6362\u884c\u7b26\u3002\\n\\n\u73b0\u5728\u9700\u8981\u68c0\u67e5\u6bcf\u4e2a\u5b57\u6bb5\u662f\u5426\u7b26\u5408\u8981\u6c42\uff1a\\n\\n\u516c\u53f8\uff1aTabador S.A.\uff0c\u6b63\u786e\u3002\\n\\n\u5730\u70b9\uff1aGen\u00e8ve\uff0c\u6b63\u786e\u3002\\n\\nb_id\uff1aB.51.322.GB.1155.\uff0c\u6b63\u786e\u3002\\n\\n\u65e5\u671f\uff1a\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\u6210\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u4f8b\u5982\u201c1943-10, 1945-02\u201d\uff0c\u4f46\u539f\u5361\u7247\u4e2d\u7684\u65e5\u671f\u662f\u201cOktober 1943\u201d\u548c\u201cFebruar 1945\u201d\uff0c\u6240\u4ee5\u8f6c\u6362\u4e3aYYYY-MM-DD\u7684\u8bdd\uff0c\u5e94\u8be5\u662f1943-10\u548c1945-02\uff0c\u6240\u4ee5\u5408\u5e76\u4e3a\u201c1943-10, 1945-02\u201d\u3002\\n\\n\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u6309\u7167\u7528\u6237\u7684\u8981\u6c42\uff0c\u5c06\u65e5\u671f\u63d0\u53d6\u4e3a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u5408\u5e76\u4e24\u4e2a\u65e5\u671f\u3002\\n\\n\u4e0d\u8fc7\uff0c\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u4e2d\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u800cinformation\u5b57\u6bb5\u662f\u6570\u7ec4\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u5c06\u65e5\u671f\u653e\u5728date\u5b57\u6bb5\uff0c\u800c\u5176\u4ed6\u4fe1\u606f\u653e\u5728information\u4e2d\u3002\u4f8b\u5982\uff0c\u539f\u5361\u7247\u4e2d\u7684\u201cBritische schwarze Liste, Amendment 14, Oktober 1943.\u201d\u548c\u201cgestrichen: Amendment 3, Februar 1945.\u201d\u5e94\u8be5\u4f5c\u4e3ainformation\u4e2d\u7684\u4e24\u4e2a\u6761\u76ee\uff0c\u800cdate\u5b57\u6bb5\u53ef\u80fd\u7559\u7a7a\uff0c\u6216\u8005\u63d0\u53d6\u5176\u4e2d\u7684\u65e5\u671f\u3002\u4f46\u7528\u6237\u8bf4\u660e\u4e2d\u63d0\u5230\u201c\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\u201d\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u8fd9\u4e24\u4e2a\u65e5\u671f\u63d0\u53d6\u5230date\u5b57\u6bb5\u3002\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u4f8b\u5982\u201c1943-10, 1945-02\u201d\u3002\\n\\n\u4e0d\u8fc7\uff0c\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u6309\u7167\u7528\u6237\u7684\u8981\u6c42\uff0c\u5c06\u65e5\u671f\u63d0\u53d6\u4e3a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u5408\u5e76\u4e24\u4e2a\u65e5\u671f\u3002\\n\\n\u73b0\u5728\uff0c\u6211\u9700\u8981\u786e\u8ba4\u6bcf\u4e2a\u5b57\u6bb5\u7684\u6b63\u786e\u6027\uff1a\\n\\n\u516c\u53f8\uff1aTabador S.A.\uff0c\u6b63\u786e\u3002\\n\\n\u5730\u70b9\uff1aGen\u00e8ve\uff0c\u6b63\u786e\u3002\\n\\nb_id\uff1aB.51.322.GB.1155.\uff0c\u6b63\u786e\u3002\\n\\n\u65e5\u671f\uff1a1943-10\u548c1945-02\uff0c\u5408\u5e76\u4e3a\u201c1943-10, 1945-02\u201d\u3002\\n\\ninformation\uff1a\u4e24\u4e2a\u6761\u76ee\uff0c\u6bcf\u4e2a\u5305\u542b\u6362\u884c\u7b26\u3002\\n\\n\u6240\u4ee5\u6700\u7ec8\u7684JSON\u5e94\u8be5\u662f\uff1a\\n\\n{\\n  \\\"company\\\": {\\\"transcription\\\": \\\"Tabador S.A.\\\"},\\n  \\\"location\\\": {\\\"transcription\\\": \\\"Gen\u00e8ve\\\"},\\n  \\\"b_id\\\": {\\\"transcription\\\": \\\"B.51.322.GB.1155.\\\"},\\n  \\\"date\\\": \\\"1943-10, 1945-02\\\",\\n  \\\"information\\\": [\\n    {\\\"transcription\\\": \\\"Britische schwarze Liste,\\\\nAmendment 14, Oktober 1943.\\\"},\\n    {\\\"transcription\\\": \\\"gestrichen:\\\\nAmendment 3, Februar 1945.\\\"}\\n  ]\\n}\\n\\n\u4f46\u9700\u8981\u68c0\u67e5\u662f\u5426\u7b26\u5408\u7528\u6237\u63d0\u4f9b\u7684JSON Schema\u3002\u7528\u6237\u63d0\u4f9b\u7684Schema\u4e2d\uff0cdate\u5b57\u6bb5\u53ef\u4ee5\u662f\u5b57\u7b26\u4e32\u6216null\uff0c\u800cinformation\u662f\u6570\u7ec4\uff0c\u6bcf\u4e2a\u5143\u7d20\u662fEntry\u5bf9\u8c61\uff0c\u5305\u542btranscription\u5b57\u6bb5\u3002\u6240\u4ee5\u8fd9\u4e2a\u7ed3\u6784\u662f\u6b63\u786e\u7684\u3002\\n\\n\u4e0d\u8fc7\uff0c\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u65e5\u671f\u5206\u5f00\u5904\u7406\uff0c\u4f46\u6839\u636eSchema\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u5408\u5e76\u662f\u6b63\u786e\u7684\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636eSchema\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u5408\u5e76\u662f\u6b63\u786e\u7684\u3002\\n\\n\u53e6\u5916\uff0c\u68c0\u67e5\u662f\u5426\u6709\u5176\u4ed6\u65e5\u671f\uff0c\u6bd4\u5982\u5361\u7247\u5e95\u90e8\u7684\u201c74463\u201d\uff0c\u4f46\u90a3\u662f\u7f16\u53f7\uff0c\u4e0d\u662f\u65e5\u671f\uff0c\u6240\u4ee5\u4e0d\u9700\u8981\u63d0\u53d6\u3002\\n\\n\u6240\u4ee5\u6700\u7ec8\u7684JSON\u5e94\u8be5\u5982\u4e0a\u8ff0\u6240\u793a\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u5f20\u7d22\u5f15\u5361\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u6240\u9700\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u6211\u9700\u8981\u4ed4\u7ec6\u5206\u6790\u56fe\u7247\u4e2d\u7684\u5404\u4e2a\u90e8\u5206\uff0c\u6309\u7167\u7528\u6237\u7684\u8981\u6c42\u9010\u4e00\u63d0\u53d6\u6570\u636e\u3002\\n\\n\u9996\u5148\u770b\u516c\u53f8\u90e8\u5206\uff0c\u7528\u6237\u8bf4\u516c\u53f8\u540d\u901a\u5e38\u5728\u5de6\u4e0a\u89d2\u3002\u56fe\u7247\u5de6\u4e0a\u89d2\u663e\u793a\u7684\u662f\u201cTabador S.A., Gen\u00e8ve.\u201d\uff0c\u8fd9\u91cc\u516c\u53f8\u540d\u5e94\u8be5\u662f\u201cTabador S.A.\u201d\uff0c\u800c\u201cGen\u00e8ve\u201d\u662f\u5730\u70b9\uff0c\u6240\u4ee5\u516c\u53f8\u5b57\u6bb5\u5e94\u8be5\u662f\u201cTabador S.A.\u201d\uff0c\u4e0d\u5305\u62ec\u540e\u9762\u7684\u5730\u70b9\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u5730\u70b9\uff0c\u4e5f\u5c31\u662f\u57ce\u5e02\u6216\u57ce\u9547\uff0c\u901a\u5e38\u5728\u516c\u53f8\u540d\u79f0\u540e\u9762\u3002\u8fd9\u91cc\u201cGen\u00e8ve\u201d\u5c31\u662f\u65e5\u5185\u74e6\uff0c\u6240\u4ee5location\u7684\u8f6c\u5f55\u5e94\u8be5\u662f\u201cGen\u00e8ve\u201d\u3002\\n\\n\u7136\u540e\u662fb_id\uff0c\u901a\u5e38\u5728\u53f3\u4e0a\u89d2\uff0c\u4ee5\u201cB.\u201d\u5f00\u5934\u3002\u56fe\u7247\u53f3\u4e0a\u89d2\u6709\u201cB.51.322.GB.1155.\u201d\uff0c\u6240\u4ee5b_id\u5c31\u662f\u8fd9\u4e2a\u5b57\u7b26\u4e32\uff0c\u5305\u62ec\u540e\u9762\u7684\u70b9\u3002\\n\\n\u65e5\u671f\u90e8\u5206\uff0c\u7528\u6237\u8981\u6c42\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\uff0c\u683c\u5f0f\u4e3aYYYY-MM-DD\u3002\u56fe\u7247\u4e2d\u6709\u4e24\u4e2a\u65e5\u671f\uff1a\u4e00\u4e2a\u662f\u201cOktober 1943\u201d\uff0c\u53e6\u4e00\u4e2a\u662f\u201cFebruar 1945\u201d\u3002\u4e0d\u8fc7\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u8fd9\u4e24\u4e2a\u65e5\u671f\u90fd\u63d0\u53d6\u51fa\u6765\uff0c\u4f46\u6839\u636e\u683c\u5f0f\u8981\u6c42\uff0c\u53ef\u80fd\u9700\u8981\u5206\u5f00\u5904\u7406\u3002\u4e0d\u8fc7\u7528\u6237\u8bf4\u660e\u4e2d\u65e5\u671f\u5b57\u6bb5\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u6216\u8005\u9009\u62e9\u5176\u4e2d\u4e00\u4e2a\u3002\u4f46\u539f\u5361\u7247\u4e2d\u7684\u65e5\u671f\u662f\u5206\u5f00\u7684\uff0c\u53ef\u80fd\u5e94\u8be5\u5206\u522b\u8bb0\u5f55\u3002\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684JSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u6216\u8005\u53ef\u80fd\u53ea\u63d0\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u4f46\u4ed4\u7ec6\u770b\u7528\u6237\u7684\u8981\u6c42\uff0c\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6240\u6709\u7684\u65e5\u671f\u90fd\u5217\u51fa\u6765\uff0c\u4f46\u6839\u636e\u793a\u4f8b\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\u6210\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\u3002\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u6bd4\u5982\u201c1943-10, 1945-02\u201d\u6216\u8005\u5206\u522b\u5217\u51fa\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u5355\u72ec\u5904\u7406\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\u6210\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u4f8b\u5982\u201c1943-10, 1945-02\u201d\u3002\u4e0d\u8fc7\u539f\u5361\u7247\u4e2d\u7684\u65e5\u671f\u662f\u5206\u5f00\u7684\uff0c\u53ef\u80fd\u9700\u8981\u5206\u522b\u5904\u7406\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u6ce8\u610f\uff0c\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\\n\\n\u4e0d\u8fc7\uff0c\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u4e2d\uff0cdate\u5b57\u6bb5\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u800cinformation\u5b57\u6bb5\u662f\u4e00\u4e2a\u6570\u7ec4\uff0c\u6bcf\u4e2a\u6761\u76ee\u662f\u6587\u672c\u5757\u3002\u6240\u4ee5\u53ef\u80fd\u65e5\u671f\u5e94\u8be5\u653e\u5728date\u5b57\u6bb5\uff0c\u800c\u5176\u4ed6\u4fe1\u606f\u653e\u5728information\u4e2d\u3002\u4f8b\u5982\uff0c\u539f\u5361\u7247\u4e2d\u7684\u201cBritische schwarze Liste, Amendment 14, Oktober 1943.\u201d\u548c\u201cgestrichen: Amendment 3, Februar 1945.\u201d\u5e94\u8be5\u4f5c\u4e3ainformation\u4e2d\u7684\u4e24\u4e2a\u6761\u76ee\uff0c\u800cdate\u5b57\u6bb5\u53ef\u80fd\u7559\u7a7a\uff0c\u6216\u8005\u63d0\u53d6\u5176\u4e2d\u7684\u65e5\u671f\u3002\u4f46\u7528\u6237\u8bf4\u660e\u4e2d\u63d0\u5230\u201c\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\u201d\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u8fd9\u4e24\u4e2a\u65e5\u671f\u63d0\u53d6\u5230date\u5b57\u6bb5\u3002\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\uff0c\u4f8b\u5982\u201c1943-10, 1945-02\u201d\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u786e\u8ba4\uff0c\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0c\u53ef\u80fd\u5e94\u8be5\u5c06\u65e5\u671f\u5408\u5e76\u6210\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u4f8b\u5982\u201c1943-10, 1945-02\u201d\u3002\\n\\n\u4e0d\u8fc7\uff0c\u539f\u5361\u7247\u4e2d\u7684\u65e5\u671f\u662f\u5206\u5f00\u7684\uff0c\u53ef\u80fd\u5e94\u8be5\u5206\u522b\u5904\u7406\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u65e5\u671f\u662f1943\u5e7410\u6708\uff0c\u7b2c\u4e8c\u4e2a\u662f1945\u5e742\u6708\u3002\u6240\u4ee5date\u5b57\u6bb5\u53ef\u80fd\u9700\u8981\u5305\u542b\u8fd9\u4e24\u4e2a\u65e5\u671f\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u5b83\u4eec\u5408\u5e76\uff0c\u4f8b\u5982\u201c1943-10, 1945-02\u201d\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u4e0d\u540c\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636e\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u6309\u7167\u752