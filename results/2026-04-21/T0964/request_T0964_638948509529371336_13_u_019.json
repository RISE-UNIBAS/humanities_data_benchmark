    "raw_response": "{\"id\":\"gen-1776772945-6S3zjeycf8CVhBgC7684\",\"choices\":[{\"finish_reason\":\"stop\",\"index\":0,\"logprobs\":null,\"message\":{\"content\":\"{\\n  \\\"company\\\": {\\\"transcription\\\": \\\"Egli Jean Martin\\\"},\\n  \\\"location\\\": {\\\"transcription\\\": \\\"Wil\\\"},\\n  \\\"b_id\\\": {\\\"transcription\\\": \\\"B.51.322.GB.590.\\\"},\\n  \\\"date\\\": \\\"\\\",\\n  \\\"information\\\": [\\n    {\\\"transcription\\\": \\\"Britische schwarze Liste\\\\n8.Amendment vom 23. Mai 1942.\\\"},\\n    {\\\"transcription\\\": \\\"gestrichen:\\\\nAmendment 13, 23.11.1945.\\\"}\\n  ]\\n}\",\"refusal\":null,\"role\":\"assistant\",\"annotations\":null,\"audio\":null,\"function_call\":null,\"tool_calls\":null,\"parsed\":{\"company\":{\"transcription\":\"Egli Jean Martin\"},\"location\":{\"transcription\":\"Wil\"},\"b_id\":{\"transcription\":\"B.51.322.GB.590.\"},\"date\":\"\",\"information\":[{\"transcription\":\"Britische schwarze Liste\\n8.Amendment vom 23. Mai 1942.\"},{\"transcription\":\"gestrichen:\\nAmendment 13, 23.11.1945.\"}]},\"reasoning\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u8fd9\u4e2a\u7528\u6237\u63d0\u4f9b\u7684\u7d22\u5f15\u5361\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u6240\u9700\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u6211\u5f97\u4ed4\u7ec6\u770b\u770b\u7528\u6237\u7684\u8981\u6c42\u3002\u7528\u6237\u5e0c\u671b\u6211\u4f5c\u4e3a\u6863\u6848\u7ba1\u7406\u5458\uff0c\u4ece\u56fe\u7247\u4e2d\u63d0\u53d6\u516c\u53f8\u3001\u5730\u70b9\u3001BID\u3001\u65e5\u671f\u548c\u4fe1\u606f\u5b57\u6bb5\uff0c\u5e76\u4ee5\u7279\u5b9a\u7684JSON\u683c\u5f0f\u8fd4\u56de\u3002\\n\\n\u9996\u5148\uff0c\u6211\u9700\u8981\u786e\u5b9a\u6bcf\u4e2a\u5b57\u6bb5\u7684\u4f4d\u7f6e\u3002\u6839\u636e\u63cf\u8ff0\uff0c\u516c\u53f8\u540d\u79f0\u901a\u5e38\u5728\u5de6\u4e0a\u89d2\uff0c\u4e0d\u5305\u62ec\u5730\u70b9\u3002\u56fe\u7247\u5de6\u4e0a\u89d2\u663e\u793a\u7684\u662f\u201cEgli Jean Martin, Wil\u201d\uff0c\u8fd9\u91cc\u53ef\u80fd\u516c\u53f8\u540d\u662f\u201cEgli Jean Martin\u201d\uff0c\u800c\u5730\u70b9\u662f\u201cWil\u201d\u3002\u4e0d\u8fc7\u8981\u6ce8\u610f\uff0c\u6709\u65f6\u5019\u5730\u540d\u53ef\u80fd\u548c\u516c\u53f8\u540d\u8fde\u5728\u4e00\u8d77\uff0c\u9700\u8981\u5206\u5f00\u5904\u7406\u3002\u6240\u4ee5\u516c\u53f8\u5b57\u6bb5\u5e94\u8be5\u662f\u201cEgli Jean Martin\u201d\uff0c\u5730\u70b9\u662f\u201cWil\u201d\u3002\\n\\n\u63a5\u4e0b\u6765\u662fBID\uff0c\u901a\u5e38\u5728\u53f3\u4e0a\u89d2\uff0c\u4ee5\u201cB.\u201d\u5f00\u5934\u3002\u56fe\u7247\u53f3\u4e0a\u89d2\u6709\u201cB.51.322.GB.590.\u201d\uff0c\u6240\u4ee5BID\u5e94\u8be5\u662f\u8fd9\u4e2a\u5b57\u7b26\u4e32\uff0c\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u5305\u542b\u672b\u5c3e\u7684\u70b9\u3002\u7528\u6237\u793a\u4f8b\u4e2d\u7684BID\u53ef\u80fd\u4fdd\u7559\u539f\u6837\uff0c\u6240\u4ee5\u76f4\u63a5\u8f6c\u5f55\u4e3a\u201cB.51.322.GB.590.\u201d\u3002\\n\\n\u65e5\u671f\u90e8\u5206\u9700\u8981\u67e5\u627e\u662f\u5426\u6709\u76d6\u7ae0\u7684\u65e5\u671f\uff0c\u683c\u5f0f\u4e3aYYYY-MM-DD\u3002\u56fe\u7247\u4e2d\u6709\u4e24\u4e2a\u65e5\u671f\uff1a\u4e00\u4e2a\u662f\u201c23. Mai 1942\u201d\uff0c\u53e6\u4e00\u4e2a\u662f\u201c23.11.1945\u201d\u3002\u9700\u8981\u8f6c\u6362\u4e3aYYYY-MM-DD\u683c\u5f0f\u3002\u7b2c\u4e00\u4e2a\u65e5\u671f\u662f1942\u5e745\u670823\u65e5\uff0c\u6240\u4ee5\u662f1942-05-23\u3002\u7b2c\u4e8c\u4e2a\u662f1945\u5e7411\u670823\u65e5\uff0c\u53731945-11-23\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662f\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u90fd\u5217\u51fa\u6765\u3002\u4e0d\u8fc7\u7528\u6237\u793a\u4f8b\u4e2d\u7684date\u5b57\u6bb5\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u53ef\u80fd\u53ea\u80fd\u6709\u4e00\u4e2a\u65e5\u671f\uff1f\u6216\u8005\u53ef\u80fd\u9700\u8981\u5408\u5e76\uff1f\u9700\u8981\u770b\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\u3002\u7528\u6237\u7ed9\u7684\u4f8b\u5b50\u4e2ddate\u662f\u7a7a\u5b57\u7b26\u4e32\uff0c\u4f46\u5982\u679c\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5305\u62ec\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u53ef\u80fd\u53ea\u80fd\u6709\u4e00\u4e2a\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u9009\u62e9\u4e3b\u8981\u7684\u65e5\u671f\uff0c\u6216\u8005\u6839\u636e\u60c5\u51b5\u5904\u7406\u3002\u4e0d\u8fc7\u539f\u5361\u7247\u4e0a\u53ef\u80fd\u6709\u4e24\u4e2a\u4e0d\u540c\u7684\u65e5\u671f\uff0c\u4e00\u4e2a\u662f\u4fee\u6b63\u6848\u65e5\u671f\uff0c\u53e6\u4e00\u4e2a\u662f\u5220\u9664\u7684\u65e5\u671f\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662f\u201c\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\u201d\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u90fd\u5305\u542b\u3002\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\uff0c\u6216\u8005\u53ea\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\u4f8b\u5982\uff0c\u539f\u5361\u7247\u4e2d\u7684\u201c8.Amendment vom 23. Mai 1942.\u201d\u548c\u201cgestrichen: Amendment 13, 23.11.1945.\u201d\uff0c\u8fd9\u4e24\u4e2a\u65e5\u671f\u90fd\u662f\u76f8\u5173\u7684\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u8fd9\u4e24\u4e2a\u65e5\u671f\u90fd\u4f5c\u4e3a\u4fe1\u606f\u7684\u4e00\u90e8\u5206\uff0c\u800cdate\u5b57\u6bb5\u53ef\u80fd\u7559\u7a7a\uff0c\u6216\u8005\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u6307\u4ee4\uff0cdate\u5b57\u6bb5\u662f\u201c\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\u201d\uff0c\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5217\u51fa\u6765\uff0c\u4f46JSON\u7ed3\u6784\u4e2d\u7684date\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\uff0c\u6216\u8005\u53ea\u53d6\u7b2c\u4e00\u4e2a\u3002\u4f46\u6839\u636e\u793a\u4f8b\u8f93\u51fa\uff0c\u53ef\u80fddate\u5b57\u6bb5\u7559\u7a7a\uff0c\u800c\u5c06\u65e5\u671f\u653e\u5728\u4fe1\u606f\u4e2d\u3002\u4f8b\u5982\uff0c\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u4e2d\uff0cdate\u662f\u7a7a\u5b57\u7b26\u4e32\uff0c\u800c\u4fe1\u606f\u4e2d\u5305\u542b\u65e5\u671f\u3002\u6240\u4ee5\u53ef\u80fd\u6b63\u786e\u7684\u505a\u6cd5\u662f\u5c06\u65e5\u671f\u653e\u5728\u4fe1\u606f\u5b57\u6bb5\u91cc\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff0c\u9664\u975e\u6709\u660e\u786e\u7684\u76d6\u7ae0\u65e5\u671f\u3002\u4f46\u9700\u8981\u786e\u8ba4\u56fe\u7247\u4e2d\u7684\u65e5\u671f\u662f\u5426\u662f\u76d6\u7ae0\u7684\u3002\u4f8b\u5982\uff0c\u539f\u5361\u7247\u4e2d\u7684\u65e5\u671f\u53ef\u80fd\u662f\u6253\u5370\u7684\uff0c\u800c\u4e0d\u662f\u76d6\u7ae0\u7684\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5224\u65ad\u3002\u4f8b\u5982\uff0c\u201c23. Mai 1942\u201d\u548c\u201c23.11.1945\u201d\u662f\u5426\u662f\u76d6\u7ae0\u7684\u3002\u5982\u679c\u7528\u6237\u8bf4\u660e\u4e2d\u63d0\u5230\u201cstamped dates\u201d\uff0c\u90a3\u4e48\u9700\u8981\u786e\u8ba4\u8fd9\u4e9b\u65e5\u671f\u662f\u5426\u662f\u76d6\u7ae0\u7684\u3002\u5047\u8bbe\u8fd9\u4e9b\u662f\u6253\u5370\u7684\uff0c\u90a3\u4e48date\u5b57\u6bb5\u53ef\u80fd\u7559\u7a7a\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0c\u53ef\u80fddate\u5b57\u6bb5\u9700\u8981\u586b\u5199\u3002\u4f8b\u5982\uff0c\u7528\u6237\u793a\u4f8b\u4e2d\u7684date\u662f\u7a7a\u5b57\u7b26\u4e32\uff0c\u4f46\u5728\u8fd9\u4e2a\u6848\u4f8b\u4e2d\uff0c\u53ef\u80fd\u6709\u4e24\u4e2a\u65e5\u671f\uff0c\u4f46\u9700\u8981\u8f6c\u6362\u4e3aYYYY-MM-DD\u683c\u5f0f\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u65e5\u671f\u662f1942-05-23\uff0c\u7b2c\u4e8c\u4e2a\u662f1945-11-23\u3002\u4f46JSON\u4e2d\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u5305\u542b\uff0c\u4f46\u5982\u4f55\u683c\u5f0f\u5316\uff1f\u6216\u8005\u53ef\u80fd\u53ea\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u66f4\u591a\u7684\u4e0a\u4e0b\u6587\uff0c\u4f46\u6839\u636e\u7528\u6237\u6307\u4ee4\uff0c\u5982\u679c\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5217\u5728\u4fe1\u606f\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u53ef\u80fd\u7559\u7a7a\u3002\u6216\u8005\uff0c\u5982\u679c\u5b58\u5728\u591a\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u9009\u62e9\u5176\u4e2d\u4e00\u4e2a\u4f5c\u4e3adate\u5b57\u6bb5\u3002\u4f8b\u5982\uff0c\u53ef\u80fd\u4e3b\u8981\u7684\u65e5\u671f\u662f1942-05-23\uff0c\u800c\u53e6\u4e00\u4e2a\u662f\u5220\u9664\u7684\u65e5\u671f\uff0c\u653e\u5728\u4fe1\u606f\u91cc\u3002\u4f46\u9700\u8981\u4ed4\u7ec6\u5206\u6790\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u4fe1\u606f\u5b57\u6bb5\uff0c\u9700\u8981\u63d0\u53d6\u4e3b\u4f53\u90e8\u5206\u7684\u6587\u672c\u5757\uff0c\u6bcf\u4e2a\u5757\u4f5c\u4e3a\u5355\u72ec\u7684\u5b57\u7b26\u4e32\uff0c\u4fdd\u7559\u6362\u884c\u3002\u539f\u5361\u7247\u4e2d\u7684\u4e3b\u4f53\u90e8\u5206\u6709\uff1a\\n\\nBritische schwarze Liste\\n8.Amendment vom 23. Mai 1942.\\n\\ngestrichen:\\nAmendment 13, 23.11.1945.\\n\\n\u6240\u4ee5\u4fe1\u606f\u90e8\u5206\u5e94\u8be5\u5206\u6210\u4e24\u4e2a\u5757\uff1a\u7b2c\u4e00\u4e2a\u662f\u201cBritische schwarze Liste\\\\n8.Amendment vom 23. Mai 1942.\u201d\uff0c\u7b2c\u4e8c\u4e2a\u662f\u201cgestrichen:\\\\nAmendment 13, 23.11.1945.\u201d\u3002\u6216\u8005\u53ef\u80fd\u6bcf\u4e2a\u6bb5\u843d\u4f5c\u4e3a\u4e00\u4e2a\u5757\u3002\u9700\u8981\u770b\u539f\u6587\u7684\u6362\u884c\u60c5\u51b5\u3002\u539f\u5361\u7247\u4e2d\uff0c\u201cBritische schwarze Liste\u201d\u662f\u4e00\u884c\uff0c\u4e0b\u4e00\u884c\u662f\u201c8.Amendment...\u201d\uff0c\u7136\u540e\u7a7a\u884c\uff0c\u63a5\u7740\u201cgestrichen:\u201d\u548c\u4e0b\u4e00\u884c\u3002\u6240\u4ee5\u53ef\u80fd\u5206\u6210\u4e24\u4e2a\u4fe1\u606f\u5757\uff1a\u7b2c\u4e00\u4e2a\u5757\u662f\u524d\u4e24\u884c\uff0c\u7b2c\u4e8c\u4e2a\u5757\u662f\u540e\u4e24\u884c\u3002\u6216\u8005\u6bcf\u4e2a\u6bb5\u843d\u4f5c\u4e3a\u4e00\u4e2a\u5757\u3002\u4f8b\u5982\uff1a\\n\\n\u4fe1\u606f\u6570\u7ec4\u4e2d\u7684\u7b2c\u4e00\u4e2a\u5143\u7d20\u662f\u201cBritische schwarze Liste\\\\n8.Amendment vom 23. Mai 1942.\u201d\uff0c\u7b2c\u4e8c\u4e2a\u5143\u7d20\u662f\u201cgestrichen:\\\\nAmendment 13, 23.11.1945.\u201d\u3002\u8fd9\u6837\u5904\u7406\u3002\\n\\n\u73b0\u5728\uff0c\u7efc\u5408\u6240\u6709\u4fe1\u606f\uff1a\\n\\n\u516c\u53f8\uff1aEgli Jean Martin\uff08\u6392\u9664\u5730\u70b9Wil\uff09\\n\u5730\u70b9\uff1aWil\\nBID\uff1aB.51.322.GB.590.\\n\u65e5\u671f\uff1a\u53ef\u80fd\u6709\u4e24\u4e2a\u65e5\u671f\uff0c\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0cdate\u5b57\u6bb5\u53ef\u80fd\u7559\u7a7a\uff0c\u6216\u8005\u9700\u8981\u8f6c\u6362\u3002\u4f8b\u5982\uff0c\u5982\u679c\u7528\u6237\u8981\u6c42\u7684\u662f\u76d6\u7ae0\u7684\u65e5\u671f\uff0c\u800c\u8fd9\u91cc\u7684\u65e5\u671f\u662f\u6253\u5370\u7684\uff0c\u90a3\u4e48date\u5b57\u6bb5\u7559\u7a7a\u3002\u4f46\u9700\u8981\u786e\u8ba4\u3002\u5047\u8bbe\u8fd9\u4e9b\u65e5\u671f\u662f\u6253\u5370\u7684\uff0c\u4e0d\u662f\u76d6\u7ae0\u7684\uff0c\u6240\u4ee5date\u5b57\u6bb5\u7559\u7a7a\u3002\u6216\u8005\uff0c\u5982\u679c\u7528\u6237\u8ba4\u4e3a\u8fd9\u4e9b\u662f\u6709\u6548\u7684\u65e5\u671f\uff0c\u90a3\u4e48\u9700\u8981\u8f6c\u6362\u3002\u4f8b\u5982\uff0c\u5c06\u201c23. Mai 1942\u201d\u8f6c\u6362\u4e3a1942-05-23\uff0c\u800c\u201c23.11.1945\u201d\u8f6c\u6362\u4e3a1945-11-23\u3002\u4f46JSON\u4e2d\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u9009\u62e9\u5176\u4e2d\u4e00\u4e2a\uff0c\u6216\u8005\u5408\u5e76\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0cdate\u5b57\u6bb5\u662f\u7a7a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u8fd9\u91cc\u5e94\u8be5\u7559\u7a7a\uff0c\u800c\u5c06\u65e5\u671f\u653e\u5728\u4fe1\u606f\u4e2d\u3002\u56e0\u6b64\uff0cdate\u5b57\u6bb5\u7559\u7a7a\u3002\\n\\n\u4fe1\u606f\u90e8\u5206\u5219\u5305\u62ec\u4e24\u4e2a\u5757\uff0c\u6bcf\u4e2a\u5757\u5305\u542b\u76f8\u5e94\u7684\u6587\u672c\uff0c\u4fdd\u7559\u6362\u884c\u3002\\n\\n\u73b0\u5728\uff0c\u68c0\u67e5JSON\u7ed3\u6784\u662f\u5426\u7b26\u5408\u8981\u6c42\u3002\u516c\u53f8\u3001\u5730\u70b9\u3001BID\u90fd\u662f\u5bf9\u8c61\uff0c\u5305\u542btranscription\u5b57\u6bb5\u3002date\u662f\u5b57\u7b26\u4e32\uff0c\u4fe1\u606f\u662f\u6570\u7ec4\uff0c\u6bcf\u4e2a\u5143\u7d20\u662f\u5bf9\u8c61\uff0c\u5305\u542btranscription\u3002\\n\\n\u6240\u4ee5\u6700\u7ec8\u7684JSON\u5e94\u8be5\u662f\uff1a\\n\\n{\\n  \\\"company\\\": {\\\"transcription\\\": \\\"Egli Jean Martin\\\"},\\n  \\\"location\\\": {\\\"transcription\\\": \\\"Wil\\\"},\\n  \\\"b_id\\\": {\\\"transcription\\\": \\\"B.51.322.GB.590.\\\"},\\n  \\\"date\\\": \\\"\\\",\\n  \\\"information\\\": [\\n    {\\\"transcription\\\": \\\"Britische schwarze Liste\\\\n8.Amendment vom 23. Mai 1942.\\\"},\\n    {\\\"transcription\\\": \\\"gestrichen:\\\\nAmendment 13, 23.11.1945.\\\"}\\n  ]\\n}\\n\\n\u9700\u8981\u786e\u8ba4\u662f\u5426\u6240\u6709\u5b57\u6bb5\u90fd\u6b63\u786e\u3002\u4f8b\u5982\uff0c\u516c\u53f8\u540d\u662f\u5426\u6b63\u786e\u6392\u9664\u5730\u70b9\uff0cBID\u662f\u5426\u6b63\u786e\u8f6c\u5f55\uff0c\u4fe1\u606f\u5757\u662f\u5426\u6b63\u786e\u5206\u5272\uff0c\u65e5\u671f\u662f\u5426\u5904\u7406\u6b63\u786e\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u8fd9\u4e2a\u7528\u6237\u63d0\u4f9b\u7684\u7d22\u5f15\u5361\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u6240\u9700\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u6211\u5f97\u4ed4\u7ec6\u770b\u770b\u7528\u6237\u7684\u8981\u6c42\u3002\u7528\u6237\u5e0c\u671b\u6211\u4f5c\u4e3a\u6863\u6848\u7ba1\u7406\u5458\uff0c\u4ece\u56fe\u7247\u4e2d\u63d0\u53d6\u516c\u53f8\u3001\u5730\u70b9\u3001BID\u3001\u65e5\u671f\u548c\u4fe1\u606f\u5b57\u6bb5\uff0c\u5e76\u4ee5\u7279\u5b9a\u7684JSON\u683c\u5f0f\u8fd4\u56de\u3002\\n\\n\u9996\u5148\uff0c\u6211\u9700\u8981\u786e\u5b9a\u6bcf\u4e2a\u5b57\u6bb5\u7684\u4f4d\u7f6e\u3002\u6839\u636e\u63cf\u8ff0\uff0c\u516c\u53f8\u540d\u79f0\u901a\u5e38\u5728\u5de6\u4e0a\u89d2\uff0c\u4e0d\u5305\u62ec\u5730\u70b9\u3002\u56fe\u7247\u5de6\u4e0a\u89d2\u663e\u793a\u7684\u662f\u201cEgli Jean Martin, Wil\u201d\uff0c\u8fd9\u91cc\u53ef\u80fd\u516c\u53f8\u540d\u662f\u201cEgli Jean Martin\u201d\uff0c\u800c\u5730\u70b9\u662f\u201cWil\u201d\u3002\u4e0d\u8fc7\u8981\u6ce8\u610f\uff0c\u6709\u65f6\u5019\u5730\u540d\u53ef\u80fd\u548c\u516c\u53f8\u540d\u8fde\u5728\u4e00\u8d77\uff0c\u9700\u8981\u5206\u5f00\u5904\u7406\u3002\u6240\u4ee5\u516c\u53f8\u5b57\u6bb5\u5e94\u8be5\u662f\u201cEgli Jean Martin\u201d\uff0c\u5730\u70b9\u662f\u201cWil\u201d\u3002\\n\\n\u63a5\u4e0b\u6765\u662fBID\uff0c\u901a\u5e38\u5728\u53f3\u4e0a\u89d2\uff0c\u4ee5\u201cB.\u201d\u5f00\u5934\u3002\u56fe\u7247\u53f3\u4e0a\u89d2\u6709\u201cB.51.322.GB.590.\u201d\uff0c\u6240\u4ee5BID\u5e94\u8be5\u662f\u8fd9\u4e2a\u5b57\u7b26\u4e32\uff0c\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u5305\u542b\u672b\u5c3e\u7684\u70b9\u3002\u7528\u6237\u793a\u4f8b\u4e2d\u7684BID\u53ef\u80fd\u4fdd\u7559\u539f\u6837\uff0c\u6240\u4ee5\u76f4\u63a5\u8f6c\u5f55\u4e3a\u201cB.51.322.GB.590.\u201d\u3002\\n\\n\u65e5\u671f\u90e8\u5206\u9700\u8981\u67e5\u627e\u662f\u5426\u6709\u76d6\u7ae0\u7684\u65e5\u671f\uff0c\u683c\u5f0f\u4e3aYYYY-MM-DD\u3002\u56fe\u7247\u4e2d\u6709\u4e24\u4e2a\u65e5\u671f\uff1a\u4e00\u4e2a\u662f\u201c23. Mai 1942\u201d\uff0c\u53e6\u4e00\u4e2a\u662f\u201c23.11.1945\u201d\u3002\u9700\u8981\u8f6c\u6362\u4e3aYYYY-MM-DD\u683c\u5f0f\u3002\u7b2c\u4e00\u4e2a\u65e5\u671f\u662f1942\u5e745\u670823\u65e5\uff0c\u6240\u4ee5\u662f1942-05-23\u3002\u7b2c\u4e8c\u4e2a\u662f1945\u5e7411\u670823\u65e5\uff0c\u53731945-11-23\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662f\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u90fd\u5217\u51fa\u6765\u3002\u4e0d\u8fc7\u7528\u6237\u793a\u4f8b\u4e2d\u7684date\u5b57\u6bb5\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u53ef\u80fd\u53ea\u80fd\u6709\u4e00\u4e2a\u65e5\u671f\uff1f\u6216\u8005\u53ef\u80fd\u9700\u8981\u5408\u5e76\uff1f\u9700\u8981\u770b\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\u3002\u7528\u6237\u7ed9\u7684\u4f8b\u5b50\u4e2ddate\u662f\u7a7a\u5b57\u7b26\u4e32\uff0c\u4f46\u5982\u679c\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5305\u62ec\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u53ef\u80fd\u53ea\u80fd\u6709\u4e00\u4e2a\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u9009\u62e9\u4e3b\u8981\u7684\u65e5\u671f\uff0c\u6216\u8005\u6839\u636e\u60c5\u51b5\u5904\u7406\u3002\u4e0d\u8fc7\u539f\u5361\u7247\u4e0a\u53ef\u80fd\u6709\u4e24\u4e2a\u4e0d\u540c\u7684\u65e5\u671f\uff0c\u4e00\u4e2a\u662f\u4fee\u6b63\u6848\u65e5\u671f\uff0c\u53e6\u4e00\u4e2a\u662f\u5220\u9664\u7684\u65e5\u671f\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662f\u201c\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\u201d\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u90fd\u5305\u542b\u3002\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\uff0c\u6216\u8005\u53ea\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\u4f8b\u5982\uff0c\u539f\u5361\u7247\u4e2d\u7684\u201c8.Amendment vom 23. Mai 1942.\u201d\u548c\u201cgestrichen: Amendment 13, 23.11.1945.\u201d\uff0c\u8fd9\u4e24\u4e2a\u65e5\u671f\u90fd\u662f\u76f8\u5173\u7684\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u8fd9\u4e24\u4e2a\u65e5\u671f\u90fd\u4f5c\u4e3a\u4fe1\u606f\u7684\u4e00\u90e8\u5206\uff0c\u800cdate\u5b57\u6bb5\u53ef\u80fd\u7559\u7a7a\uff0c\u6216\u8005\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u6307\u4ee4\uff0cdate\u5b57\u6bb5\u662f\u201c\u4efb\u4f55\u76d6\u7ae0\u7684\u65e5\u671f\u201d\uff0c\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5217\u51fa\u6765\uff0c\u4f46JSON\u7ed3\u6784\u4e2d\u7684date\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5408\u5e76\uff0c\u6216\u8005\u53ea\u53d6\u7b2c\u4e00\u4e2a\u3002\u4f46\u6839\u636e\u793a\u4f8b\u8f93\u51fa\uff0c\u53ef\u80fddate\u5b57\u6bb5\u7559\u7a7a\uff0c\u800c\u5c06\u65e5\u671f\u653e\u5728\u4fe1\u606f\u4e2d\u3002\u4f8b\u5982\uff0c\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u4e2d\uff0cdate\u662f\u7a7a\u5b57\u7b26\u4e32\uff0c\u800c\u4fe1\u606f\u4e2d\u5305\u542b\u65e5\u671f\u3002\u6240\u4ee5\u53ef\u80fd\u6b63\u786e\u7684\u505a\u6cd5\u662f\u5c06\u65e5\u671f\u653e\u5728\u4fe1\u606f\u5b57\u6bb5\u91cc\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff0c\u9664\u975e\u6709\u660e\u786e\u7684\u76d6\u7ae0\u65e5\u671f\u3002\u4f46\u9700\u8981\u786e\u8ba4\u56fe\u7247\u4e2d\u7684\u65e5\u671f\u662f\u5426\u662f\u76d6\u7ae0\u7684\u3002\u4f8b\u5982\uff0c\u539f\u5361\u7247\u4e2d\u7684\u65e5\u671f\u53ef\u80fd\u662f\u6253\u5370\u7684\uff0c\u800c\u4e0d\u662f\u76d6\u7ae0\u7684\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5224\u65ad\u3002\u4f8b\u5982\uff0c\u201c23. Mai 1942\u201d\u548c\u201c23.11.1945\u201d\u662f\u5426\u662f\u76d6\u7ae0\u7684\u3002\u5982\u679c\u7528\u6237\u8bf4\u660e\u4e2d\u63d0\u5230\u201cstamped dates\u201d\uff0c\u90a3\u4e48\u9700\u8981\u786e\u8ba4\u8fd9\u4e9b\u65e5\u671f\u662f\u5426\u662f\u76d6\u7ae0\u7684\u3002\u5047\u8bbe\u8fd9\u4e9b\u662f\u6253\u5370\u7684\uff0c\u90a3\u4e48date\u5b57\u6bb5\u53ef\u80fd\u7559\u7a7a\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0c\u53ef\u80fddate\u5b57\u6bb5\u9700\u8981\u586b\u5199\u3002\u4f8b\u5982\uff0c\u7528\u6237\u793a\u4f8b\u4e2d\u7684date\u662f\u7a7a\u5b57\u7b26\u4e32\uff0c\u4f46\u5728\u8fd9\u4e2a\u6848\u4f8b\u4e2d\uff0c\u53ef\u80fd\u6709\u4e24\u4e2a\u65e5\u671f\uff0c\u4f46\u9700\u8981\u8f6c\u6362\u4e3aYYYY-MM-DD\u683c\u5f0f\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u65e5\u671f\u662f1942-05-23\uff0c\u7b2c\u4e8c\u4e2a\u662f1945-11-23\u3002\u4f46JSON\u4e2d\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u5305\u542b\uff0c\u4f46\u5982\u4f55\u683c\u5f0f\u5316\uff1f\u6216\u8005\u53ef\u80fd\u53ea\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u66f4\u591a\u7684\u4e0a\u4e0b\u6587\uff0c\u4f46\u6839\u636e\u7528\u6237\u6307\u4ee4\uff0c\u5982\u679c\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u90fd\u5217\u5728\u4fe1\u606f\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u53ef\u80fd\u7559\u7a7a\u3002\u6216\u8005\uff0c\u5982\u679c\u5b58\u5728\u591a\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u9009\u62e9\u5176\u4e2d\u4e00\u4e2a\u4f5c\u4e3adate\u5b57\u6bb5\u3002\u4f8b\u5982\uff0c\u53ef\u80fd\u4e3b\u8981\u7684\u65e5\u671f\u662f1942-05-23\uff0c\u800c\u53e6\u4e00\u4e2a\u662f\u5220\u9664\u7684\u65e5\u671f\uff0c\u653e\u5728\u4fe1\u606f\u91cc\u3002\u4f46\u9700\u8981\u4ed4\u7ec6\u5206\u6790\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u4fe1\u606f\u5b57\u6bb5\uff0c\u9700\u8981\u63d0\u53d6\u4e3b\u4f53\u90e8\u5206\u7684\u6587\u672c\u5757\uff0c\u6bcf\u4e2a\u5757\u4f5c\u4e3a\u5355\u72ec\u7684\u5b57\u7b26\u4e32\uff0c\u4fdd\u7559\u6362\u884c\u3002\u539f\u5361\u7247\u4e2d\u7684\u4e3b\u4f53\u90e8\u5206\u6709\uff1a\\n\\nBritische schwarze Liste\\n8.Amendment vom 23. Mai 1942.\\n\\ngestrichen:\\nAmendment 13, 23.11.1945.\\n\\n\u6240\u4ee5\u4fe1\u606f\u90e8\u5206\u5e94\u8be5\u5206\u6210\u4e24\u4e2a\u5757\uff1a\u7b2c\u4e00\u4e2a\u662f\u201cBritische schwarze Liste\\\\n8.Amendment vom 23. Mai 1942.\u201d\uff0c\u7b2c\u4e8c\u4e2a\u662f\u201cgestrichen:\\\\nAmendment 13, 23.11.1945.\u201d\u3002\u6216\u8005\u53ef\u80fd\u6bcf\u4e2a\u6bb5\u843d\u4f5c\u4e3a\u4e00\u4e2a\u5757\u3002\u9700\u8981\u770b\u539f\u6587\u7684\u6362\u884c\u60c5\u51b5\u3002\u539f\u5361\u7247\u4e2d\uff0c\u201cBritische schwarze Liste\u201d\u662f\u4e00\u884c\uff0c\u4e0b\u4e00\u884c\u662f\u201c8.Amendment...\u201d\uff0c\u7136\u540e\u7a7a\u884c\uff0c\u63a5\u7740\u201cgestrichen:\u201d\u548c\u4e0b\u4e00\u884c\u3002\u6240\u4ee5\u53ef\u80fd\u5206\u6210\u4e24\u4e2a\u4fe1\u606f\u5757\uff1a\u7b2c\u4e00\u4e2a\u5757\u662f\u524d\u4e24\u884c\uff0c\u7b2c\u4e8c\u4e2a\u5757\u662f\u540e\u4e24\u884c\u3002\u6216\u8005\u6bcf\u4e2a\u6bb5\u843d\u4f5c\u4e3a\u4e00\u4e2a\u5757\u3002\u4f8b\u5982\uff1a\\n\\n\u4fe1\u606f\u6570\u7ec4\u4e2d\u7684\u7b2c\u4e00\u4e2a\u5143\u7d20\u662f\u201cBritische schwarze Liste\\\\n8.Amendment vom 23. Mai 1942.\u201d\uff0c\u7b2c\u4e8c\u4e2a\u5143\u7d20\u662f\u201cgestrichen:\\\\nAmendment 13, 23.11.1945.\u201d\u3002\u8fd9\u6837\u5904\u7406\u3002\\n\\n\u73b0\u5728\uff0c\u7efc\u5408\u6240\u6709\u4fe1\u606f\uff1a\\n\\n\u516c\u53f8\uff1aEgli Jean Martin\uff08\u6392\u9664\u5730\u70b9Wil\uff09\\n\u5730\u70b9\uff1aWil\\nBID\uff1aB.51.322.GB.590.\\n\u65e5\u671f\uff1a\u53ef\u80fd\u6709\u4e24\u4e2a\u65e5\u671f\uff0c\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0cdate\u5b57\u6bb5\u53ef\u80fd\u7559\u7a7a\uff0c\u6216\u8005\u9700\u8981\u8f6c\u6362\u3002\u4f8b\u5982\uff0c\u5982\u679c\u7528\u6237\u8981\u6c42\u7684\u662f\u76d6\u7ae0\u7684\u65e5\u671f\uff0c\u800c\u8fd9\u91cc\u7684\u65e5\u671f\u662f\u6253\u5370\u7684\uff0c\u90a3\u4e48date\u5b57\u6bb5\u7559\u7a7a\u3002\u4f46\u9700\u8981\u786e\u8ba4\u3002\u5047\u8bbe\u8fd9\u4e9b\u65e5\u671f\u662f\u6253\u5370\u7684\uff0c\u4e0d\u662f\u76d6\u7ae0\u7684\uff0c\u6240\u4ee5date\u5b57\u6bb5\u7559\u7a7a\u3002\u6216\u8005\uff0c\u5982\u679c\u7528\u6237\u8ba4\u4e3a\u8fd9\u4e9b\u662f\u6709\u6548\u7684\u65e5\u671f\uff0c\u90a3\u4e48\u9700\u8981\u8f6c\u6362\u3002\u4f8b\u5982\uff0c\u5c06\u201c23. Mai 1942\u201d\u8f6c\u6362\u4e3a1942-05-23\uff0c\u800c\u201c23.11.1945\u201d\u8f6c\u6362\u4e3a1945-11-23\u3002\u4f46JSON\u4e2d\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u9009\u62e9\u5176\u4e2d\u4e00\u4e2a\uff0c\u6216\u8005\u5408\u5e76\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0cdate\u5b57\u6bb5\u662f\u7a7a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u8fd9\u91cc\u5e94\u8be5\u7559\u7a7a\uff0c\u800c\u5c06\u65e5\u671f\u653e\u5728\u4fe1\u606f\u4e2d\u3002\u56e0\u6b64\uff0cdate\u5b57\u6bb5\u7559\u7a7a\u3002\\n\\n\u4fe1\u606f\u90e8\u5206\u5219\u5305\u62ec\u4e24\u4e2a\u5757\uff0c\u6bcf\u4e2a\u5757\u5305\u542b\u76f8\u5e94\u7684\u6587\u672c\uff0c\u4fdd\u7559\u6362\u884c\u3002\\n