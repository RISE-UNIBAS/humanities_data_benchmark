u63a5\u4e0b\u6765\u662f\u201clocation\u201d\uff0c\u7d27\u8ddf\u5728\u516c\u53f8\u540d\u540e\u9762\uff0c\u8fd9\u91cc\u5c31\u662f\u201cLUGANO\u201d\u3002\u9700\u8981\u786e\u8ba4\u662f\u5426\u8fd8\u6709\u5176\u4ed6\u4f4d\u7f6e\u4fe1\u606f\uff0c\u4f46\u770b\u8d77\u6765\u8fd9\u91cc\u53ea\u6709LUGANO\uff0c\u6240\u4ee5\u6ca1\u95ee\u9898\u3002\\n\\n\u7136\u540e\u662f\u201cb_id\u201d\uff0c\u5728\u53f3\u4e0a\u89d2\uff0c\u4ee5\u201cB.\u201d\u5f00\u5934\u3002\u56fe\u7247\u53f3\u4e0a\u89d2\u663e\u793a\u7684\u662f\u201cB.51.322.GB.397.\u201d\uff0c\u6240\u4ee5\u76f4\u63a5\u63d0\u53d6\u8fd9\u4e2a\u4f5c\u4e3ab_id\u3002\\n\\n\u65e5\u671f\u90e8\u5206\u9700\u8981\u67e5\u627e\u662f\u5426\u6709 stamped dates\u3002\u56fe\u7247\u4e2d\u6709\u4e24\u4e2a\u65e5\u671f\uff1a2.10.1941\u548c23.11.1945\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662fYYYY-MM-DD\u683c\u5f0f\u3002\u8fd9\u91cc\u9700\u8981\u6ce8\u610f\u65e5\u671f\u7684\u683c\u5f0f\u8f6c\u6362\u30022.10.1941\u5e94\u8be5\u662f1941-10-02\uff0c\u800c23.11.1945\u5219\u662f1945-11-23\u3002\u4e0d\u8fc7\u7528\u6237\u53ef\u80fd\u53ea\u9700\u8981\u5b58\u5728\u7684\u4e00\u4e2a\u65e5\u671f\uff0c\u6216\u8005\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u591a\u4e2a\u65e5\u671f\u3002\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u53ef\u80fd\u53ea\u9700\u8981\u7b2c\u4e00\u4e2a\u51fa\u73b0\u7684\u65e5\u671f\uff0c\u6216\u8005\u6240\u6709\u65e5\u671f\uff1f\u4f46\u6839\u636e\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u4f8b\u5b50\uff0c\u53ef\u80fd\u53ea\u9700\u8981\u5b58\u5728\u7684\u4e00\u4e2a\u65e5\u671f\uff0c\u6216\u8005\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u5168\u90e8\u5217\u51fa\uff1f\u4e0d\u8fc7\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u4f8b\u5b50\u662f\u201cdate\u201d\u5b57\u6bb5\uff0c\u53ef\u80fd\u53ea\u53d6\u4e00\u4e2a\u3002\u4f46\u4ed4\u7ec6\u770b\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u8bf4\u660e\uff1a\u201cAny stamped dates on the card in YYYY-MM-DD format. If no date is present, use an empty string.\u201d \u6240\u4ee5\u5982\u679c\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u5168\u90e8\u5217\u51fa\uff0c\u4f46\u6839\u636eJSON\u683c\u5f0f\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u4e0d\u662f\u6570\u7ec4\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u53d6\u7b2c\u4e00\u4e2a\uff1f\u6216\u8005\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u591a\u4e2a\u65e5\u671f\u5408\u5e76\uff1f\u4f46\u6839\u636e\u793a\u4f8b\u4e2d\u7684JSON\u7ed3\u6784\uff0cdate\u662f\u5b57\u7b26\u4e32\u7c7b\u578b\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u4f46\u56fe\u7247\u4e2d\u6709\u4e24\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u5176\u4ed6\u6307\u793a\u3002\u4f8b\u5982\uff0c\u5361\u7247\u4e2d\u7684\u201cgestrichen\u201d\u90e8\u5206\u53ef\u80fd\u8868\u793a\u5220\u9664\uff0c\u6240\u4ee5\u53ef\u80fd\u7b2c\u4e8c\u4e2a\u65e5\u671f\u662f\u5220\u9664\u7684\u65e5\u671f\uff0c\u800c\u7b2c\u4e00\u4e2a\u662f\u539f\u59cb\u65e5\u671f\u3002\u4f46\u7528\u6237\u53ef\u80fd\u53ea\u9700\u8981\u5b58\u5728\u7684\u65e5\u671f\uff0c\u4e0d\u7ba1\u662f\u5426\u88ab\u5220\u9664\u3002\u6216\u8005\u53ef\u80fd\u4e24\u4e2a\u65e5\u671f\u90fd\u9700\u8981\u8003\u8651\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\uff0c\u53ef\u80fd\u53ea\u53d6\u7b2c\u4e00\u4e2a\u51fa\u73b0\u7684\u65e5\u671f\uff0c\u6216\u8005\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\\n\\n\u4e0d\u8fc7\uff0c\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\u4e2d\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u53d6\u4e00\u4e2a\u65e5\u671f\u3002\u4f46\u56fe\u7247\u4e2d\u6709\u4e24\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u54ea\u4e2a\u662f\u4e3b\u8981\u7684\u3002\u4f8b\u5982\uff0c\u5361\u7247\u4e2d\u7684\u201cAmendment 16, vom 2.10.1941.\u201d\u548c\u201cgestrichen: Amendment 13, 23.11.1945.\u201d\u3002\u53ef\u80fd\u7b2c\u4e00\u4e2a\u65e5\u671f\u662f\u539f\u59cb\u6761\u76ee\u65e5\u671f\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5220\u9664\u65e5\u671f\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u8bb0\u5f55\u6240\u6709\u5b58\u5728\u7684\u65e5\u671f\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u9009\u62e9\u5176\u4e2d\u4e00\u4e2a\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u5305\u542b\u5728information\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff1f\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u8bf4\u201cAny stamped dates on the card in YYYY-MM-DD format\u201d\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u8f6c\u6362\u4e3aYYYY-MM-DD\u683c\u5f0f\uff0c\u5e76\u653e\u5728date\u5b57\u6bb5\u4e2d\uff0c\u4f46JSON\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u4e0d\u662f\u6570\u7ec4\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u653e\u4e00\u4e2a\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5224\u65ad\uff0c\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\u6210\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u7528\u5206\u53f7\u5206\u9694\uff1f\u4f46\u6839\u636e\u793a\u4f8b\u4e2d\u7684JSON\u7ed3\u6784\uff0cdate\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u53d6\u7b2c\u4e00\u4e2a\u51fa\u73b0\u7684\u65e5\u671f\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5728information\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff1f\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u4f8b\u5b50\u663e\u793adate\u5b57\u6bb5\u662f\u5b58\u5728\u7684\uff0c\u6bd4\u5982\u793a\u4f8b\u4e2d\u7684date\u662f\u201c1941-10-02\u201d\u6216\u8005\u7c7b\u4f3c\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\u4e2d\u7684date\u5b57\u6bb5\u662f\u5426\u5141\u8bb8\u6709\u591a\u4e2a\u65e5\u671f\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684JSON Schema\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\u7c7b\u578b\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u6709\u4e00\u4e2a\u65e5\u671f\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u9009\u62e9\u7b2c\u4e00\u4e2a\u51fa\u73b0\u7684\u65e5\u671f\uff0c\u53731941-10-02\uff0c\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u5305\u542b\u5728information\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff1f\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u8bf4\u660e\u662f\u201cAny stamped dates on the card in YYYY-MM-DD format\u201d\uff0c\u6240\u4ee5\u5982\u679c\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u5c06\u5b83\u4eec\u90fd\u8f6c\u6362\u4e3a\u6b63\u786e\u7684\u683c\u5f0f\uff0c\u5e76\u653e\u5728date\u5b57\u6bb5\u4e2d\uff0c\u4f46JSON\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u7528\u5206\u53f7\u5206\u9694\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u6ca1\u6709\u8fd9\u79cd\u60c5\u51b5\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\u4e2d\u7684date\u5b57\u6bb5\u662f\u5426\u5141\u8bb8\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u4f46\u6839\u636e\u63d0\u4f9b\u7684JSON Schema\uff0cdate\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u6709\u4e00\u4e2a\u65e5\u671f\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5224\u65ad\u54ea\u4e2a\u65e5\u671f\u662f\u4e3b\u8981\u7684\u3002\u4f8b\u5982\uff0c\u5361\u7247\u4e2d\u7684\u201cAmendment 16, vom 2.10.1941.\u201d\u53ef\u80fd\u8868\u793a\u8be5\u6761\u76ee\u57281941\u5e7410\u67082\u65e5\u88ab\u6dfb\u52a0\uff0c\u800c\u201cgestrichen\u201d\u90e8\u5206\u8868\u793a\u57281945\u5e7411\u670823\u65e5\u88ab\u5220\u9664\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u8bb0\u5f55\u5b58\u5728\u7684\u65e5\u671f\uff0c\u4e0d\u7ba1\u662f\u5426\u88ab\u5220\u9664\u3002\u6240\u4ee5\u53ef\u80fd\u4e24\u4e2a\u65e5\u671f\u90fd\u9700\u8981\u8003\u8651\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0c\u53ea\u80fd\u9009\u4e00\u4e2a\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5728information\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff1f\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u4f8b\u5b50\u663e\u793adate\u5b57\u6bb5\u662f\u5b58\u5728\u7684\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u8f6c\u6362\u4e3aYYYY-MM-DD\u683c\u5f0f\uff0c\u5e76\u653e\u5728date\u5b57\u6bb5\u4e2d\uff0c\u7528\u5206\u53f7\u5206\u9694\u3002\u4f46\u6839\u636eJSON Schema\uff0cdate\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u5141\u8bb8\u8fd9\u6837\u505a\u3002\u4f8b\u5982\uff0c\u201c1941-10-02; 1945-11-23\u201d\u3002\u4f46\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\u4e2d\u7684date\u5b57\u6bb5\u662f\u5355\u4e2a\u65e5\u671f\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u786e\u8ba4\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u53ea\u53d6\u7b2c\u4e00\u4e2a\u51fa\u73b0\u7684\u65e5\u671f\uff0c\u53731941-10-02\u3002\u8fd9\u65f6\u5019\u9700\u8981\u51b3\u5b9a\u5982\u4f55\u5904\u7406\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u201cinformation\u201d\u5b57\u6bb5\uff0c\u9700\u8981\u63d0\u53d6\u4e3b\u6587\u672c\u5757\uff0c\u6bcf\u4e2a\u5757\u4f5c\u4e3a\u5355\u72ec\u7684\u5b57\u7b26\u4e32\uff0c\u4fdd\u6301\u6362\u884c\u3002\u56fe\u7247\u4e2d\u7684\u4e3b\u6587\u672c\u90e8\u5206\u6709\uff1a\\n\\n\u201cBritische Schwarze Liste\\nAmendment 16, vom 2.10.1941.\\n\\ngestrichen:\\nAmendment 13, 23.11.1945.\u201d\\n\\n\u6240\u4ee5\u9700\u8981\u5c06\u8fd9\u4e24\u90e8\u5206\u4f5c\u4e3a\u4e24\u4e2a\u6761\u76ee\uff0c\u6bcf\u4e2a\u6761\u76ee\u5305\u542b\u6362\u884c\u7b26\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u6761\u76ee\u662f\u201cBritische Schwarze Liste\\\\nAmendment 16, vom 2.10.1941.\u201d\uff0c\u7b2c\u4e8c\u4e2a\u662f\u201cgestrichen:\\\\nAmendment 13, 23.11.1945.\u201d\u3002\u6ce8\u610f\u4e2d\u95f4\u7684\u7a7a\u884c\u662f\u5426\u9700\u8981\u4fdd\u7559\uff0c\u4f46\u6839\u636e\u7528\u6237\u6307\u4ee4\uff0c\u6bcf\u4e2a\u6587\u672c\u5757\u4f5c\u4e3a\u5355\u72ec\u7684\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u5c06\u6bcf\u4e2a\u6bb5\u843d\u5206\u5f00\u3002\u4f46\u539f\u5361\u7247\u4e2d\u7684\u6587\u672c\u53ef\u80fd\u5206\u4e3a\u4e24\u4e2a\u90e8\u5206\uff0c\u4e2d\u95f4\u6709\u7a7a\u884c\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u6bcf\u4e2a\u90e8\u5206\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u90e8\u5206\u662f\u201cBritische Schwarze Liste\\\\nAmendment 16, vom 2.10.1941.\u201d\uff0c\u7b2c\u4e8c\u4e2a\u90e8\u5206\u662f\u201cgestrichen:\\\\nAmendment 13, 23.11.1945.\u201d\u3002\u8fd9\u6837\u5728information\u6570\u7ec4\u4e2d\u4f1a\u6709\u4e24\u4e2a\u5bf9\u8c61\uff0c\u6bcf\u4e2a\u5305\u542b\u5bf9\u5e94\u7684\u6587\u672c\u3002\\n\\n\u73b0\u5728\u9700\u8981\u68c0\u67e5\u6bcf\u4e2a\u5b57\u6bb5\u662f\u5426\u7b26\u5408\u8981\u6c42\uff1a\\n\\ncompany: Sacom (S.a.) \u2192 \u6b63\u786e\uff0c\u6392\u9664\u4f4d\u7f6eLUGANO\u3002\\n\\nlocation: LUGANO \u2192 \u6b63\u786e\u3002\\n\\nb_id: B.51.322.GB.397. \u2192 \u6b63\u786e\uff0c\u6ce8\u610f\u672b\u5c3e\u7684\u53e5\u70b9\u662f\u5426\u9700\u8981\u4fdd\u7559\uff0c\u6839\u636e\u56fe\u7247\uff0c\u5e94\u8be5\u4fdd\u7559\u3002\\n\\ndate: \u9700\u8981\u8f6c\u6362\u4e3aYYYY-MM-DD\u3002\u539f\u65e5\u671f\u662f2.10.1941\u548c23.11.1945\u3002\u8f6c\u6362\u4e3a1941-10-02\u548c1945-11-23\u3002\u4f46\u6839\u636eJSON\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u53ef\u80fd\u9700\u8981\u9009\u62e9\u5176\u4e2d\u4e00\u4e2a\uff0c\u6216\u8005\u5408\u5e76\u3002\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u4f8b\u5b50\u53ef\u80fd\u53ea\u53d6\u7b2c\u4e00\u4e2a\uff0c\u6216\u8005\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u5168\u90e8\u5217\u51fa\u3002\u4f46\u6839\u636eJSON Schema\uff0cdate\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u6709\u4e00\u4e2a\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u770b\u7528\u6237\u793a\u4f8b\u4e2d\u7684\u5904\u7406\u65b9\u5f0f\u3002\u4f8b\u5982\uff0c\u5982\u679c\u539f\u5361\u7247\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u662f\u5426\u90fd\u653e\u5165date\u5b57\u6bb5\uff1f\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\u4e2d\u7684date\u5b57\u6bb5\u662f\u5355\u4e2a\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u9009\u62e9\u7b2c\u4e00\u4e2a\u51fa\u73b0\u7684\u65e5\u671f\uff0c\u53731941-10-02\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5165information\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff1f\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u8bf4\u660e\u662f\u201cAny stamped dates on the card in YYYY-MM-DD format\u201d\uff0c\u6240\u4ee5\u5e94\u8be5\u5c06\u5b58\u5728\u7684\u65e5\u671f\u90fd\u8f6c\u6362\u5e76\u653e\u5165date\u5b57\u6bb5\u3002\u4f46JSON\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u7528\u5206\u53f7\u5206\u9694\u3002\u4f8b\u5982\uff0c\u201c1941-10-02; 1945-11-23\u201d\u3002\u4f46\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u4e2d\u6ca1\u6709\u8fd9\u79cd\u60c5\u51b5\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u786e\u8ba4\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5728information\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff1f\u4f46\u6839\u636e\u7528\u6237\u6307\u4ee4\uff0cdate\u5b57\u6bb5\u5e94\u8be5\u5305\u542b\u4efb\u4f55\u5b58\u5728\u7684\u65e5\u671f\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u8f6c\u6362\u5e76\u653e\u5165date\u5b57\u6bb5\uff0c\u7528\u5206\u53f7\u5206\u9694\u3002\u4f46\u6839\u636eJSON Schema\uff0cdate\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u5141\u8bb8\u8fd9\u6837\u505a\u3002\u4f8b\u5982\uff1a\\n\\n\\\"date\\\": \\\"1941-10-02; 1945-11-23\\\"\\n\\n\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b26\u5408\u7528\u6237\u7684\u8981\u6c42\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u53ea\u53d6\u7b2c\u4e00\u4e2a\u65e5\u671f\uff0c\u56e0\u4e3a\u7b2c\u4e8c\u4e2a\u662f\u5220\u9664\u7684\u65e5\u671f\uff0c\u53ef\u80fd\u4e0d\u7b97\u4f5c\u6709\u6548\u65e5\u671f\u3002\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u6ca1\u6709\u8bf4\u660e\u8fd9\u4e00\u70b9\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5305\u62ec\u6240\u6709\u5b58\u5728\u7684\u65e5\u671f\u3002\u56e0\u6b64\uff0c\u6b63\u786e\u7684\u505a\u6cd5\u662f\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u8f6c\u6362\u4e3aYYYY-MM-DD\u683c\u5f0f\uff0c\u5e76\u7528\u5206\u53f7\u5206\u9694\u653e\u5728date\u5b57\u6bb5\u4e2d\u3002\\n\\n\u4e0d\u8fc7\uff0c\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\u4e2d\u7684date\u5b57\u6bb5\u662f\u5355\u4e2a\u65e5\u671f\uff0c\u4f8b\u5982\u201c1941-10-02\u201d\uff0c\u6240\u4ee5\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u53ea\u53d6\u7b2c\u4e00\u4e2a\u51fa\u73b0\u7684\u65e5\u671f\u3002\u6216\u8005\u53ef\u80fd\u7b2c\u4e8c\u4e2a\u65e5\u671f\u662f\u5220\u9664\u7684\uff0c\u6240\u4ee5\u4e0d\u7b97\u3002\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u6ca1\u6709\u8bf4\u660e\u8fd9\u4e00\u70b9\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5305\u62ec\u6240\u6709\u65e5\u671f\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5165date\u5b57\u6bb5\uff0c\u7528\u5206\u53f7\u5206\u9694\u3002\u4f46\u6839\u636eJSON Schema\uff0cdate\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u4ee5\u8fd9\u6837\u505a\u3002\u4f8b\u5982\uff1a\\n\\n\\\"date\\\": \\\"1941-10-02; 1945-11-23\\\"\\n\\n\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b26\u5408\u7528\u6237\u7684\u8981\u6c42\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5728information\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff1f\u4f46\u6839\u636e\u7528\u6237\u6307\u4ee4\uff0cdate\u5b57\u6bb5\u5e94\u8be5\u5305\u542b\u4efb\u4f55\u5b58\u5728\u7684\u65e5\u671f\u3002\u56e0\u6b64\uff0c\u6b63\u786e\u7684\u505a\u6cd5\u662f\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u8f6c\u6362\u5e76\u653e\u5165date\u5b57\u6bb5\uff0c\u7528\u5206\u53f7\u5206\u9694\u3002\\n\\n\u4e0d\u8fc7\uff0c\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u6bcf\u4e2a\u65e5\u671f\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ea\u80fd\u5408\u5e76\u3002\u56e0\u6b64\uff0c\u6700\u7ec8\u7684date\u5b57\u6bb5\u5e94\u4e3a\u201c1941-10-02; 1945-11-23\u201d\u3002\\n\\n\u4f46\u9700\u8981\u68c0\u67e5\u539f\u5361\u7247\u4e2d\u7684\u65e5\u671f\u662f\u5426\u90fd\u662fstamped dates\u3002\u56fe\u7247\u4e2d\u7684\u65e5\u671f\u662f\u624b\u5199\u7684\u8fd8\u662f\u6253\u5370\u7684\uff1f\u6839\u636e\u56fe\u7247\u63cf\u8ff0\uff0c\u53ef\u80fd\u90fd\u662f\u6253\u5370\u7684\uff0c\u6240\u4ee5\u5e94\u8be5\u88ab\u63d0\u53d6\u3002\u56e0\u6b64\uff0cdate\u5b57\u6bb5\u5e94\u5305\u542b\u4e24\u4e2a\u65e5\u671f\uff0c\u7528\u5206\u53f7\u5206\u9694\u3002\\n\\n\u63a5\u4e0b\u6765\u662finformation\u90e8\u5206\uff0c\u9700\u8981\u5c06\u4e3b\u6587\u672c\u5206\u6210\u4e24\u4e2a\u5757\u3002\u7b2c\u4e00\u4e2a\u5757\u662f\u201cBritische Schwarze Liste\\\\nAmendment 16, vom 2.10.1941.\u201d\uff0c\u7b2c\u4e8c\u4e2a\u5757\u662f\u201cgestrichen:\\\\nAmendment 13, 23.11.1945.\u201d\u3002\u6ce8\u610f\u4e2d\u95f4\u7684\u7a7a\u884c\u662f\u5426\u9700\u8981\u4fdd\u7559\uff0c\u4f46\u6839\u636e\u7528\u6237\u6307\u4ee4\uff0c\u6bcf\u4e2a\u6587\u672c\u5757\u4f5c\u4e3a\u5355\u72ec\u7684\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u5c06\u6bcf\u4e2a\u6bb5\u843d\u5206\u5f00\uff0c\u4fdd\u7559\u6362\u884c\u7b26\u3002\\n\\n\u73b0\u5728\u9700\u8981\u786e\u4fdd\u6240\u6709\u5b57\u6bb5\u90fd\u6b63\u786e\u586b\u5199\uff0c\u6ca1\u6709\u9057\u6f0f\u3002\u4f8b\u5982\uff0ccompany\u662f\u5426\u6b63\u786e\uff0clocation\u662f\u5426\u6b63\u786e\uff0cb_id\u662f\u5426\u6b63\u786e\uff0cdate\u662f\u5426\u6b63\u786e\u8f6c\u6362\uff0cinformation\u662f\u5426\u6b63\u786e\u5206\u5272\u3002\\n\\n\u6700\u540e\uff0c\u68c0\u67e5JSON\u683c\u5f0f\u662f\u5426\u7b26\u5408\u63d0\u4f9b\u7684Schema\uff0c\u786e\u4fdd\u6240\u6709required\u5b57\u6bb5\u90fd\u5b58\u5728\uff0c\u4e14\u7c7b\u578b\u6b63\u786e\u3002\u4f8b\u5982\uff0ccompany\u3001location\u3001b_id\u90fd\u662f\u5bf9\u8c61\uff0c\u5305\u542btranscription\u5b57\u6bb5\uff0cdate\u662f\u5b57\u7b26\u4e32\uff0cinformation\u662f\u6570\u7ec4\uff0c\u6bcf\u4e2a\u5143\u7d20\u662f\u5bf9\u8c61\u5305\u542btranscription\u5b57\u6bb5\u3002\\n\\n\u603b\u7ed3\uff1a\\n\\ncompany: {\\\"transcription\\\": \\\"Sacom (S.a.)\\\"}\\n\\nlocation: {\\\"transcription\\\": \\\"LUGANO\\\"}\\n\\nb_id: {\\\"transcription\\\": \\\"B.51.322.GB.397.\\\"}\\n\\ndate: \\\"1941-10-02; 1945-11-23\\\"\\n\\ninformation: [\\n  {\\\"transcription\\\": \\\"Britische Schwarze Liste\\\\nAmendment 16, vom 2.10.1941.\\\"},\\n  {\\\"transcription\\\": \\\"gestrichen:\\\\nAmendment 13, 23.11.1945.\\\"}\\n]\\n\\n\u4f46\u9700\u8981\u786e\u8ba4date\u5b57\u6bb5\u662f\u5426\u5141\u8bb8\u5206\u53f7\u5206\u9694\u7684\u591a\u4e2a\u65e5\u671f\u3002\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684JSON Schema\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\u7c7b\u578b\uff0c\u6240\u4ee5\u53ef\u4ee5\u5305\u542b\u591a\u4e2a\u65e5\u671f\uff0c\u7528\u5206\u53f7\u5206\u9694\u3002\u56e0\u6b64\uff0c\u8fd9\u6837\u5904\u7406\u662f\u6b63\u786e\u7684\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u5f20\u7d22\u5f15\u5361\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u6240\u9700\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u6211\u8981\u4ed4\u7ec6\u5206\u6790\u56fe\u7247\u4e2d\u7684\u5404\u4e2a\u90e8\u5206\uff0c\u786e\u4fdd\u6bcf\u4e2a\u5b57\u6bb5\u90fd\u6b63\u786e\u65e0\u8bef\u5730\u63d0\u53d6\u51fa\u6765\u3002\\n\\n\u9996\u5148\u770b\u201ccompany\u201d\u5b57\u6bb5\uff0c\u901a\u5e38\u5728\u5de6\u4e0a\u89d2\u3002\u56fe\u7247\u5de6\u4e0a\u89d2\u663e\u793a\u7684\u662f\u201cSacom (S.a.), LUGANO\u201d\uff0c\u6240\u4ee5\u516c\u53f8\u540d\u5e94\u8be5\u662f\u201cSacom (S.a.)\u201d\uff0c\u800c\u4f4d\u7f6e\u662f\u201cLUGANO\u201d\u3002\u8fd9\u91cc\u9700\u8981\u6ce8\u610f\u6392\u9664\u4f4d\u7f6e\u4fe1\u606f\uff0c\u6240\u4ee5\u516c\u53f8\u90e8\u5206\u53ea\u53d6\u201cSacom (S.a.)\u201d\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u201clocation\u201d\uff0c\u7d27\u8ddf\u5728\u516c\u53f8\u540d\u540e\u9762\uff0c\u8fd9\u91cc\u5c31\u662f\u201cLUGANO\u201d\u3002\u9700\u8981\u786e\u8ba4\u662f\u5426\u8fd8\u6709\u5176\u4ed6\u4f4d\u7f6e\u4fe1\u606f\uff0c\u4f46\u770b\u8d77\u6765\u8fd9\u91cc\u53ea\u6709LUGANO\uff0c\u6240\u4ee5\u6ca1\u95ee\u9898\u3002\\n\\n\u7136\u540e\u662f\u201cb_id\u201d\uff0c\u5728\u53f3\u4e0a\u89d2\uff0c\u4ee5\u201cB.\u201d\u5f00\u5934\u3002\u56fe\u7247\u53f3\u4e0a\u89d2\u663e\u793a\u7684\u662f\u201cB.51.322.GB.397.\u201d\uff0c\u6240\u4ee5\u76f4\u63a5\u63d0\u53d6\u8fd9\u4e2a\u4f5c\u4e3ab_id\u3002\\n\\n\u65e5\u671f\u90e8\u5206\u9700\u8981\u67e5\u627e\u662f\u5426\u6709 stamped dates\u3002\u56fe\u7247\u4e2d\u6709\u4e24\u4e2a\u65e5\u671f\uff1a2.10.1941\u548c23.11.1945\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662fYYYY-MM-DD\u683c\u5f0f\u3002\u8fd9\u91cc\u9700\u8981\u6ce8\u610f\u65e5\u671f\u7684\u683c\u5f0f\u8f6c\u6362\u30022.10.1941\u5e94\u8be5\u662f1941-10-02\uff0c\u800c23.11.1945\u5219\u662f1945-11-23\u3002\u4e0d\u8fc7\u7528\u6237\u53ef\u80fd\u53ea\u9700\u8981\u5b58\u5728\u7684\u4e00\u4e2a\u65e5\u671f\uff0c\u6216\u8005\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u591a\u4e2a\u65e5\u671f\u3002\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u53ef\u80fd\u53ea\u9700\u8981\u7b2c\u4e00\u4e2a\u51fa\u73b0\u7684\u65e5\u671f\uff0c\u6216\u8005\u6240\u6709\u65e5\u671f\uff1f\u4f46\u6839\u636e\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u4f8b\u5b50\uff0c\u53ef\u80fd\u53ea\u9700\u8981\u5b58\u5728\u7684\u4e00\u4e2a\u65e5\u671f\uff0c\u6216\u8005\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u5168\u90e8\u5217\u51fa\uff1f\u4e0d\u8fc7\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u4f8b\u5b50\u662f\u201cdate\u201d\u5b57\u6bb5\uff0c\u53ef\u80fd\u53ea\u53d6\u4e00\u4e2a\u3002\u4f46\u4ed4\u7ec6\u770b\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u8bf4\u660e\uff1a\u201cAny stamped dates on the card in YYYY-MM-DD format. If no date is present, use an empty string.\u201d \u6240\u4ee5\u5982\u679c\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u5168\u90e8\u5217\u51fa\uff0c\u4f46\u6839\u636eJSON\u683c\u5f0f\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u4e0d\u662f\u6570\u7ec4\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u53d6\u7b2c\u4e00\u4e2a\uff1f\u6216\u8005\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u5c06\u591a\u4e2a\u65e5\u671f\u5408\u5e76\uff1f\u4f46\u6839\u636e\u793a\u4f8b\u4e2d\u7684JSON\u7ed3\u6784\uff0cdate\u662f\u5b57\u7b26\u4e32\u7c7b\u578b\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u53d6\u5176\u4e2d\u4e00\u4e2a\u3002\u4f46\u56fe\u7247\u4e2d\u6709\u4e24\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u5176\u4ed6\u6307\u793a\u3002\u4f8b\u5982\uff0c\u5361\u7247\u4e2d\u7684\u201cgestrichen\u201d\u90e8\u5206\u53ef\u80fd\u8868\u793a\u5220\u9664\uff0c\u6240\u4ee5\u53ef\u80fd\u7b2c\u4e8c\u4e2a\u65e5\u671f\u662f\u5220\u9664\u7684\u65e5\u671f\uff0c\u800c\u7b2c\u4e00\u4e2a\u662f\u539f\u59cb\u65e5\u671f\u3002\u4f46\u7528\u6237\u53ef\u80fd\u53ea\u9700\u8981\u5b58\u5728\u7684\u65e5\u671f\uff0c\u4e0d\u7ba1\u662f\u5426\u88ab\u5220\u9664\u3002\u6216\u8005\u53ef\u80fd\u4e24\u4e2a\u65e5\u671f\u90fd\u9700\u8981\u8003\u8651\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\uff0c\u53ef\u80fd\u53ea\u53d6\u7b2c\u4e00\u4e2a\u51fa\u73b0\u7684\u65e5\u671f\uff0c\u6216\u8005\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\\n\\n\u4e0d\u8fc7\uff0c\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\u4e2d\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u53d6\u4e00\u4e2a\u65e5\u671f\u3002\u4f46\u56fe\u7247\u4e2d\u6709\u4e24\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u54ea\u4e2a\u662f\u4e3b\u8981\u7684\u3002\u4f8b\u5982\uff0c\u5361\u7247\u4e2d\u7684\u201cAmendment 16, vom 2.10.1941.\u201d\u548c\u201cgestrichen: Amendment 13, 23.11.1945.\u201d\u3002\u53ef\u80fd\u7b2c\u4e00\u4e2a\u65e5\u671f\u662f\u539f\u59cb\u6761\u76ee\u65e5\u671f\uff0c\u7b2c\u4e8c\u4e2a\u662f\u5220\u9664\u65e5\u671f\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u8bb0\u5f55\u6240\u6709\u5b58\u5728\u7684\u65e5\u671f\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u9009\u62e9\u5176\u4e2d\u4e00\u4e2a\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u5305\u542b\u5728information\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff1f\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u8bf4\u201cAny stamped dates on the card in YYYY-MM-DD format\u201d\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u8f6c\u6362\u4e3aYYYY-MM-DD\u683c\u5f0f\uff0c\u5e76\u653e\u5728date\u5b57\u6bb5\u4e2d\uff0c\u4f46JSON\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u4e0d\u662f\u6570\u7ec4\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u653e\u4e00\u4e2a\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5224\u65ad\uff0c\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u5408\u5e76\u6210\u4e00\u4e2a\u5b57\u7b26\u4e32\uff0c\u7528\u5206\u53f7\u5206\u9694\uff1f\u4f46\u6839\u636e\u793a\u4f8b\u4e2d\u7684JSON\u7ed3\u6784\uff0cdate\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u53d6\u7b2c\u4e00\u4e2a\u51fa\u73b0\u7684\u65e5\u671f\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5728information\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff1f\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u4f8b\u5b50\u663e\u793adate\u5b57\u6bb5\u662f\u5b58\u5728\u7684\uff0c\u6bd4\u5982\u793a\u4f8b\u4e2d\u7684date\u662f\u201c1941-10-02\u201d\u6216\u8005\u7c7b\u4f3c\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\u4e2d\u7684date\u5b57\u6bb5\u662f\u5426\u5141\u8bb8\u6709\u591a\u4e2a\u65e5\u671f\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684JSON Schema\uff0cdate\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\u7c7b\u578b\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u6709\u4e00\u4e2a\u65e5\u671f\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u9009\u62e9\u7b2c\u4e00\u4e2a\u51fa\u73b0\u7684\u65e5\u671f\uff0c\u53731941-10-02\uff0c\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u5305\u542b\u5728information\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff1f\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u8bf4\u660e\u662f\u201cAny stamped dates on the card in YYYY-MM-DD format\u201d\uff0c\u6240\u4ee5\u5982\u679c\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u53ef\u80fd\u9700\u8981\u5c06\u5b83\u4eec\u90fd\u8f6c\u6362\u4e3a\u6b63\u786e\u7684\u683c\u5f0f\uff0c\u5e76\u653e\u5728date\u5b57\u6bb5\u4e2d\uff0c\u4f46JSON\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u7528\u5206\u53f7\u5206\u9694\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u6ca1\u6709\u8fd9\u79cd\u60c5\u51b5\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\u4e2d\u7684date\u5b57\u6bb5\u662f\u5426\u5141\u8bb8\u6709\u591a\u4e2a\u65e5\u671f\uff0c\u4f46\u6839\u636e\u63d0\u4f9b\u7684JSON Schema\uff0cdate\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u6709\u4e00\u4e2a\u65e5\u671f\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5224\u65ad\u54ea\u4e2a\u65e5\u671f\u662f\u4e3b\u8981\u7684\u3002\u4f8b\u5982\uff0c\u5361\u7247\u4e2d\u7684\u201cAmendment 16, vom 2.10.1941.\u201d\u53ef\u80fd\u8868\u793a\u8be5\u6761\u76ee\u57281941\u5e7410\u67082\u65e5\u88ab\u6dfb\u52a0\uff0c\u800c\u201cgestrichen\u201d\u90e8\u5206\u8868\u793a\u57281945\u5e7411\u670823\u65e5\u88ab\u5220\u9664\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u8bb0\u5f55\u5b58\u5728\u7684\u65e5\u671f\uff0c\u4e0d\u7ba1\u662f\u5426\u88ab\u5220\u9664\u3002\u6240\u4ee5\u53ef\u80fd\u4e24\u4e2a\u65e5\u671f\u90fd\u9700\u8981\u8003\u8651\uff0c\u4f46\u6839\u636eJSON\u7ed3\u6784\uff0c\u53ea\u80fd\u9009\u4e00\u4e2a\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u653e\u5728information\u4e2d\uff0c\u800cdate\u5b57\u6bb5\u7559\u7a7a\uff1f\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u4f8b\u5b50\u663e\u793adate\u5b57\u6bb5\u662f\u5b58\u5728\u7684\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u5c06\u4e24\u4e2a\u65e5\u671f\u90fd\u8f6c\u6362\u4e3aYYYY-MM-DD\u683c\u5f0f\uff0c\u5e76\u653e\u5728date\u5b57\u6bb5\u4e2d\uff0c\u7528\u5206\u53f7\u5206\u9694\u3002\u4f46\u6839\u636eJSON Schema\uff0cdate\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u5141\u8bb8\u8fd9\u6837\u505a\u3002\u4f8b\u5982\uff0c\u201c1941-10-02; 1945-11-23\u201d\u3002\u4f46\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\u8f93\u51fa\u4e2d\u7684date\u5b57\u6bb5\u662f\u5355\u4e2a\u65e5\u671f\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u786e\u8ba4\u3002\u6216\u8005\u53ef\u80fd\u7528\u6237\u5e0c\u671b\u53ea\u53d6\u7b2c\u4e00\u4e2a\u51fa\u73b0\u7684\u65e5\u671f\uff0c\u53731941-10-02\u3002\u8fd9\u65f6\u5019\u9700\u8981\u51b3\u5b9a\u5982\u4f55\u5904\u7406\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u201cinformation\u201d\u5b57\u6bb5\uff0c\u9700\u8981\u63d0\u53d6\u4e3b\u6587\u672c\u5757\uff0c\u6bcf\u4e2a\u5757\u4f5c\u4e3a\u5355\u72ec\u7684\u5b57\u7b26\u4e32\uff0c\u4fdd\u6301\u6362\u884c\u3002\u56fe\u7247\u4e2d\u7684\u4e3b\u6587\u672c\u90e8\u5206\u6709\uff1a\\n\\n\u201cBritische Schwarze Liste\\nAmendment 16, vom 2.10.1941.\\n\\ngestrichen:\\nAmendment 13, 23.11.1945.\u201d\\n\\n\u6240\u4ee5\u9700\u8981\u5c06\u8fd9\u4e24\u90e8\u5206\u4f5c\u4e3a\u4e24\u4e2a\u6761\u76ee\uff0c\u6bcf\u4e2a\u6761\u76ee\u5305\u542b\u6362\u884c\u7b26\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u6761\u76ee\u662f\u201cBritische Schwarze Liste\\\\nAmendment 16, vom 2.10.1941.\u201d\uff0c\u7b2c\u4e8c\u4e2a\u662f\u201cgestrichen:\\\\nAmendment 13, 23.11.1945.\u201d\u3002\u6ce8\u610f\u4e2d\u95f4\u7684\u7a7a\u884c\u662f\u5426\u9700\u8981\u4fdd\u7559\uff0c\u4f46\u6839\u636e\u7528\u6237\u6307\u4ee4\uff0c\u6bcf\u4e2a\u6587\u672c\u5757\u4f5c\u4e3a\u5355\u72ec\u7684\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u5c06\u6bcf\u4e2a\u6bb5\u843d\u5206\u5f00\u3002\u4f46\u539f\u5361\u7247\u4e2d\u7684\u6587\u672c\u53ef\u80fd\u5206\u4e3a\u4e24\u4e2a\u90e8\u5206\uff0c\u4e2d\u95f4\u6709\u7a7a\u884c\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u6bcf\u4e2a\u90e8\u5206\u4f5c\u4e3a\u5355\u72ec\u7684\u6761\u76ee\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u90e8\u5206\u662f\u201cBritische Schwarze Liste\\\\nAmendment 16, vom 2.10.1941.\u201d\uff0c\u7b2c\u4e8c\u4e2a\u90e8\u5206\u662f\u201cgestrichen:\\\\nAmendment 13, 23.11.1945.\u201d\u3002\u8fd9\u6837\u5728information\u6570\u7ec4\u4e2d\u4f1a\u6709\u4e24\u4e2a\u5bf9\u8c61\uff0c\u6bcf\u4e2a\u5305\u542b\u5bf9\u5e94\u7684\u6587\u672c\u3002\\n\\n\u73b0\u5728\u9700\u8981\u68c0\u67e5\u6bcf\u4e2a\u5b57\u6bb5\u662f\u5426\u7b26\u5408\u8981\u6c42\uff1a\\n\\ncompany: Sacom (S.a.) \u2192 \u6b63\u786e\uff0c\u6392\u9664\u4f4d\u7f6eLUGANO\u3002\\n\\nlocation: LUGANO \u2192 \u6b63\u786e\u3002\\n\\nb_id: B.51.322.GB.397. \u2192 \u6b63\u786e\uff0c\u6ce8\u610f\u672b\u5c3e\u7684\u53e5\u70b9\u662f\u5426\u9700\u8981\u4fdd\u7559\uff0c\u6839\u636e\u56fe\u7247\uff0c\u5e94\u8be5\u4fdd\u7559\u3002\\n\\ndate: \u9700\u8981\u8f6c\u6362\u4e3aYYYY-MM-DD\u3002\u539f\u65e5\u671f\u662f2.10.1941\u548c23.11.1945\u3002\u8f6c\u6362\u4e3a1941-10-02\u548c1945-11-23\u3002\u4f46\u6839\u636eJSON\u7684date\u5b57\u6bb5\u662f\u5b57\u7b26\u4e32\uff0c\u53ef\u80fd\u9700\u8981\u9009\u62e9\u5176\u4e2d\u4e00\u4e2a\uff0c\u6216\u8005\u5408\u5e76\u3002\u4f46\u7528\u6237\u6307\u4ee4\u4e2d\u7684\u4f8b\u5b50\u53ef\u80fd\u53ea\u53d6\u7b2c\u4e00\u4e2a\uff0c\u6216\u8005\u5982\u679c\u6709\u591a\u4e2a\uff0c\u53ef\u80fd\u9700\u8981\u5168\u90e8\u5217\u51fa\u3002\u4f46\u6839\u636eJSON Schema\uff0cdate\u662f\u5b57\u7b26\u4e32\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u6709\u4e00\u4e2a\u3002\u8fd9\u65f6\u5019\u5