f0c\u5982\u679c\u4fe1\u4ef6\u662f\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u9001\uff0c\u4f46\u7531\u4e2a\u4eba\u7b7e\u7f72\uff0c\u90a3\u4e48sender_persons\u53ef\u80fd\u5305\u62ec\u7b7e\u7f72\u4eba\u7684\u540d\u5b57\u3002\u4f46\u7b7e\u540d\u65e0\u6cd5\u8bc6\u522b\uff0c\u6240\u4ee5\u8bbe\u4e3anull\uff1f\\n\\n\u7efc\u4e0a\uff1a\\n\\nletter_title: null\\n\\nsend_date: [\\\"1928-03-22\\\"]\\n\\nsender_persons: null\uff08\u56e0\u4e3a\u65e0\u6cd5\u8bc6\u522b\u7b7e\u540d\u540d\u5b57\uff0c\u6216\u8005\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2dsender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u8bbe\u4e3anull\uff09\\n\\nreceiver_persons: null\uff08\u56e0\u4e3a\u6536\u4ef6\u4eba\u662f\u516c\u53f8\u8463\u4e8b\u4f1a\uff0c\u65e0\u5177\u4f53\u4eba\u540d\uff09\\n\\n\u4f46\u9700\u8981\u518d\u68c0\u67e5\u662f\u5426\u6709\u5176\u4ed6\u4fe1\u606f\u3002\u4f8b\u5982\uff0c\u5728\u4fe1\u4ef6\u5185\u5bb9\u4e2d\u662f\u5426\u6709\u63d0\u5230\u53d1\u4ef6\u4eba\u7684\u540d\u5b57\uff1f\u4f8b\u5982\uff0c\u5728\u7b2c\u56db\u9875\u7684\u7b7e\u540d\u90e8\u5206\uff0c\u53ef\u80fd\u6709\u540d\u5b57\uff0c\u4f46\u624b\u5199\u4f53\u96be\u4ee5\u8fa8\u8ba4\u3002\u4f8b\u5982\uff0c\u7b2c\u4e00\u4e2a\u7b7e\u540d\u770b\u8d77\u6765\u50cf\u201cSulich\u201d\uff0c\u7b2c\u4e8c\u4e2a\u53ef\u80fd\u50cf\u201cGundelfinger\u201d\u6216\u8005\u201cGundel finger\u201d\uff1f\u4f46\u4f5c\u4e3a\u5386\u53f2\u5b66\u5bb6\uff0c\u53ef\u80fd\u9700\u8981\u6839\u636e\u5e38\u89c1\u745e\u58eb\u540d\u5b57\u63a8\u6d4b\uff0c\u4f46\u4e0d\u786e\u5b9a\u3002\u5982\u679c\u65e0\u6cd5\u786e\u5b9a\uff0c\u5e94\u8bbe\u4e3anull\u3002\\n\\n\u56e0\u6b64\uff0c\u6700\u7ec8JSON\u5e94\u4e3a\uff1a\\n\\n{\\n  \\\"metadata\\\": {\\n    \\\"letter_title\\\": [null],\\n    \\\"send_date\\\": [\\\"1928-03-22\\\"],\\n    \\\"sender_persons\\\": [null],\\n    \\\"receiver_persons\\\": [null]\\n  }\\n}\\n\\n\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426sender_persons\u53ef\u4ee5\u586b\u516c\u53f8\u540d\u79f0\u3002\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0csender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u586b\u4e2a\u4eba\u540d\u5b57\u3002\u4f46\u8fd9\u91cc\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fdsender_persons\u5e94\u4e3a\u516c\u53f8\u540d\u79f0\uff1f\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u8c03\u6574\u3002\u4f8b\u5982\uff0c\u5982\u679c\u4fe1\u4ef6\u7531\u516c\u53f8\u53d1\u51fa\uff0c\u4f46\u7531\u4e2a\u4eba\u7b7e\u7f72\uff0c\u90a3\u4e48sender_persons\u5e94\u586b\u7b7e\u7f72\u4eba\u7684\u540d\u5b57\u3002\u4f46\u7b7e\u540d\u65e0\u6cd5\u8bc6\u522b\uff0c\u6240\u4ee5\u8bbe\u4e3anull\u3002\\n\\n\u6216\u8005\uff0c\u53ef\u80fdsender_persons\u5e94\u586b\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0csender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u4e0d\u7b26\u5408\u3002\u56e0\u6b64\uff0c\u53ef\u80fdsender_persons\u8bbe\u4e3anull\u3002\\n\\n\u540c\u6837\uff0creceiver_persons\u662f\u6536\u4ef6\u516c\u53f8\uff0c\u4f46\u65e0\u5177\u4f53\u4eba\u540d\uff0c\u6240\u4ee5\u8bbe\u4e3anull\u3002\\n\\n\u56e0\u6b64\uff0c\u6700\u7ec8JSON\u5982\u4e0a\u8ff0\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u56db\u5f20\u5386\u53f2\u4fe1\u4ef6\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u76f8\u5173\u4fe1\u606f\u5230\u6307\u5b9a\u7684JSON\u683c\u5f0f\u4e2d\u3002\u9996\u5148\uff0c\u6211\u8981\u4ed4\u7ec6\u9605\u8bfb\u6bcf\u5f20\u56fe\u7247\u7684\u5185\u5bb9\uff0c\u627e\u51fa\u6240\u9700\u7684\u56db\u4e2a\u5b57\u6bb5\uff1aletter_title\u3001sender_persons\u3001send_date\u548creceiver_persons\u3002\\n\\n\u9996\u5148\u770b\u7b2c\u4e00\u5f20\u56fe\u7247\u3002\u4fe1\u5934\u663e\u793a\u53d1\u4ef6\u4eba\u662fBasler Rheinschiffahrt-Aktiengesellschaft\uff0c\u5730\u5740\u5728Basel\u3002\u65e5\u671f\u662f1928\u5e743\u670822\u65e5\uff0c\u7528\u5fb7\u8bed\u5199\u7684\u201cBasel, den 22. M\u00e4rz 1928.\u201d\uff0c\u6240\u4ee5send_date\u5e94\u8be5\u662f1928-03-22\u3002\u6536\u4ef6\u4eba\u662fBasler Personenschiffahrtsgesellschaft\u7684\u8463\u4e8b\u4f1a\uff0c\u6240\u4ee5receiver_persons\u5e94\u8be5\u662f\u8fd9\u4e2a\u516c\u53f8\u7684\u540d\u79f0\u3002\u4e0d\u8fc7\u7528\u6237\u8981\u6c42\u7684\u662f\u4eba\u540d\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u6ca1\u6709\u5177\u4f53\u7684\u4eba\u540d\uff0c\u53ea\u6709\u516c\u53f8\u540d\u79f0\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586bnull\uff1f\u6216\u8005\u53ef\u80fd\u6536\u4ef6\u4eba\u662f\u8463\u4e8b\u4f1a\uff0c\u4f46\u5177\u4f53\u4eba\u540d\u672a\u63d0\u53ca\uff0c\u6240\u4ee5receiver_persons\u8bbe\u4e3anull\uff1f\\n\\n\u63a5\u4e0b\u6765\u770b\u7b7e\u540d\u90e8\u5206\uff0c\u7b2c\u56db\u5f20\u56fe\u7247\u5e95\u90e8\u6709\u7b7e\u540d\uff0c\u770b\u8d77\u6765\u662f\u201cSulich\u201d\u548c\u53e6\u4e00\u4e2a\u540d\u5b57\uff0c\u53ef\u80fd\u62fc\u5199\u4e3a\u201cGundelfinger\u201d\u6216\u8005\u7c7b\u4f3c\uff0c\u4f46\u4e0d\u786e\u5b9a\u3002\u9700\u8981\u786e\u8ba4\u7b7e\u540d\u90e8\u5206\u3002\u7b2c\u56db\u9875\u7684\u7b7e\u540d\u662f\u201chochachtend BASLER RHEINSCHIFFAHRT-AKTIENGESELLSCHAFT\u201d\u7136\u540e\u6709\u4e24\u4e2a\u624b\u5199\u7b7e\u540d\uff0c\u53ef\u80fd\u5206\u522b\u662fSulich\u548cGundelfinger\uff1f\u4f46\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u9700\u8981\u586b\u516c\u53f8\u540d\u79f0\uff0c\u6216\u8005\u5982\u679c\u7b7e\u540d\u662f\u4e2a\u4eba\uff0c\u5219\u586b\u4e2a\u4eba\u540d\u5b57\u3002\u4f46\u6839\u636e\u4fe1\u5934\uff0c\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u5e94\u8be5\u662f\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2dsender_persons\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u6bd4\u5982Lisa Simpson\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5224\u65ad\u3002\u4f8b\u5982\uff0c\u5982\u679c\u4fe1\u4ef6\u662f\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u9001\uff0c\u4f46\u7531\u4e2a\u4eba\u7b7e\u7f72\uff0c\u90a3\u4e48sender_persons\u53ef\u80fd\u5305\u62ec\u7b7e\u7f72\u4eba\u7684\u540d\u5b57\u3002\u4f46\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u53ef\u80fd\u96be\u4ee5\u8fa8\u8ba4\uff0c\u6bd4\u5982\u7b2c\u4e00\u4e2a\u7b7e\u540d\u770b\u8d77\u6765\u50cf\u201cSulich\u201d\uff0c\u7b2c\u4e8c\u4e2a\u53ef\u80fd\u50cf\u201cGundelfinger\u201d\u6216\u8005\u522b\u7684\u3002\u4f46\u4f5c\u4e3a\u5386\u53f2\u5b66\u5bb6\uff0c\u53ef\u80fd\u9700\u8981\u6839\u636e\u5e38\u89c1\u540d\u5b57\u63a8\u6d4b\uff0c\u6216\u8005\u5982\u679c\u65e0\u6cd5\u786e\u5b9a\uff0c\u53ef\u80fd\u7559\u7a7a\uff1f\u4f46\u6839\u636e\u7528\u6237\u6307\u793a\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\u5219\u8bbe\u4e3anull\u3002\u4f46\u8fd9\u91cc\u7b7e\u540d\u5b58\u5728\uff0c\u4f46\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u586bnull\uff1f\u6216\u8005\u6839\u636e\u4fe1\u5934\uff0c\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u586b\u516c\u53f8\u540d\u79f0\uff1f\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u770b\u662f\u5426\u6709\u4e2a\u4eba\u540d\u5b57\u3002\u4f8b\u5982\uff0c\u5728\u4fe1\u4ef6\u5185\u5bb9\u4e2d\u63d0\u5230\u201cUnterzeichneten\u201d\u53ef\u80fd\u6307\u7b7e\u7f72\u4eba\uff0c\u4f46\u5177\u4f53\u540d\u5b57\u53ef\u80fd\u5728\u7b7e\u540d\u5904\u3002\u5982\u679c\u7b7e\u540d\u65e0\u6cd5\u8bc6\u522b\uff0c\u53ef\u80fdsender_persons\u8bbe\u4e3anull\uff1f\u6216\u8005\u6839\u636e\u4fe1\u5934\uff0c\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5sender_persons\u662f\u516c\u53f8\u540d\u79f0\uff1f\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u3002\\n\\n\u518d\u770b\u4fe1\u4ef6\u5185\u5bb9\uff0c\u7b2c\u4e00\u9875\u63d0\u5230\u201cUnterzeichneten und Ihrer Delegation, bestehend aus Herrn Dr. Vischer, Pr\u00e4sident, Herrn Christ, Vicepr\u00e4sident und Herrn Oettinger\u201d\uff0c\u4f46\u8fd9\u662f\u5bf9\u65b9\u7684\u4ee3\u8868\u56e2\u6210\u5458\uff0c\u4e0d\u662f\u53d1\u4ef6\u4eba\u3002\u53d1\u4ef6\u4eba\u7684\u7b7e\u540d\u5728\u7b2c\u56db\u9875\uff0c\u662f\u4e24\u4e2a\u624b\u5199\u7b7e\u540d\uff0c\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\uff0c\u6240\u4ee5\u53ef\u80fdsender_persons\u8bbe\u4e3anull\uff1f\u6216\u8005\u6839\u636e\u4fe1\u5934\uff0c\u53d1\u4ef6\u4eba\u662fBasler Rheinschiffahrt-Aktiengesellschaft\uff0c\u6240\u4ee5sender_persons\u586b\u8fd9\u4e2a\u516c\u53f8\u540d\u79f0\uff1f\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u3002\u4f8b\u5982\uff0c\u5982\u679c\u4fe1\u4ef6\u662f\u516c\u53f8\u53d1\u51fa\u7684\uff0c\u4f46\u7531\u4e2a\u4eba\u7b7e\u7f72\uff0c\u90a3\u4e48sender_persons\u53ef\u80fd\u5305\u62ec\u7b7e\u7f72\u4eba\u7684\u540d\u5b57\u3002\u4f46\u8fd9\u91cc\u7b7e\u540d\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\uff0c\u6240\u4ee5\u53ef\u80fd\u8bbe\u4e3anull\uff1f\u6216\u8005\u6839\u636e\u4fe1\u5934\uff0c\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u6240\u4ee5sender_persons\u662f\u516c\u53f8\u540d\u79f0\uff1f\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u793a\u4f8b\uff0csender_persons\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u770b\u662f\u5426\u6709\u4e2a\u4eba\u540d\u5b57\u3002\u4f8b\u5982\uff0c\u5728\u7b2c\u56db\u9875\u7684\u7b7e\u540d\u90e8\u5206\uff0c\u53ef\u80fd\u6709\u4e24\u4e2a\u540d\u5b57\uff0c\u4f46\u624b\u5199\u4f53\u96be\u4ee5\u8fa8\u8ba4\uff0c\u6240\u4ee5\u53ef\u80fd\u65e0\u6cd5\u786e\u5b9a\uff0c\u56e0\u6b64sender_persons\u8bbe\u4e3anull\uff1f\\n\\n\u5173\u4e8eletter_title\uff0c\u4fe1\u4ef6\u4e2d\u6ca1\u6709\u660e\u786e\u7684\u6807\u9898\uff0c\u6240\u4ee5\u8bbe\u4e3anull\u3002send_date\u662f1928-03-22\u3002receiver_persons\u662fBasler Personenschiffahrtsgesellschaft\u7684\u8463\u4e8b\u4f1a\uff0c\u4f46\u5177\u4f53\u4eba\u540d\u672a\u63d0\u53ca\uff0c\u6240\u4ee5\u8bbe\u4e3anull\uff1f\u6216\u8005\u6536\u4ef6\u4eba\u662f\u516c\u53f8