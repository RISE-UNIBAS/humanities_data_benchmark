    "raw_response": "{\"id\":\"gen-1776771838-6jdinScQTKoiMC4V7e7o\",\"choices\":[{\"finish_reason\":\"stop\",\"index\":0,\"logprobs\":null,\"message\":{\"content\":\"{\\n  \\\"metadata\\\": {\\n    \\\"send_date\\\": [\\\"1928-09-28\\\"],\\n    \\\"letter_title\\\": [\\n      \\\"null\\\"\\n    ],\\n    \\\"sender_persons\\\": [\\n      \\\"Jeanfrey\\\"\\n    ],\\n    \\\"receiver_persons\\\": [\\n      \\\"Dr. Max Vischer\\\"\\n    ]\\n  }\\n}\",\"refusal\":null,\"role\":\"assistant\",\"annotations\":null,\"audio\":null,\"function_call\":null,\"tool_calls\":null,\"parsed\":{\"metadata\":{\"send_date\":[\"1928-09-28\"],\"letter_title\":[\"null\"],\"sender_persons\":[\"Jeanfrey\"],\"receiver_persons\":[\"Dr. Max Vischer\"]}},\"reasoning\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u5386\u53f2\u4fe1\u4ef6\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u51fa\u6307\u5b9a\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u6211\u8981\u4ed4\u7ec6\u770b\u770b\u7528\u6237\u7684\u8981\u6c42\u3002\u7528\u6237\u5e0c\u671b\u6211\u4f5c\u4e3a20\u4e16\u7eaa\u745e\u58eb\u5386\u53f2\u7684\u4e13\u5bb6\uff0c\u4ece\u56fe\u7247\u4e2d\u63d0\u53d6\u4fe1\u4ef6\u7684\u6807\u9898\u3001\u53d1\u4ef6\u4eba\u3001\u6536\u4ef6\u4eba\u548c\u65e5\u671f\uff0c\u5e76\u4ee5JSON\u683c\u5f0f\u8fd4\u56de\uff0c\u6bcf\u4e2a\u503c\u90fd\u662f\u5217\u8868\u5f62\u5f0f\uff0c\u5373\u4f7f\u53ea\u6709\u4e00\u4e2a\u5143\u7d20\u3002\u65e5\u671f\u8981\u7528ISO\u683c\u5f0f\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\u5c31\u8bbe\u4e3anull\u3002\\n\\n\u9996\u5148\uff0c\u6211\u9700\u8981\u5206\u6790\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\u3002\u56fe\u7247\u663e\u793a\u7684\u662f\u201cVEREIN F\u00dcR DIE SCHIFFAHRT AUF DEM OBERRHEIN\u201d\u7684\u4fe1\u5934\uff0c\u4e5f\u5c31\u662f\u4e0a\u83b1\u8335\u6cb3\u822a\u8fd0\u534f\u4f1a\u3002\u65e5\u671f\u90e8\u5206\u5728\u53f3\u4e0a\u89d2\uff0c\u5199\u7740\u201cBASEL, DEN 28 Sept. 1928.\u201d\uff0c\u6240\u4ee5\u65e5\u671f\u5e94\u8be5\u662f1928\u5e749\u670828\u65e5\uff0c\u8f6c\u6362\u6210ISO\u683c\u5f0f\u5c31\u662f1928-09-28\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u6536\u4ef6\u4eba\uff0c\u4fe1\u4e2d\u63d0\u5230\u201cHerrn Dr. Max Vischer, Advokat & Notar Basel.\u201d\uff0c\u6240\u4ee5\u6536\u4ef6\u4eba\u662fDr. Max Vischer\uff0c\u53ef\u80fd\u8fd8\u6709\u4ed6\u7684\u804c\u4e1a\u548c\u5730\u70b9\uff0c\u4f46\u7528\u6237\u53ea\u9700\u8981\u540d\u5b57\uff0c\u6240\u4ee5\u6536\u4ef6\u4eba\u5217\u8868\u5e94\u8be5\u662f[\\\"Dr. Max Vischer\\\"]\u3002\\n\\n\u53d1\u4ef6\u4eba\u65b9\u9762\uff0c\u4fe1\u672b\u6709\u7b7e\u540d\uff0c\u770b\u8d77\u6765\u662f\u201cJeanfrey\u201d\uff0c\u4f46\u4fe1\u5934\u662f\u534f\u4f1a\u7684\u540d\u79f0\uff0c\u6240\u4ee5\u53d1\u4ef6\u4eba\u5e94\u8be5\u662f\u534f\u4f1a\u672c\u8eab\uff0c\u5373\u201cVerein f\u00fcr die Schiffahrt auf dem Oberrhein - BASEL\u201d\u3002\u4e0d\u8fc7\u7528\u6237\u8981\u6c42\u7684\u662f\u53d1\u4ef6\u4eba\u59d3\u540d\uff0c\u5982\u679c\u662f\u7ec4\u7ec7\u7684\u8bdd\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b97\u4f5c\u4e2a\u4eba\u3002\u4f46\u6839\u636e\u4f8b\u5b50\u4e2d\u7684\u60c5\u51b5\uff0c\u6bd4\u5982\u201cLisa Simpson\u201d\u662f\u4e2a\u4eba\uff0c\u800c\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u7ec4\u7ec7\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u586b\u5199\u7ec4\u7ec7\u540d\u79f0\u3002\u4e0d\u8fc7\u539f\u4fe1\u4e2d\u7684\u7b7e\u540d\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u8be5\u7ec4\u7ec7\u7684\u4ee3\u8868\uff0c\u6bd4\u5982Jeanfrey\u3002\u4f46\u9700\u8981\u4ed4\u7ec6\u770b\u4fe1\u7684\u5185\u5bb9\u3002\u4fe1\u7684\u7ed3\u5c3e\u6709\u201cMit vorz\u00fcglicher Hochachtung:\u201d\u540e\u9762\u662f\u534f\u4f1a\u7684\u5370\u7ae0\u548c\u7b7e\u540d\uff0c\u7b7e\u540d\u770b\u8d77\u6765\u662f\u201cJeanfrey\u201d\uff0c\u6240\u4ee5\u53d1\u4ef6\u4eba\u53ef\u80fd\u662f\u8be5\u7ec4\u7ec7\u7684\u4ee3\u8868\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u7ec4\u7ec7\u540d\u79f0\u8fd8\u662f\u4e2a\u4eba\u540d\u5b57\uff1f\u6839\u636e\u4f8b\u5b50\u4e2d\u7684\u60c5\u51b5\uff0c\u6bd4\u5982\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u7ec4\u7ec7\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u586b\u5199\u7ec4\u7ec7\u540d\u79f0\u3002\u4e0d\u8fc7\u539f\u4fe1\u4e2d\u7684\u53d1\u4ef6\u4eba\u4fe1\u606f\u5728\u4fe1\u5934\u662f\u534f\u4f1a\uff0c\u800c\u7b7e\u540d\u662f\u4e2a\u4eba\uff0c\u53ef\u80fd\u9700\u8981\u5224\u65ad\u3002\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0c\u6bd4\u5982\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u534f\u4f1a\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u3002\u4f46\u9700\u8981\u786e\u8ba4\u3002\u4f8b\u5982\uff0c\u5728\u4f8b\u5b50\u4e2d\uff0c\u53d1\u4ef6\u4eba\u662fLisa Simpson\uff0c\u800c\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u6240\u4ee5sender_persons\u5e94\u8be5\u662f[\\\"Verein f\u00fcr die Schiffahrt auf dem Oberrhein\\\"]\u3002\u4f46\u7b7e\u540d\u662fJeanfrey\uff0c\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u8be5\u4eba\u4ee3\u8868\u534f\u4f1a\u3002\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u7684\u662f\u5b9e\u9645\u5199\u4fe1\u7684\u4eba\uff0c\u5373\u7b7e\u540d\u7684\u4eba\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u770b\u4fe1\u7684\u5185\u5bb9\u662f\u5426\u6709\u8bf4\u660e\u3002\u4fe1\u4e2d\u5e76\u6ca1\u6709\u660e\u786e\u8bf4\u660e\u53d1\u4ef6\u4eba\u662f\u8c01\uff0c\u53ea\u662f\u534f\u4f1a\u7684\u62ac\u5934\uff0c\u800c\u7b7e\u540d\u662fJeanfrey\u3002\u6240\u4ee5\u53ef\u80fd\u53d1\u4ef6\u4eba\u662fJeanfrey\uff0c\u4f46\u9700\u8981\u786e\u8ba4\u3002\u6216\u8005\uff0c\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u800c\u7b7e\u540d\u662f\u4ee3\u8868\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u6839\u636e\u5e38\u89c4\u5904\u7406\uff0c\u5982\u679c\u4fe1\u5934\u662f\u7ec4\u7ec7\uff0c\u53d1\u4ef6\u4eba\u53ef\u80fd\u662f\u7ec4\u7ec7\uff0c\u4f46\u7b7e\u540d\u662f\u4e2a\u4eba\u3002\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u7684\u662f\u5b9e\u9645\u7b7e\u7f72\u7684\u4eba\u3002\u4f8b\u5982\uff0c\u5728\u4f8b\u5b50\u4e2d\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662fJeanfrey\u3002\u4f46\u9700\u8981\u4ed4\u7ec6\u770b\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u90e8\u5206\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u770b\u8d77\u6765\u662f\u201cJeanfrey\u201d\uff0c\u6240\u4ee5\u53d1\u4ef6\u4eba\u5e94\u8be5\u662f\u8fd9\u4e2a\u4eba\u3002\u4f46\u4fe1\u5934\u662f\u534f\u4f1a\uff0c\u6240\u4ee5\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u800c\u7b7e\u540d\u662f\u4ee3\u8868\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5c06\u534f\u4f1a\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u7684\u662f\u4e2a\u4eba\u540d\u5b57\u3002\u8fd9\u91cc\u53ef\u80fd\u5b58\u5728\u6b67\u4e49\uff0c\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\\n\\n\u53e6\u5916\uff0c\u4fe1\u4ef6\u6807\u9898\u662f\u5426\u5b58\u5728\uff1f\u7528\u6237\u8981\u6c42\u63d0\u53d6letter_title\uff0c\u4f46\u4fe1\u4ef6\u4e2d\u662f\u5426\u6709\u6807\u9898\uff1f\u901a\u5e38\u6b63\u5f0f\u4fe1\u4ef6\u53ef\u80fd\u6ca1\u6709\u6807\u9898\uff0c\u800c\u662f\u4ee5\u5185\u5bb9\u4e3a\u4e3b\u3002\u4f8b\u5982\uff0c\u4f8b\u5b50\u4e2d\u7684\u6807\u9898\u662f\u201cPetition for Environmental Protection\u201d\uff0c\u4f46\u5728\u8fd9\u4e2a\u4fe1\u4ef6\u4e2d\uff0c\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u7684\u6807\u9898\uff0c\u6240\u4ee5letter_title\u5e94\u4e3anull\u3002\u9700\u8981\u68c0\u67e5\u56fe\u7247\u4e2d\u662f\u5426\u6709\u6807\u9898\u3002\u56fe\u7247\u4e2d\u7684\u4fe1\u5934\u662f\u534f\u4f1a\u540d\u79f0\uff0c\u6b63\u6587\u5f00\u5934\u662f\u201cSehr geehrter Herr !\u201d\uff0c\u7136\u540e\u5185\u5bb9\uff0c\u6ca1\u6709\u660e\u663e\u7684\u6807\u9898\u3002\u56e0\u6b64\uff0cletter_title\u5e94\u4e3anull\u3002\\n\\n\u73b0\u5728\u6574\u7406\u4fe1\u606f\uff1a\\n\\n- letter_title: \u6ca1\u6709\u6807\u9898\uff0c\u6240\u4ee5null\u3002\\n- send_date: 1928-09-28\u3002\\n- sender_persons: \u7b7e\u540d\u662fJeanfrey\uff0c\u4f46\u4fe1\u5934\u662f\u534f\u4f1a\uff0c\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u3002\u5982\u679c\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u5219\u586b\u5199\u534f\u4f1a\u540d\u79f0\uff1b\u5982\u679c\u662f\u4e2a\u4eba\uff0c\u5219\u586b\u5199Jeanfrey\u3002\u6839\u636e\u5e38\u89c4\uff0c\u6b63\u5f0f\u4fe1\u4ef6\u7684\u53d1\u4ef6\u4eba\u901a\u5e38\u662f\u7ec4\u7ec7\uff0c\u4f46\u7b7e\u540d\u662f\u4e2a\u4eba\u4ee3\u8868\u3002\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u5b9e\u9645\u7b7e\u7f72\u7684\u4eba\u3002\u4f8b\u5982\uff0c\u5728\u4f8b\u5b50\u4e2d\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662fJeanfrey\u3002\u4f46\u9700\u8981\u770b\u662f\u5426\u6709\u5176\u4ed6\u4fe1\u606f\u3002\u4fe1\u4e2d\u5e76\u6ca1\u6709\u660e\u786e\u8bf4\u660e\u53d1\u4ef6\u4eba\u662f\u8c01\uff0c\u53ea\u662f\u534f\u4f1a\u7684\u62ac\u5934\uff0c\u800c\u7b7e\u540d\u662fJeanfrey\u3002\u56e0\u6b64\uff0c\u53ef\u80fd\u53d1\u4ef6\u4eba\u662fJeanfrey\uff0c\u4ee3\u8868\u534f\u4f1a\u3002\u6240\u4ee5sender_persons\u5e94\u4e3a[\\\"Jeanfrey\\\"]\u3002\\n- receiver_persons: Dr. Max Vischer\u3002\\n\\n\u4f46\u9700\u8981\u518d\u6b21\u786e\u8ba4\u3002\u4f8b\u5982\uff0c\u5728\u4fe1\u7684\u5f00\u5934\uff0c\u6536\u4ef6\u4eba\u662f\u201cHerrn Dr. Max Vischer, Advokat & Notar Basel.\u201d\uff0c\u6240\u4ee5\u6536\u4ef6\u4eba\u662fDr. Max Vischer\u3002\u53d1\u4ef6\u4eba\u65b9\u9762\uff0c\u4fe1\u672b\u7684\u7b7e\u540d\u662fJeanfrey\uff0c\u800c\u4fe1\u5934\u662f\u534f\u4f1a\uff0c\u6240\u4ee5\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u4f46\u7b7e\u540d\u662f\u4e2a\u4eba\u3002\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u7684\u662f\u5b9e\u9645\u5199\u4fe1\u7684\u4eba\uff0c\u5373\u7b7e\u540d\u7684\u4eba\u3002\u56e0\u6b64\uff0csender_persons\u5e94\u4e3a[\\\"Jeanfrey\\\"]\u3002\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u6709\u5176\u4ed6\u4fe1\u606f\u3002\u4f8b\u5982\uff0c\u4fe1\u4e2d\u662f\u5426\u6709\u63d0\u5230\u53d1\u4ef6\u4eba\u7684\u540d\u5b57\uff1f\u5728\u6b63\u6587\u4e2d\uff0c\u6ca1\u6709\u63d0\u5230\u53d1\u4ef6\u4eba\u7684\u540d\u5b57\uff0c\u53ea\u662f\u534f\u4f1a\u7684\u62ac\u5934\u3002\u56e0\u6b64\uff0c\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u4f46\u7b7e\u540d\u662f\u4e2a\u4eba\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5c06\u534f\u4f1a\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u7684\u662f\u4e2a\u4eba\u540d\u5b57\u3002\u8fd9\u91cc\u53ef\u80fd\u5b58\u5728\u4e0d\u786e\u5b9a\u6027\uff0c\u4f46\u6839\u636e\u4f8b\u5b50\u4e2d\u7684\u60c5\u51b5\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u586b\u5199\u7b7e\u540d\u7684\u4eba\u540d\u3002\\n\\n\u7efc\u4e0a\uff1a\\n\\nletter_title: null\\nsend_date: [\\\"1928-09-28\\\"]\\nsender_persons: [\\\"Jeanfrey\\\"]\\nreceiver_persons: [\\\"Dr. Max Vischer\\\"]\\n\\n\u4f46\u9700\u8981\u68c0\u67e5\u662f\u5426\u6709\u5176\u4ed6\u53ef\u80fd\u7684\u53d1\u4ef6\u4eba\u3002\u4f8b\u5982\uff0c\u4fe1\u5934\u4e2d\u7684\u534f\u4f1a\u540d\u79f0\u662f\u5426\u5e94\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff1f\u4f8b\u5982\uff0c\u5728\u4f8b\u5b50\u4e2d\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u7ec4\u7ec7\u3002\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u586b\u5199\u5b9e\u9645\u7b7e\u7f72\u7684\u4eba\u3002\u56e0\u6b64\uff0c\u53ef\u80fd\u6b63\u786e\u7684\u53d1\u4ef6\u4eba\u662fJeanfrey\u3002\u4f46\u9700\u8981\u786e\u8ba4\u7b7e\u540d\u662f\u5426\u6e05\u6670\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u770b\u8d77\u6765\u662f\u201cJeanfrey\u201d\uff0c\u6240\u4ee5\u5e94\u8be5\u6b63\u786e\u3002\\n\\n\u56e0\u6b64\uff0c\u6700\u7ec8\u7684JSON\u5e94\u8be5\u662f\uff1a\\n\\n{\\n  \\\"metadata\\\": {\\n    \\\"letter_title\\\": [null],\\n    \\\"send_date\\\": [\\\"1928-09-28\\\"],\\n    \\\"sender_persons\\\": [\\\"Jeanfrey\\\"],\\n    \\\"receiver_persons\\\": [\\\"Dr. Max Vischer\\\"]\\n  }\\n}\\n\\n\u4f46\u9700\u8981\u68c0\u67e5\u662f\u5426\u6240\u6709\u5b57\u6bb5\u90fd\u662f\u5217\u8868\uff0c\u5373\u4f7fnull\u4e5f\u8981\u7528\u5217\u8868\u3002\u6839\u636e\u7528\u6237\u7684\u8981\u6c42\uff0c\u6bcf\u4e2a\u503c\u90fd\u662f\u5217\u8868\uff0c\u6240\u4ee5letter_title\u5e94\u4e3a[null]\uff0c\u5176\u4ed6\u540c\u7406\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u5386\u53f2\u4fe1\u4ef6\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u51fa\u6307\u5b9a\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u6211\u8981\u4ed4\u7ec6\u770b\u770b\u7528\u6237\u7684\u8981\u6c42\u3002\u7528\u6237\u5e0c\u671b\u6211\u4f5c\u4e3a20\u4e16\u7eaa\u745e\u58eb\u5386\u53f2\u7684\u4e13\u5bb6\uff0c\u4ece\u56fe\u7247\u4e2d\u63d0\u53d6\u4fe1\u4ef6\u7684\u6807\u9898\u3001\u53d1\u4ef6\u4eba\u3001\u6536\u4ef6\u4eba\u548c\u65e5\u671f\uff0c\u5e76\u4ee5JSON\u683c\u5f0f\u8fd4\u56de\uff0c\u6bcf\u4e2a\u503c\u90fd\u662f\u5217\u8868\u5f62\u5f0f\uff0c\u5373\u4f7f\u53ea\u6709\u4e00\u4e2a\u5143\u7d20\u3002\u65e5\u671f\u8981\u7528ISO\u683c\u5f0f\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\u5c31\u8bbe\u4e3anull\u3002\\n\\n\u9996\u5148\uff0c\u6211\u9700\u8981\u5206\u6790\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\u3002\u56fe\u7247\u663e\u793a\u7684\u662f\u201cVEREIN F\u00dcR DIE SCHIFFAHRT AUF DEM OBERRHEIN\u201d\u7684\u4fe1\u5934\uff0c\u4e5f\u5c31\u662f\u4e0a\u83b1\u8335\u6cb3\u822a\u8fd0\u534f\u4f1a\u3002\u65e5\u671f\u90e8\u5206\u5728\u53f3\u4e0a\u89d2\uff0c\u5199\u7740\u201cBASEL, DEN 28 Sept. 1928.\u201d\uff0c\u6240\u4ee5\u65e5\u671f\u5e94\u8be5\u662f1928\u5e749\u670828\u65e5\uff0c\u8f6c\u6362\u6210ISO\u683c\u5f0f\u5c31\u662f1928-09-28\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u6536\u4ef6\u4eba\uff0c\u4fe1\u4e2d\u63d0\u5230\u201cHerrn Dr. Max Vischer, Advokat & Notar Basel.\u201d\uff0c\u6240\u4ee5\u6536\u4ef6\u4eba\u662fDr. Max Vischer\uff0c\u53ef\u80fd\u8fd8\u6709\u4ed6\u7684\u804c\u4e1a\u548c\u5730\u70b9\uff0c\u4f46\u7528\u6237\u53ea\u9700\u8981\u540d\u5b57\uff0c\u6240\u4ee5\u6536\u4ef6\u4eba\u5217\u8868\u5e94\u8be5\u662f[\\\"Dr. Max Vischer\\\"]\u3002\\n\\n\u53d1\u4ef6\u4eba\u65b9\u9762\uff0c\u4fe1\u672b\u6709\u7b7e\u540d\uff0c\u770b\u8d77\u6765\u662f\u201cJeanfrey\u201d\uff0c\u4f46\u4fe1\u5934\u662f\u534f\u4f1a\u7684\u540d\u79f0\uff0c\u6240\u4ee5\u53d1\u4ef6\u4eba\u5e94\u8be5\u662f\u534f\u4f1a\u672c\u8eab\uff0c\u5373\u201cVerein f\u00fcr die Schiffahrt auf dem Oberrhein - BASEL\u201d\u3002\u4e0d\u8fc7\u7528\u6237\u8981\u6c42\u7684\u662f\u53d1\u4ef6\u4eba\u59d3\u540d\uff0c\u5982\u679c\u662f\u7ec4\u7ec7\u7684\u8bdd\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b97\u4f5c\u4e2a\u4eba\u3002\u4f46\u6839\u636e\u4f8b\u5b50\u4e2d\u7684\u60c5\u51b5\uff0c\u6bd4\u5982\u201cLisa Simpson\u201d\u662f\u4e2a\u4eba\uff0c\u800c\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u7ec4\u7ec7\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u586b\u5199\u7ec4\u7ec7\u540d\u79f0\u3002\u4e0d\u8fc7\u539f\u4fe1\u4e2d\u7684\u7b7e\u540d\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u8be5\u7ec4\u7ec7\u7684\u4ee3\u8868\uff0c\u6bd4\u5982Jeanfrey\u3002\u4f46\u9700\u8981\u4ed4\u7ec6\u770b\u4fe1\u7684\u5185\u5bb9\u3002\u4fe1\u7684\u7ed3\u5c3e\u6709\u201cMit vorz\u00fcglicher Hochachtung:\u201d\u540e\u9762\u662f\u534f\u4f1a\u7684\u5370\u7ae0\u548c\u7b7e\u540d\uff0c\u7b7e\u540d\u770b\u8d77\u6765\u662f\u201cJeanfrey\u201d\uff0c\u6240\u4ee5\u53d1\u4ef6\u4eba\u53ef\u80fd\u662f\u8be5\u7ec4\u7ec7\u7684\u4ee3\u8868\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u7ec4\u7ec7\u540d\u79f0\u8fd8\u662f\u4e2a\u4eba\u540d\u5b57\uff1f\u6839\u636e\u4f8b\u5b50\u4e2d\u7684\u60c5\u51b5\uff0c\u6bd4\u5982\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u7ec4\u7ec7\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u586b\u5199\u7ec4\u7ec7\u540d\u79f0\u3002\u4e0d\u8fc7\u539f\u4fe1\u4e2d\u7684\u53d1\u4ef6\u4eba\u4fe1\u606f\u5728\u4fe1\u5934\u662f\u534f\u4f1a\uff0c\u800c\u7b7e\u540d\u662f\u4e2a\u4eba\uff0c\u53ef\u80fd\u9700\u8981\u5224\u65ad\u3002\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0c\u6bd4\u5982\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5c06\u534f\u4f1a\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\u3002\u4f46\u9700\u8981\u786e\u8ba4\u3002\u4f8b\u5982\uff0c\u5728\u4f8b\u5b50\u4e2d\uff0c\u53d1\u4ef6\u4eba\u662fLisa Simpson\uff0c\u800c\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u6240\u4ee5sender_persons\u5e94\u8be5\u662f[\\\"Verein f\u00fcr die Schiffahrt auf dem Oberrhein\\\"]\u3002\u4f46\u7b7e\u540d\u662fJeanfrey\uff0c\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u8be5\u4eba\u4ee3\u8868\u534f\u4f1a\u3002\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u7684\u662f\u5b9e\u9645\u5199\u4fe1\u7684\u4eba\uff0c\u5373\u7b7e\u540d\u7684\u4eba\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u770b\u4fe1\u7684\u5185\u5bb9\u662f\u5426\u6709\u8bf4\u660e\u3002\u4fe1\u4e2d\u5e76\u6ca1\u6709\u660e\u786e\u8bf4\u660e\u53d1\u4ef6\u4eba\u662f\u8c01\uff0c\u53ea\u662f\u534f\u4f1a\u7684\u62ac\u5934\uff0c\u800c\u7b7e\u540d\u662fJeanfrey\u3002\u6240\u4ee5\u53ef\u80fd\u53d1\u4ef6\u4eba\u662fJeanfrey\uff0c\u4f46\u9700\u8981\u786e\u8ba4\u3002\u6216\u8005\uff0c\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u800c\u7b7e\u540d\u662f\u4ee3\u8868\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u6839\u636e\u5e38\u89c4\u5904\u7406\uff0c\u5982\u679c\u4fe1\u5934\u662f\u7ec4\u7ec7\uff0c\u53d1\u4ef6\u4eba\u53ef\u80fd\u662f\u7ec4\u7ec7\uff0c\u4f46\u7b7e\u540d\u662f\u4e2a\u4eba\u3002\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u7684\u662f\u5b9e\u9645\u7b7e\u7f72\u7684\u4eba\u3002\u4f8b\u5982\uff0c\u5728\u4f8b\u5b50\u4e2d\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662fJeanfrey\u3002\u4f46\u9700\u8981\u4ed4\u7ec6\u770b\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u90e8\u5206\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u770b\u8d77\u6765\u662f\u201cJeanfrey\u201d\uff0c\u6240\u4ee5\u53d1\u4ef6\u4eba\u5e94\u8be5\u662f\u8fd9\u4e2a\u4eba\u3002\u4f46\u4fe1\u5934\u662f\u534f\u4f1a\uff0c\u6240\u4ee5\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u800c\u7b7e\u540d\u662f\u4ee3\u8868\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5c06\u534f\u4f1a\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u7684\u662f\u4e2a\u4eba\u540d\u5b57\u3002\u8fd9\u91cc\u53ef\u80fd\u5b58\u5728\u6b67\u4e49\uff0c\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\\n\\n\u53e6\u5916\uff0c\u4fe1\u4ef6\u6807\u9898\u662f\u5426\u5b58\u5728\uff1f\u7528\u6237\u8981\u6c42\u63d0\u53d6letter_title\uff0c\u4f46\u4fe1\u4ef6\u4e2d\u662f\u5426\u6709\u6807\u9898\uff1f\u901a\u5e38\u6b63\u5f0f\u4fe1\u4ef6\u53ef\u80fd\u6ca1\u6709\u6807\u9898\uff0c\u800c\u662f\u4ee5\u5185\u5bb9\u4e3a\u4e3b\u3002\u4f8b\u5982\uff0c\u4f8b\u5b50\u4e2d\u7684\u6807\u9898\u662f\u201cPetition for Environmental Protection\u201d\uff0c\u4f46\u5728\u8fd9\u4e2a\u4fe1\u4ef6\u4e2d\uff0c\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u7684\u6807\u9898\uff0c\u6240\u4ee5letter_title\u5e94\u4e3anull\u3002\u9700\u8981\u68c0\u67e5\u56fe\u7247\u4e2d\u662f\u5426\u6709\u6807\u9898\u3002\u56fe\u7247\u4e2d\u7684\u4fe1\u5934\u662f\u534f\u4f1a\u540d\u79f0\uff0c\u6b63\u6587\u5f00\u5934\u662f\u201cSehr geehrter Herr !\u201d\uff0c\u7136\u540e\u5185\u5bb9\uff0c\u6ca1\u6709\u660e\u663e\u7684\u6807\u9898\u3002\u56e0\u6b64\uff0cletter_title\u5e94\u4e3anull\u3002\\n\\n\u73b0\u5728\u6574\u7406\u4fe1\u606f\uff1a\\n\\n- letter_title: \u6ca1\u6709\u6807\u9898\uff0c\u6240\u4ee5null\u3002\\n- send_date: 1928-09-28\u3002\\n- sender_persons: \u7b7e\u540d\u662fJeanfrey\uff0c\u4f46\u4fe1\u5934\u662f\u534f\u4f1a\uff0c\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u3002\u5982\u679c\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u5219\u586b\u5199\u534f\u4f1a\u540d\u79f0\uff1b\u5982\u679c\u662f\u4e2a\u4eba\uff0c\u5219\u586b\u5199Jeanfrey\u3002\u6839\u636e\u5e38\u89c4\uff0c\u6b63\u5f0f\u4fe1\u4ef6\u7684\u53d1\u4ef6\u4eba\u901a\u5e38\u662f\u7ec4\u7ec7\uff0c\u4f46\u7b7e\u540d\u662f\u4e2a\u4eba\u4ee3\u8868\u3002\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u5b9e\u9645\u7b7e\u7f72\u7684\u4eba\u3002\u4f8b\u5982\uff0c\u5728\u4f8b\u5b50\u4e2d\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u53d1\u4ef6\u4eba\u662fJeanfrey\u3002\u4f46\u9700\u8981\u770b\u662f\u5426\u6709\u5176\u4ed6\u4fe1\u606f\u3002\u4fe1\u4e2d\u5e76\u6ca1\u6709\u660e\u786e\u8bf4\u660e\u53d1\u4ef6\u4eba\u662f\u8c01\uff0c\u53ea\u662f\u534f\u4f1a\u7684\u62ac\u5934\uff0c\u800c\u7b7e\u540d\u662fJeanfrey\u3002\u56e0\u6b64\uff0c\u53ef\u80fd\u53d1\u4ef6\u4eba\u662fJeanfrey\uff0c\u4ee3\u8868\u534f\u4f1a\u3002\u6240\u4ee5sender_persons\u5e94\u4e3a[\\\"Jeanfrey\\\"]\u3002\\n- receiver_persons: Dr. Max Vischer\u3002\\n\\n\u4f46\u9700\u8981\u518d\u6b21\u786e\u8ba4\u3002\u4f8b\u5982\uff0c\u5728\u4fe1\u7684\u5f00\u5934\uff0c\u6536\u4ef6\u4eba\u662f\u201cHerrn Dr. Max Vischer, Advokat & Notar Basel.\u201d\uff0c\u6240\u4ee5\u6536\u4ef6\u4eba\u662fDr. Max Vischer\u3002\u53d1\u4ef6\u4eba\u65b9\u9762\uff0c\u4fe1\u672b\u7684\u7b7e\u540d\u662fJeanfrey\uff0c\u800c\u4fe1\u5934\u662f\u534f\u4f1a\uff0c\u6240\u4ee5\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u4f46\u7b7e\u540d\u662f\u4e2a\u4eba\u3002\u4f46\u7528\u6237\u53ef\u80fd\u9700\u8981\u7684\u662f\u5b9e\u9645\u5199\u4fe1\u7684\u4eba\uff0c\u5373\u7b7e\u540d\u7684\u4eba\u3002\u56e0\u6b64\uff0csender_persons\u5e94\u4e3a[\\\"Jeanfrey\\\"]\u3002\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u6709\u5176\u4ed6\u4fe1\u606f\u3002\u4f8b\u5982\uff0c\u4fe1\u4e2d\u662f\u5426\u6709\u63d0\u5230\u53d1\u4ef6\u4eba\u7684\u540d\u5b57\uff1f\u5728\u6b63\u6587\u4e2d\uff0c\u6ca1\u6709\u63d0\u5230\u53d1\u4ef6\u4eba\u7684\u540d\u5b57\uff0c\u53ea\u662f\u534f\u4f1a\u7684\u62ac\u5934\u3002\u56e0\u6b64\uff0c\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u534f\u4f1a\uff0c\u4f46\u7b7e\u540d\u662f\u4e2a\u4eba\u3002\u8fd9\u65f6\u