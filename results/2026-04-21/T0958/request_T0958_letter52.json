7528\u6237\u63d0\u4f9b\u7684\u4e09\u5f20\u5386\u53f2\u4fe1\u4ef6\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u6307\u5b9a\u7684\u4fe1\u606f\u5230JSON\u683c\u5f0f\u4e2d\u3002\u9996\u5148\uff0c\u6211\u8981\u4ed4\u7ec6\u9605\u8bfb\u7528\u6237\u7684\u6307\u4ee4\uff0c\u786e\u4fdd\u7406\u89e3\u6240\u6709\u8981\u6c42\u3002\u7528\u6237\u5e0c\u671b\u63d0\u53d6\u56db\u4e2a\u5b57\u6bb5\uff1aletter_title\u3001sender_persons\u3001send_date\u548creceiver_persons\uff0c\u6bcf\u4e2a\u5b57\u6bb5\u7684\u503c\u90fd\u662f\u5217\u8868\u5f62\u5f0f\uff0c\u5373\u4f7f\u53ea\u6709\u4e00\u4e2a\u503c\u3002\u65e5\u671f\u9700\u8981\u7528ISO\u683c\u5f0fYYYY-MM-DD\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\u5219\u8bbe\u4e3anull\u3002\\n\\n\u9996\u5148\uff0c\u6211\u9700\u8981\u5206\u6790\u6bcf\u5f20\u56fe\u7247\u7684\u5185\u5bb9\u3002\u7b2c\u4e00\u5f20\u56fe\u7247\u662f\u4fe1\u4ef6\u7684\u9996\u9875\uff0c\u9876\u90e8\u6709\u516c\u53f8\u540d\u79f0\u201cBASLER RHEINSCHIFFFAHRT AKTIENGESELLSCHAFT\u201d\uff0c\u5730\u5740\u5728\u5df4\u585e\u5c14\u3002\u65e5\u671f\u90e8\u5206\u663e\u793a\u201cBasel, den 4.Oktober 1932\u201d\uff0c\u6240\u4ee5\u53d1\u9001\u65e5\u671f\u5e94\u8be5\u662f1932-10-04\u3002\u6536\u4ef6\u4eba\u662f\u201cHerrn Dr. Max Vischer, Advokat und Notar, Basel, St. Albangraben 8.\u201d\uff0c\u6240\u4ee5receiver_persons\u662fDr. Max Vischer\u3002\u53d1\u4ef6\u4eba\u5e94\u8be5\u662f\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u7528\u6237\u8981\u6c42\u7684\u662fsender_persons\uff0c\u5373\u4e2a\u4eba\u540d\u5b57\u3002\u4e0d\u8fc7\u4fe1\u4ef6\u672b\u5c3e\u7684\u7b7e\u540d\u90e8\u5206\u6709\u624b\u5199\u7b7e\u540d\uff0c\u4f46\u53ef\u80fd\u65e0\u6cd5\u8fa8\u8ba4\u5177\u4f53\u4eba\u540d\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0csender_persons\u5e94\u8be5\u662f\u4e2a\u4eba\u540d\u5b57\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u786e\u8ba4\uff0c\u4f46\u6839\u636e\u4fe1\u4ef6\u672b\u5c3e\u7684\u7b7e\u540d\uff0c\u53ef\u80fd\u65e0\u6cd5\u8bc6\u522b\u5177\u4f53\u4eba\u540d\uff0c\u6240\u4ee5\u53ef\u80fd\u7559\u7a7a\u6216\u8bbe\u4e3anull\uff1f\u4e0d\u8fc7\u6839\u636e\u793a\u4f8b\uff0c\u5982\u679c\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u53ef\u80fd\u9700\u8981\u7528\u516c\u53f8\u540d\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\\n\\n\u63a5\u4e0b\u6765\u770b\u7b2c\u4e8c\u548c\u7b2c\u4e09\u5f20\u56fe\u7247\uff0c\u786e\u8ba4\u662f\u5426\u6709\u66f4\u591a\u4fe1\u606f\u3002\u7b2c\u4e8c\u9875\u548c\u7b2c\u4e09\u9875\u7684\u9876\u90e8\u90fd\u91cd\u590d\u4e86\u6536\u4ef6\u4ebaDr. Max Vischer\u548c\u65e5\u671f4.10.32\uff0c\u53731932-10-04\u3002\u7b2c\u4e09\u9875\u672b\u5c3e\u6709\u516c\u53f8\u76d6\u7ae0\u548c\u7b7e\u540d\uff0c\u4f46\u7b7e\u540d\u53ef\u80fd\u96be\u4ee5\u8fa8\u8ba4\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4e2a\u4eba\uff0c\u53ea\u80fd\u7559\u7a7a\u6216\u8bbe\u4e3anull\uff1f\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u5982\u679c\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u53ef\u80fd\u9700\u8981\u7528\u516c\u53f8\u540d\uff0c\u4f46\u7528\u6237\u8981\u6c42\u7684\u662fsender_persons\uff0c\u5373\u4e2a\u4eba\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5224\u65ad\uff0c\u5982\u679c\u4fe1\u4ef6\u662f\u7531\u516c\u53f8\u53d1\u51fa\uff0c\u4f46\u7b7e\u540d\u662f\u4e2a\u4eba\uff0c\u4f46\u65e0\u6cd5\u8bc6\u522b\u540d\u5b57\uff0c\u53ef\u80fd\u53ea\u80fd\u7559\u7a7a\u3002\u6216\u8005\uff0c\u53ef\u80fd\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0csender_persons\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u8bbe\u4e3anull\u3002\u4e0d\u8fc7\uff0c\u5728\u7b2c\u4e09\u9875\u7684\u672b\u5c3e\uff0c\u6709\u201cBASLER RHEINSCHIFFFAHRT-AKTIENGESELLSCHAFT\u201d\u7684\u76d6\u7ae0\uff0c\u53ef\u80fd\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u4f46\u7528\u6237\u8981\u6c42\u7684\u662f\u4e2