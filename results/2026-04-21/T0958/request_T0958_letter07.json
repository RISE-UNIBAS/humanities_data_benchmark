e0d\u662f\u4e2a\u4eba\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662fsender_persons\uff0c\u5373\u4e2a\u4eba\u540d\u5b57\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5224\u65ad\u662f\u5426\u6709\u4e2a\u4eba\u7b7e\u540d\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u770b\u8d77\u6765\u50cf\u201cGundel\u201d\u548c\u53e6\u4e00\u4e2a\u540d\u5b57\uff0c\u4f46\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\u3002\u5982\u679c\u65e0\u6cd5\u786e\u5b9a\uff0c\u53ef\u80fd\u53ea\u80fd\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u6839\u636eschema\uff0csender_persons\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u6240\u4ee5\u53ef\u80fd\u8fd9\u91cc\u9700\u8981\u586b\u5199\u516c\u53f8\u540d\u79f0\uff0c\u6216\u8005\u5982\u679c\u65e0\u6cd5\u786e\u5b9a\u4e2a\u4eba\uff0c\u5219\u8bbe\u4e3anull\u3002\u4f46\u6839\u636e\u5386\u53f2\u4fe1\u4ef6\uff0c\u901a\u5e38\u516c\u53f8\u4fe1\u4ef6\u53ef\u80fd\u7531\u4ee3\u8868\u7b7e\u7f72\uff0c\u4f46\u540d\u5b57\u53ef\u80fd\u4e0d\u660e\u786e\u3002\u56e0\u6b64\uff0c\u53ef\u80fdsender_persons\u5e94\u4e3anull\uff0c\u6216\u8005\u586b\u5199\u516c\u53f8\u540d\u79f0\u3002\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u786e\u8ba4\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u53d1\u9001\u65e5\u671f\uff0c\u56fe\u7247\u4e2d\u660e\u786e\u5199\u7740\u201cBasel, den 22. Juni 1926.\u201d\uff0c\u6240\u4ee5\u65e5\u671f\u662f1926-06-22\u3002\\n\\n\u6536\u4ef6\u4eba\u662fHerrn P. Christ - Wackernagel\uff0c\u5730\u5740\u5728\u5df4\u585e\u5c14\uff0c\u6240\u4ee5receiver_persons\u662f[\\\"P. Christ - Wackernagel\\\"]\u3002\\n\\n\u73b0\u5728\uff0c\u5173\u4e8eletter_title\uff0c\u4fe1\u4ef6\u4e2d\u6ca1\u6709\u660e\u786e\u7684\u6807\u9898\uff0c\u6240\u4ee5\u8bbe\u4e3anull\u3002\\n\\n\u53d1\u4ef6\u4eba\u65b9\u9762\uff0c\u5982\u679c\u516c\u53f8\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u8981\u6c42\u7684\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u53ef\u80fd\u9700\u8981\u770b\u662f\u5426\u6709\u7b7e\u540d\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u770b\u8d77\u6765\u50cf\u201cGundel\u201d\u548c\u53e6\u4e00\u4e2a\u540d\u5b57\uff0c\u4f46\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\u3002\u4f8b\u5982\uff0c\u53ef\u80fd\u7b7e\u540d\u662f\u201cGundel\u201d\u548c\u201cM\u00fcller\u201d\u6216\u5176\u4ed6\uff0c\u4f46\u65e0\u6cd5\u786e\u5b9a\u3002\u56e0\u6b64\uff0c\u53ef\u80fd\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u7684\u53d1\u4ef6\u4eba\u4e2a\u4eba\u540d\u5b57\uff0c\u6240\u4ee5sender_persons\u8bbe\u4e3anull\u3002\u6216\u8005\uff0c\u5982\u679c\u516c\u53f8\u540d\u79f0\u53ef\u4ee5\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u6839\u636eschema\uff0csender_persons\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u6240\u4ee5\u53ef\u80fd\u8fd9\u91cc\u9700\u8981\u586b\u5199\u516c\u53f8\u540d\u79f0\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u8fd9\u91cc\u5e94\u8be5\u8bbe\u4e3anull\uff0c\u6216\u8005\u5982\u679c\u516c\u53f8\u4ee3\u8868\u7b7e\u7f72\uff0c\u4f46\u540d\u5b57\u4e0d\u660e\u786e\uff0c\u53ef\u80fd\u65e0\u6cd5\u586b\u5199\u3002\\n\\n\u7efc\u4e0a\uff0c\u53ef\u80fd\u7684JSON\u7ed3\u6784\u662f\uff1a\\n\\n{\\n  \\\"metadata\\\": {\\n    \\\"letter_title\\\": null,\\n    \\\"send_date\\\": [\\\"1926-06-22\\\"],\\n    \\\"sender_persons\\\": null,\\n    \\\"receiver_persons\\\": [\\\"P. Christ - Wackernagel\\\"]\\n  }\\n}\\n\\n\u4f46\u9700\u8981\u786e\u8ba4\u53d1\u4ef6\u4eba\u662f\u5426\u4e3a\u516c\u53f8\u8fd8\u662f\u4e2a\u4eba\u3002\u6839\u636e\u4fe1\u4ef6\u7684\u4fe1\u5934\u662f\u516c\u53f8\uff0c\u800c\u7b7e\u540d\u5904\u53ef\u80fd\u6709\u4e2a\u4eba\uff0c\u4f46\u65e0\u6cd5\u8bc6\u522b\u540d\u5b57\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u4e3anull\u3002\u6216\u8005\uff0c\u5982\u679c\u516c\u53f8\u540d\u79f0\u53ef\u4ee5\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u6839\u636eschema\uff0csender_persons\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u6240\u4ee5\u53ef\u80fd\u8fd9\u91cc\u5e94\u8be5\u8bbe\u4e3anull\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u5386\u53f2\u4fe1\u4ef6\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u51fa\u6307\u5b9a\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u6211\u5f97\u4ed4\u7ec6\u770b\u770b\u7528\u6237\u7684\u8981\u6c42\u3002\u7528\u6237\u5e0c\u671b\u6211\u4f5c\u4e3a20\u4e16\u7eaa\u745e\u58eb\u5386\u53f2\u7684\u4e13\u5bb6\uff0c\u4ece\u56fe\u7247\u4e2d\u63d0\u53d6\u56db\u4e2a\u5173\u952e\u4fe1\u606f\uff1a\u4fe1\u4ef6\u6807\u9898\u3001\u53d1\u4ef6\u4eba\u3001\u53d1\u9001\u65e5\u671f\u548c\u6536\u4ef6\u4eba\uff0c\u5e76\u4ee5JSON\u683c\u5f0f\u8fd4\u56de\uff0c\u6bcf\u4e2a\u503c\u90fd\u662f\u5217\u8868\u5f62\u5f0f\uff0c\u5373\u4f7f\u53ea\u6709\u4e00\u4e2a\u5143\u7d20\u3002\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u5c31\u8bbe\u4e3anull\u3002\\n\\n\u9996\u5148\uff0c\u6211\u9700\u8981\u4ed4\u7ec6\u5206\u6790\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\u3002\u56fe\u7247\u662f\u4e00\u5c01\u6765\u81eaBasler Rheinschiffahrt-Aktiengesellschaft\u7684\u4fe1\u4ef6\uff0c\u65e5\u671f\u662f1926\u5e746\u670822\u65e5\uff0c\u5730\u70b9\u662f\u5df4\u585e\u5c14\u3002\u6536\u4ef6\u4eba\u662fHerrn P. Christ - Wackernagel\uff0c\u5730\u5740\u5728\u5df4\u585e\u5c14\u3002\u4fe1\u4ef6\u7684\u6b63\u6587\u63d0\u5230\u4ed6\u4eec\u9644\u4e0a\u4e86\u4e00\u5c01\u524d\u4e00\u5929\u5199\u7ed9Dr. Max Vischer\u7684\u4fe1\u7684\u526f\u672c\uff0cDr. Max Vischer\u662fBasler Personenschiffahrts-Gesellschaft\u7684\u4e3b\u5e2d\u3002\\n\\n\u63a5\u4e0b\u6765\uff0c\u6211\u9700\u8981\u786e\u5b9a\u6bcf\u4e2a\u5b57\u6bb5\u7684\u4fe1\u606f\u3002\u9996\u5148\u662f\u4fe1\u4ef6\u6807\u9898\u3002\u901a\u5e38\uff0c\u6b63\u5f0f\u4fe1\u4ef6\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u7684\u6807\u9898\uff0c\u4f46\u6709\u65f6\u4f1a\u6709\u4e3b\u9898\u884c\u3002\u5728\u8fd9\u5c01\u4fe1\u4e2d\uff0c\u6b63\u6587\u5f00\u5934\u662f\u201cSehr geehrter Herr Christ\u201d\uff0c\u7136\u540e\u8bf4\u660e\u9644\u4e0a\u53e6\u4e00\u5c01\u4fe1\u7684\u526f\u672c\u3002\u8fd9\u91cc\u6ca1\u6709\u660e\u663e\u7684\u6807\u9898\uff0c\u6240\u4ee5letter_title\u5e94\u8be5\u662fnull\u3002\\n\\n\u7136\u540e\u662f\u53d1\u4ef6\u4eba\u3002\u4fe1\u4ef6\u7684\u4fe1\u5934\u662fBasler Rheinschiffahrt-Aktiengesellschaft\uff0c\u4f46\u53d1\u4ef6\u4eba\u901a\u5e38\u662f\u5177\u4f53\u7684\u4e2a\u4eba\u3002\u5728\u7b7e\u540d\u90e8\u5206\uff0c\u6709\u624b\u5199\u7b7e\u540d\uff0c\u4f46\u53ef\u80fd\u96be\u4ee5\u8fa8\u8ba4\u3002\u4e0d\u8fc7\uff0c\u4fe1\u672b\u7684\u7f72\u540d\u662f\u201cHochachtend BASLER RHEINSCHIFFAHRT-AKTIENGESELLSCHAFT\u201d\uff0c\u6240\u4ee5\u53d1\u4ef6\u4eba\u5e94\u8be5\u662f\u8fd9\u4e2a\u516c\u53f8\uff0c\u800c\u4e0d\u662f\u4e2a\u4eba\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662fsender_persons\uff0c\u5373\u4e2a\u4eba\u540d\u5b57\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u662f\u5426\u6709\u4e2a\u4eba\u7b7e\u540d\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u770b\u8d77\u6765\u50cf\u201cGundel\u201d\u548c\u53e6\u4e00\u4e2a\u540d\u5b57\uff0c\u4f46\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\u3002\u5982\u679c\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4e2a\u4eba\uff0c\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u7528\u6237\u53ef\u80fd\u671f\u671b\u4e2a\u4eba\u540d\u5b57\u3002\u4e0d\u8fc7\uff0c\u5728\u793a\u4f8b\u4e2d\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u800c\u8fd9\u91cc\u53ef\u80fd\u516c\u53f8\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u5e0c\u671b\u586b\u5199\u516c\u53f8\u540d\u79f0\u3002\u4e0d\u8fc7\u6839\u636e\u95ee\u9898\u63cf\u8ff0\uff0csender_persons\u662f\u201cName(s) of the person(s) who wrote the letter\u201d\uff0c\u6240\u4ee5\u5982\u679c\u662f\u516c\u53f8\u53d1\u51fa\u7684\uff0c\u53ef\u80fd\u6ca1\u6709\u5177\u4f53\u4e2a\u4eba\uff0c\u4f46\u4fe1\u4e2d\u6709\u7b7e\u540d\uff0c\u53ef\u80fd\u7b7e\u540d\u7684\u4eba\u662f\u53d1\u4ef6\u4eba\u3002\u4f46\u7b7e\u540d\u96be\u4ee5\u8fa8\u8ba4\uff0c\u53ef\u80fd\u65e0\u6cd5\u786e\u5b9a\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u6839\u636eJSON schema\uff0csender_persons\u662f\u5b57\u7b26\u4e32\u6570\u7ec4\uff0c\u53ef\u80fd\u9700\u8981\u586b\u5199\u516c\u53f8\u540d\u79f0\u3002\u6216\u8005\uff0c\u5982\u679c\u7b7e\u540d\u65e0\u6cd5\u8bc6\u522b\uff0c\u53ef\u80fd\u8bbe\u4e3anull\u3002\u4f46\u6839\u636e\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\uff0c\u53ef\u80fd\u6709\u4e24\u4e2a\u4eba\u7b7e\u540d\uff0c\u4f46\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\u540d\u5b57\uff0c\u6240\u4ee5\u53ef\u80fd\u53ea\u80fd\u586b\u5199\u516c\u53f8\u540d\u79f0\u3002\u4e0d\u8fc7\uff0c\u5728\u4fe1\u4ef6\u7684\u4fe1\u5934\u662f\u516c\u53f8\uff0c\u800c\u7b7e\u540d\u5904\u53ef\u80fd\u6709\u4e2a\u4eba\uff0c\u4f46\u65e0\u6cd5\u786e\u5b9a\u540d\u5b57\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u53d1\u4ef6\u4eba\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\\n\\n\u4e0d\u8fc7\uff0c\u4ed4\u7ec6\u770b\u4fe1\u4ef6\u5185\u5bb9\uff0c\u4fe1\u672b\u7684\u7f72\u540d\u662f\u201cHochachtend BASLER RHEINSCHIFFAHRT-AKTIENGESELLSCHAFT\u201d\uff0c\u6240\u4ee5\u53d1\u4ef6\u4eba\u662f\u516c\u53f8\uff0c\u800c\u4e0d\u662f\u4e2a\u4eba\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662fsender_persons\uff0c\u5373\u4e2a\u4eba\u540d\u5b57\u3002\u8fd9\u65f6\u5019\u53ef\u80fd\u9700\u8981\u5224\u65ad\u662f\u5426\u6709\u4e2a\u4eba\u7b7e\u540d\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u770b\u8d77\u6765\u50cf\u201cGundel\u201d\u548c\u53e6\u4e00\u4e2a\u540d\u5b57\uff0c\u4f46\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\u3002\u5982\u679c\u65e0\u6cd5\u786e\u5b9a\uff0c\u53ef\u80fd\u53ea\u80fd\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u6839\u636eschema\uff0csender_persons\u662f\u4e2a\u4eba\u540d\u5b57\uf