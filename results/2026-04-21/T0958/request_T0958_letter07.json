    "raw_response": "{\"id\":\"gen-1776771812-IIESojpnALgZWWijsjKM\",\"choices\":[{\"finish_reason\":\"stop\",\"index\":0,\"logprobs\":null,\"message\":{\"content\":\"{\\n  \\\"metadata\\\": {\\n    \\\"send_date\\\": [\\\"1926-06-22\\\"],\\n    \\\"letter_title\\\": null,\\n    \\\"sender_persons\\\": null,\\n    \\\"receiver_persons\\\": [\\\"P. Christ - Wackernagel\\\"]\\n  }\\n}\",\"refusal\":null,\"role\":\"assistant\",\"annotations\":null,\"audio\":null,\"function_call\":null,\"tool_calls\":null,\"parsed\":{\"metadata\":{\"send_date\":[\"1926-06-22\"],\"letter_title\":null,\"sender_persons\":null,\"receiver_persons\":[\"P. Christ - Wackernagel\"]}},\"reasoning\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u5386\u53f2\u4fe1\u4ef6\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u51fa\u6307\u5b9a\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u6211\u5f97\u4ed4\u7ec6\u770b\u770b\u7528\u6237\u7684\u8981\u6c42\u3002\u7528\u6237\u5e0c\u671b\u6211\u4f5c\u4e3a20\u4e16\u7eaa\u745e\u58eb\u5386\u53f2\u7684\u4e13\u5bb6\uff0c\u4ece\u56fe\u7247\u4e2d\u63d0\u53d6\u56db\u4e2a\u5173\u952e\u4fe1\u606f\uff1a\u4fe1\u4ef6\u6807\u9898\u3001\u53d1\u4ef6\u4eba\u3001\u53d1\u9001\u65e5\u671f\u548c\u6536\u4ef6\u4eba\uff0c\u5e76\u4ee5JSON\u683c\u5f0f\u8fd4\u56de\uff0c\u6bcf\u4e2a\u503c\u90fd\u662f\u5217\u8868\u5f62\u5f0f\uff0c\u5373\u4f7f\u53ea\u6709\u4e00\u4e2a\u5143\u7d20\u3002\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u5c31\u8bbe\u4e3anull\u3002\\n\\n\u9996\u5148\uff0c\u6211\u9700\u8981\u4ed4\u7ec6\u5206\u6790\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\u3002\u56fe\u7247\u662f\u4e00\u5c01\u6765\u81eaBasler Rheinschiffahrt-Aktiengesellschaft\u7684\u4fe1\u4ef6\uff0c\u65e5\u671f\u662f1926\u5e746\u670822\u65e5\uff0c\u5730\u70b9\u662f\u5df4\u585e\u5c14\u3002\u6536\u4ef6\u4eba\u662fHerrn P. Christ - Wackernagel\uff0c\u5730\u5740\u5728\u5df4\u585e\u5c14\u3002\u4fe1\u4ef6\u7684\u6b63\u6587\u63d0\u5230\u4ed6\u4eec\u9644\u4e0a\u4e86\u4e00\u5c01\u524d\u4e00\u5929\u5199\u7ed9Dr. Max Vischer\u7684\u4fe1\u7684\u526f\u672c\uff0cDr. Max Vischer\u662fBasler Personenschiffahrts-Gesellschaft\u7684\u4e3b\u5e2d\u3002\\n\\n\u63a5\u4e0b\u6765\uff0c\u6211\u9700\u8981\u786e\u5b9a\u6bcf\u4e2a\u5b57\u6bb5\u7684\u4fe1\u606f\u3002\u9996\u5148\u662f\u4fe1\u4ef6\u6807\u9898\u3002\u901a\u5e38\uff0c\u6b63\u5f0f\u4fe1\u4ef6\u53ef\u80fd\u6ca1\u6709\u660e\u786e\u7684\u6807\u9898\uff0c\u4f46\u6709\u65f6\u4f1a\u6709\u4e3b\u9898\u884c\u3002\u5728\u8fd9\u5c01\u4fe1\u4e2d\uff0c\u6b63\u6587\u5f00\u5934\u662f\u201cSehr geehrter Herr Christ\u201d\uff0c\u7136\u540e\u8bf4\u660e\u9644\u4e0a\u53e6\u4e00\u5c01\u4fe1\u7684\u526f\u672c\u3002\u8fd9\u91cc\u6ca1\u6709\u660e\u663e\u7684\u6807\u9898\uff0c\u6240\u4ee5letter_title\u5e94\u8be5\u662fnull\u3002\\n\\n\u7136\u540e\u662f\u53d1\u4ef6\u4eba\u3002\u4fe1\u4ef6\u7684\u4fe1\u5934\u662fBasler Rheinschiffahrt-Aktiengesellschaft\uff0c\u4f46\u53d1\u4ef6\u4eba\u901a\u5e38\u662f\u5177\u4f53\u7684\u4e2a\u4eba\u3002\u5728\u7b7e\u540d\u90e8\u5206\uff0c\u6709\u624b\u5199\u7b7e\u540d\uff0c\u4f46\u53ef\u80fd\u96be\u4ee5\u8fa8\u8ba4\u3002\u4e0d\u8fc7\uff0c\u4fe1\u672b\u7684\u7f72\u540d\u662f\u201cHochachtend BASLER RHEINSCHIFFAHRT-AKTIENGESELLSCHAFT\u201d\uff0c\u6240\u4ee5\u53d1\u4ef6\u4eba\u5e94\u8be5\u662f\u8fd9\u4e2a\u516c\u53f8\uff0c\u800c\u4e0d\u662f\u4e2a\u4eba\u3002\u4f46\u7528\u6237\u8981\u6c42\u7684\u662fsender_persons\uff0c\u5373\u4e2a\u4eba\u540d\u5b57\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u662f\u5426\u6709\u4e2a\u4eba\u7b7e\u540d\u3002\u56fe\u7247\u4e2d\u7684\u7b7e\u540d\u770b\u8d77\u6765\u50cf\u201cGundel\u201d\u548c\u53e6\u4e00\u4e2a\u540d\u5b57\uff0c\u4f46\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u8bc6\u522b\u3002\u5982\u679c\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4e2a\u4eba\uff0c\u53ef\u80fd\u9700\u8981\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3a\u53d1\u4ef6\u4eba\uff0c\u4f46\u6839\u636e\u793a\u4f8b\uff0c\u7528\u6237\u53ef\u80fd\u671f\u671b\u4e2a\u4eba\u540d\u5b57\u3002\u4e0d\u8fc7\uff0c\u5728\u793a\u4f8b\u4e