    "raw_response": "{\"id\":\"gen-1776771851-5XRAVIHn7LgXiEKsiZCs\",\"choices\":[{\"finish_reason\":\"stop\",\"index\":0,\"logprobs\":null,\"message\":{\"content\":\"{\\n  \\\"metadata\\\": {\\n    \\\"send_date\\\": [\\\"1922-12-16\\\"],\\n    \\\"letter_title\\\": null,\\n    \\\"sender_persons\\\": [\\\"Basler Personenschiffahrtsgesellschaft\\\"],\\n    \\\"receiver_persons\\\": [\\\"Basler Rheinschiffahrt A.-G.\\\"]\\n  }\\n}\",\"refusal\":null,\"role\":\"assistant\",\"annotations\":null,\"audio\":null,\"function_call\":null,\"tool_calls\":null,\"parsed\":{\"metadata\":{\"send_date\":[\"1922-12-16\"],\"letter_title\":null,\"sender_persons\":[\"Basler Personenschiffahrtsgesellschaft\"],\"receiver_persons\":[\"Basler Rheinschiffahrt A.-G.\"]}},\"reasoning\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u5386\u53f2\u4fe1\u4ef6\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u51fa\u6307\u5b9a\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u7528\u6237\u8981\u6c42\u63d0\u53d6\u56db\u4e2a\u5b57\u6bb5\uff1aletter_title\u3001sender_persons\u3001send_date\u548creceiver_persons\uff0c\u6bcf\u4e2a\u5b57\u6bb5\u90fd\u662f\u5217\u8868\u5f62\u5f0f\uff0c\u5373\u4f7f\u53ea\u6709\u4e00\u4e2a\u503c\u3002\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u5c31\u8bbe\u4e3anull\u3002\\n\\n\u9996\u5148\uff0c\u6211\u9700\u8981\u4ed4\u7ec6\u67e5\u770b\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\u3002\u4fe1\u4ef6\u7684\u9876\u90e8\u6709\u201cBASLER PERSONENSCHIFFAHRTSGESELLSCHAFT\u201d\uff0c\u8fd9\u5e94\u8be5\u662f\u53d1\u4ef6\u65b9\u7684\u540d\u79f0\uff0c\u4e5f\u5c31\u662fBasler Passenger Shipping Company\u3002\u65e5\u671f\u90e8\u5206\u5199\u7740\u201cBasel, den 16. Dezember 1922.\u201d\uff0c\u6240\u4ee5\u53d1\u9001\u65e5\u671f\u5e94\u8be5\u662f1922\u5e7412\u670816\u65e5\uff0c\u8f6c\u6362\u6210ISO\u683c\u5f0f\u5c31\u662f1922-12-16\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u6536\u4ef6\u4eba\u4fe1\u606f\uff0c\u4fe1\u4ef6\u5f00\u5934\u662f\u201cAn die Basler Rheinschiffahrt A.-G.-\u201d\uff0c\u5730\u5740\u662fMarktgasse 5, Basel\u3002\u6240\u4ee5\u6536\u4ef6\u4eba\u5e94\u8be5\u662fBasler Rheinschiffahrt A.-G.\uff0c\u4e5f\u5c31\u662fBasler Rhine Shipping Company\u3002\u8fd9\u91cc\u9700\u8981\u6ce8\u610f\uff0c\u867d\u7136\u5730\u5740\u662fBasel\uff0c\u4f46\u6536\u4ef6\u4eba\u540d\u79f0\u662f\u516c\u53f8\uff0c\u6240\u4ee5receiver_persons\u5e94\u8be5\u586b\u8fd9\u4e2a\u516c\u53f8\u540d\u3002\\n\\n\u5173\u4e8e\u53d1\u4ef6\u4eba\uff0c\u4fe1\u4ef6\u672b\u5c3e\u6709\u201cBasler Personenschiffahrtsgesellschaft\u201d\u4ee5\u53ca\u201cDer Pr\u00e4sident\u201d\u548c\u201cDer Gesch\u00e4ftsf\u00fchrer\u201d\u7684\u7b7e\u540d\u4f4d\u7f6e\uff0c\u4f46\u5177\u4f53\u540d\u5b57\u6ca1\u6709\u663e\u793a\u3002\u56e0\u6b64\uff0csender_persons\u53ef\u80fd\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4eba\u540d\uff0c\u53ea\u80fd\u586b\u516c\u53f8\u540d\u79f0\u3002\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u5982\u679c\u53d1\u4ef6\u4eba\u662f\u7ec4\u7ec7\uff0c\u53ef\u80fd\u9700\u8981\u7528\u7ec4\u7ec7\u540d\u79f0\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender_persons\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u6bd4\u5982Lisa Simpson\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5224\u65ad\u662f\u5426\u5e94\u8be5\u7528\u516c\u53f8\u540d\u79f0\u8fd8\u662f\u7559\u7a7a\u3002\u4f46\u6839\u636e\u4fe1\u4ef6\u5185\u5bb9\uff0c\u53d1\u4ef6\u65b9\u662fBasler Personenschiffahrtsgesellschaft\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u8fd9\u4e2a\u4f5c\u4e3asender_persons\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2dsender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u3002\u4e0d\u8fc7\u6839\u636e\u95ee\u9898\u63cf\u8ff0\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\u5c31\u586bnull\uff0c\u4f46\u8fd9\u91cc\u53d1\u4ef6\u65b9\u660e\u786e\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\u4e0d\u8fc7\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u770b\u662f\u5426\u6709\u5177\u4f53\u4eba\u540d\u3002\u4f46\u4fe1\u4ef6\u672b\u5c3e\u7684\u7b7e\u540d\u90e8\u5206\u6ca1\u6709\u5177\u4f53\u540d\u5b57\uff0c\u53ea\u6709\u804c\u4f4d\uff0c\u6240\u4ee5\u53ef\u80fd\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4eba\u540d\uff0c\u56e0\u6b64sender_persons\u53ef\u80fd\u4e3anull\uff1f\u6216\u8005\u7528\u516c\u53f8\u540d\u79f0\uff1f\\n\\n\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\u901a\u5e38\uff0c\u5728\u6b63\u5f0f\u4fe1\u4ef6\u4e2d\uff0c\u53d1\u4ef6\u65b9\u5982\u679c\u662f\u516c\u53f8\uff0c\u53ef\u80fd\u4f1a\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\u3002\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0c\u6bd4\u5982Lisa Simpson\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u8fd9\u91cc\u9700\u8981\u5177\u4f53\u4eba\u540d\u3002\u4f46\u4fe1\u4ef6\u4e2d\u6ca1\u6709\u5177\u4f53\u4eba\u540d\uff0c\u53ea\u6709\u516c\u53f8\u540d\u79f0\u548c\u804c\u4f4d\uff0c\u6240\u4ee5\u53ef\u80fdsender_persons\u5e94\u8be5\u4e3anull\uff1f\u6216\u8005\u662f\u5426\u5e94\u8be5\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\uff1f\\n\\n\u6839\u636e\u95ee\u9898\u63cf\u8ff0\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u8bbe\u4e3anull\u3002\u4f46\u53d1\u4ef6\u65b9\u660e\u786e\u662fBasler Personenschiffahrtsgesellschaft\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u8fd9\u4e2a\u4f5c\u4e3asender_persons\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u3002\u4e0d\u8fc7\u6839\u636e\u95ee\u9898\u4e2d\u7684\u8981\u6c42\uff0csender_persons\u662f\u5199\u4fe1\u7684\u4eba\uff0c\u5982\u679c\u662f\u516c\u53f8\uff0c\u53ef\u80fd\u5e94\u8be5\u7528\u516c\u53f8\u540d\u79f0\u3002\u4f8b\u5982\uff0c\u5982\u679c\u4fe1\u4ef6\u662f\u516c\u53f8\u53d1\u51fa\u7684\uff0c\u90a3\u4e48sender_persons\u53ef\u80fd\u5305\u62ec\u516c\u53f8\u4ee3\u8868\uff0c\u4f46\u5982\u679c\u6ca1\u6709\u5177\u4f53\u540d\u5b57\uff0c\u53ef\u80fd\u53ea\u80fd\u586b\u516c\u53f8\u540d\u79f0\u3002\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u53ef\u80fd\u671f\u671b\u7684\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5224\u65ad\u3002\\n\\n\u518d\u4ed4\u7ec6\u770b\u4fe1\u4ef6\u5185\u5bb9\uff0c\u672b\u5c3e\u6709\u201cDer Pr\u00e4sident\u201d\u548c\u201cDer Gesch\u00e4ftsf\u00fchrer\u201d\uff0c\u4f46\u540d\u5b57\u88ab\u6a21\u7cca\u5904\u7406\u4e86\uff0c\u65e0\u6cd5\u8fa8\u8ba4\u3002\u56e0\u6b64\uff0c\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u7684\u4e2a\u4eba\u540d\u5b57\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u5e94\u8be5\u8bbe\u4e3anull\uff1f\u6216\u8005\u662f\u5426\u5e94\u8be5\u7528\u516c\u53f8\u540d\u79f0\uff1f\\n\\n\u6839\u636e\u95ee\u9898\u4e2d\u7684\u4f8b\u5b50\uff0c\u6bd4\u5982sender_persons\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u5982\u679c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u4f46\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4eba\u540d\u7684\u8bdd\uff0c\u53ef\u80fd\u5e94\u8be5\u8bbe\u4e3anull\u3002\u4f46\u6709\u65f6\u5019\uff0c\u516c\u53f8\u4f5c\u4e3a\u53d1\u4ef6\u65b9\uff0c\u53ef\u80fd\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\u3002\u4f8b\u5982\uff0c\u5728\u5546\u4e1a\u4fe1\u51fd\u4e2d\uff0c\u53d1\u4ef6\u65b9\u901a\u5e38\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u6839\u636e\u60c5\u51b5\u5224\u65ad\u3002\\n\\n\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u53c2\u8003\u5386\u53f2\u4fe1\u4ef6\u7684\u60ef\u4f8b\u3002\u572820\u4e16\u7eaa\u521d\u7684\u745e\u58eb\uff0c\u516c\u53f8\u4fe1\u4ef6\u901a\u5e38\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u51fa\uff0c\u7b7e\u540d\u5904\u53ef\u80fd\u6709\u804c\u4f4d\u4f46\u65e0\u5177\u4f53\u540d\u5b57\uff0c\u6240\u4ee5\u53ef\u80fdsender_persons\u5e94\u4e3a\u516c\u53f8\u540d\u79f0\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684schema\uff0csender_persons\u662f\u4eba\u5458\u540d\u79f0\uff0c\u6240\u4ee5\u5982\u679c\u662f\u516c\u53f8\uff0c\u53ef\u80fd\u5e94\u8be5\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\u7684\u5143\u7d20\u3002\u4f8b\u5982\uff0c[\\\"Basler Personenschiffahrtsgesellschaft\\\"]\u3002\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b26\u5408\u7528\u6237\u7684\u8981\u6c42\u3002\\n\\n\u53e6\u5916\uff0cletter_title\u5728\u4fe1\u4ef6\u4e2d\u6ca1\u6709\u660e\u786e\u7684\u6807\u9898\uff0c\u901a\u5e38\u6b63\u5f0f\u4fe1\u4ef6\u53ef\u80fd\u6ca1\u6709\u6807\u9898\uff0c\u6240\u4ee5letter_title\u5e94\u4e3anull\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684letter_title\u662f\u5b58\u5728\u7684\uff0c\u6bd4\u5982\u201cPetition for Environmental Protection\u201d\u3002\u4f46\u5728\u8fd9\u4e2a\u4fe1\u4ef6\u4e2d\uff0c\u6ca1\u6709\u6807\u9898\uff0c\u6240\u4ee5\u5e94\u8be5\u8bbe\u4e3anull\u3002\\n\\n\u603b\u7ed3\uff1a\\n\\n- letter_title: \u6ca1\u6709\u6807\u9898\uff0c\u6240\u4ee5null\u3002\\n- send_date: 1922-12-16\u3002\\n- sender_persons: \u516c\u53f8\u540d\u79f0Basler Personenschiffahrtsgesellschaft\uff0c\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u4f5c\u4e3a\u4eba\u5458\u3002\u6216\u8005\u56e0\u4e3a\u7b7e\u540d\u5904\u6ca1\u6709\u5177\u4f53\u4eba\u540d\uff0c\u6240\u4ee5\u8bbe\u4e3anull\uff1f\\n- receiver_persons: Basler Rheinschiffahrt A.-G.\\n\\n\u4f46\u6839\u636e\u95ee\u9898\u4e2d\u7684\u4f8b\u5b50\uff0csender_persons\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u5982\u679c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u4f46\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4eba\u540d\u7684\u8bdd\uff0c\u53ef\u80fd\u5e94\u8be5\u8bbe\u4e3anull\u3002\u4f46\u6709\u65f6\u5019\uff0c\u516c\u53f8\u4f5c\u4e3a\u53d1\u4ef6\u65b9\uff0c\u53ef\u80fd\u7528\u516c\u53f8\u540d\u79f0\u3002\u4f8b\u5982\uff0c\u5728\u5546\u4e1a\u4fe1\u51fd\u4e2d\uff0c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u770b\u5177\u4f53\u60c5\u51b5\u3002\\n\\n\u518d\u4ed4\u7ec6\u770b\u4fe1\u4ef6\u5185\u5bb9\uff0c\u53d1\u4ef6\u65b9\u662fBasler Personenschiffahrtsgesellschaft\uff0c\u800c\u6536\u4ef6\u65b9\u662fBasler Rheinschiffahrt A.-G.\u3002\u6240\u4ee5sender_persons\u5e94\u8be5\u662f\u53d1\u4ef6\u65b9\u7684\u540d\u79f0\uff0c\u5373\u516c\u53f8\uff0c\u4f46\u7528\u6237\u53ef\u80fd\u671f\u671b\u7684\u662f\u4e2a\u4eba\u540d\u5b57\u3002\u4f46\u4fe1\u4ef6\u4e2d\u6ca1\u6709\u5177\u4f53\u4eba\u540d\uff0c\u53ea\u6709\u516c\u53f8\u540d\u79f0\u548c\u804c\u4f4d\uff0c\u6240\u4ee5\u53ef\u80fdsender_persons\u5e94\u4e3anull\uff0c\u6216\u8005\u586b\u516c\u53f8\u540d\u79f0\u3002\\n\\n\u6839\u636e\u95ee\u9898\u4e2d\u7684\u8981\u6c42\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u8bbe\u4e3anull\u3002\u4f46\u53d1\u4ef6\u65b9\u660e\u786e\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\u4f8b\u5982\uff0c\u5728\u5546\u4e1a\u4fe1\u51fd\u4e2d\uff0c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u6240\u4ee5sender_persons\u53ef\u4ee5\u662f\u516c\u53f8\u540d\u79f0\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u8c03\u6574\u3002\\n\\n\u6216\u8005\uff0c\u53ef\u80fd\u7528\u6237\u5e0c\u671bsender_persons\u662f\u5177\u4f53\u7684\u4eba\u540d\uff0c\u800c\u8fd9\u91cc\u6ca1\u6709\uff0c\u6240\u4ee5\u8bbe\u4e3anull\u3002\u4f46\u6839\u636e\u4fe1\u4ef6\u5185\u5bb9\uff0c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\u4f8b\u5982\uff0c\u5728\u5386\u53f2\u4fe1\u4ef6\u4e2d\uff0c\u516c\u53f8\u4f5c\u4e3a\u53d1\u4ef6\u65b9\uff0c\u53ef\u80fd\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\u3002\\n\\n\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u786e\u8ba4\u3002\u4f8b\u5982\uff0c\u5728\u745e\u58eb\u7684\u5386\u53f2\u4fe1\u4ef6\u4e2d\uff0c\u516c\u53f8\u4fe1\u4ef6\u901a\u5e38\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u51fa\uff0c\u7b7e\u540d\u5904\u53ef\u80fd\u6709\u804c\u4f4d\u4f46\u65e0\u5177\u4f53\u540d\u5b57\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u4e3a\u516c\u53f8\u540d\u79f0\u3002\u56e0\u6b64\uff0c\u53ef\u80fd\u5e94\u8be5\u586b[\\\"Basler Personenschiffahrtsgesellschaft\\\"]\u3002\\n\\n\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0csender_persons\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u5224\u65ad\u3002\u5982\u679c\u7528\u6237\u5e0c\u671b\u7684\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u800c\u8fd9\u91cc\u6ca1\u6709\uff0c\u90a3\u4e48\u8bbe\u4e3anull\u3002\u4f46\u6839\u636e\u95ee\u9898\u63cf\u8ff0\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u8bbe\u4e3anull\u3002\u4f46\u53d1\u4ef6\u65b9\u5b58\u5728\uff0c\u53ea\u662f\u6ca1\u6709\u5177\u4f53\u4eba\u540d\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\\n\\n\u53ef\u80fd\u8fd9\u91cc\u9700\u8981\u66f4\u4ed4\u7ec6\u5730\u5206\u6790\u95ee\u9898\u4e2d\u7684\u8981\u6c42\u3002\u95ee\u9898\u4e2d\u7684sender_persons\u662f\u201cName(s) of the person(s) who wrote the letter.\u201d\uff0c\u5373\u5199\u4fe1\u7684\u4eba\u3002\u5982\u679c\u662f\u516c\u53f8\uff0c\u53ef\u80fd\u7531\u4ee3\u8868\u7b7e\u7f72\uff0c\u4f46\u540d\u5b57\u672a\u663e\u793a\uff0c\u6240\u4ee5\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4eba\u540d\uff0c\u56e0\u6b64sender_persons\u5e94\u4e3anull\u3002\u4f46\u6709\u65f6\u5019\uff0c\u516c\u53f8\u4f5c\u4e3a\u53d1\u4ef6\u65b9\uff0c\u53ef\u80fd\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\uff0c\u4f46\u6839\u636e\u95ee\u9898\u4e2d\u7684\u4f8b\u5b50\uff0csender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u8bbe\u4e3anull\u3002\\n\\n\u4f46\u6839\u636e\u4fe1\u4ef6\u5185\u5bb9\uff0c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\u4f8b\u5982\uff0c\u5728\u5546\u4e1a\u4fe1\u51fd\u4e2d\uff0c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u6240\u4ee5sender_persons\u53ef\u4ee5\u662f\u516c\u53f8\u540d\u79f0\u3002\u4f46\u95ee\u9898\u4e2d\u7684\u4f8b\u5b50\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u6839\u636e\u60c5\u51b5\u5904\u7406\u3002\\n\\n\u8fd9\u91cc\u53ef\u80fd\u5b58\u5728\u6b67\u4e49\uff0c\u4f46\u6839\u636e\u95ee\u9898\u4e2d\u7684\u8981\u6c42\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u8bbe\u4e3anull\u3002\u4f46\u53d1\u4ef6\u65b9\u5b58\u5728\uff0c\u53ea\u662f\u6ca1\u6709\u5177\u4f53\u4eba\u540d\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\u4f8b\u5982\uff0c\u5728\u5386\u53f2\u4fe1\u4ef6\u4e2d\uff0c\u516c\u53f8\u4f5c\u4e3a\u53d1\u4ef6\u65b9\uff0c\u53ef\u80fd\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\u3002\\n\\n\u56e0\u6b64\uff0c\u53ef\u80fd\u6b63\u786e\u7684\u5904\u7406\u662f\uff1a\\n\\nletter_title: null\uff08\u56e0\u4e3a\u6ca1\u6709\u6807\u9898\uff09\\n\\nsend_date: [\\\"1922-12-16\\\"]\\n\\nsender_persons: [\\\"Basler Personenschiffahrtsgesellschaft\\\"]\\n\\nreceiver_persons: [\\\"Basler Rheinschiffahrt A.-G.\\\"]\\n\\n\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b26\u5408\u7528\u6237\u7684\u8981\u6c42\u3002\u4f8b\u5982\uff0c\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u3002\u6216\u8005\uff0c\u53ef\u80fd\u7528\u6237\u5e0c\u671bsender_persons\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u5982\u679c\u6ca1\u6709\u5177\u4f53\u540d\u5b57\uff0c\u8bbe\u4e3anull\u3002\\n\\n\u4f46\u6839\u636e\u95ee\u9898\u4e2d\u7684\u63cf\u8ff0\uff0csender_persons\u662f\u201cName(s) of the person(s) who wrote the letter.\u201d\uff0c\u5373\u5199\u4fe1\u7684\u4eba\u3002\u5982\u679c\u662f\u516c\u53f8\uff0c\u53ef\u80fd\u7531\u4ee3\u8868\u7b7e\u7f72\uff0c\u4f46\u540d\u5b57\u672a\u663e\u793a\uff0c\u6240\u4ee5\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4eba\u540d\uff0c\u56e0\u6b64sender_persons\u5e94\u4e3anull\u3002\u4f46\u6709\u65f6\u5019\uff0c\u516c\u53f8\u4f5c\u4e3a\u53d1\u4ef6\u65b9\uff0c\u53ef\u80fd\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\uff0c\u4f46\u6839\u636e\u95ee\u9898\u4e2d\u7684\u4f8b\u5b50\uff0c\u53ef\u80fd\u66f4\u503e\u5411\u4e8e\u4e2a\u4eba\u540d\u5b57\u3002\\n\\n\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u518d\u4ed4\u7ec6\u770b\u4fe1\u4ef6\u5185\u5bb9\u3002\u4fe1\u4ef6\u672b\u5c3e\u6709\u201cDer Pr\u00e4sident\u201d\u548c\u201cDer Gesch\u00e4ftsf\u00fchrer\u201d\uff0c\u4f46\u540d\u5b57\u88ab\u6a21\u7cca\u5904\u7406\u4e86\uff0c\u65e0\u6cd5\u8fa8\u8ba4\u3002\u56e0\u6b64\uff0c\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4eba\u540d\uff0c\u6240\u4ee5sender_persons\u5e94\u4e3anull\u3002\u4f46\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\u4f46\u6839\u636e\u95ee\u9898\u4e2d\u7684\u8981\u6c42\uff0csender_persons\u662f\u4eba\u5458\u540d\u79f0\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u8bbe\u4e3anull\uff0c\u56e0\u4e3a\u5177\u4f53\u4eba\u540d\u672a\u77e5\u3002\\n\\n\u4f46\u6839\u636e\u5386\u53f2\u4fe1\u4ef6\u7684\u60ef\u4f8b\uff0c\u516c\u53f8\u4fe1\u4ef6\u901a\u5e38\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u51fa\uff0c\u6240\u4ee5\u53ef\u80fdsender_persons\u5e94\u4e3a\u516c\u53f8\u540d\u79f0\u3002\u4f8b\u5982\uff0c\u5728\u5546\u4e1a\u4fe1\u51fd\u4e2d\uff0c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u6240\u4ee5sender_persons\u53ef\u4ee5\u662f\u516c\u53f8\u540d\u79f0\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u8c03\u6574\u3002\\n\\n\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u505a\u51fa\u5224\u65ad\u3002\u6839\u636e\u95ee\u9898\u4e2d\u7684\u4f8b\u5b50\uff0csender_persons\u662f\u4e2a\u4eba\uff0c\u4f46\u5728\u8fd9\u4e2a\u6848\u4f8b\u4e2d\uff0c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u4e14\u6ca1\u6709\u5177\u4f53\u4eba\u540d\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u8bbe\u4e3anull\u3002\u4f46\u6839\u636e\u5b9e\u9645\u5386\u53f2\u4fe1\u4ef6\u7684\u5904\u7406\uff0c\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\\n\\n\u53ef\u80fd\u6b63\u786e\u7684\u505a\u6cd5\u662f\uff0c\u5982\u679c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u4e14\u6ca1\u6709\u5177\u4f53\u4eba\u540d\uff0c\u5219sender_persons\u586b\u516c\u53f8\u540d\u79f0\u3002\u4f8b\u5982\uff0c\u5728\u5546\u4e1a\u4fe1\u51fd\u4e2d\uff0c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u6240\u4ee5sender_persons\u53ef\u4ee5\u662f\u516c\u53f8\u540d\u79f0\u3002\u56e0\u6b64\uff0c\u8fd9\u91cc\u5e94\u8be5\u586b[\\\"Basler Personenschiffahrtsgesellschaft\\\"]\u3002\\n\\n\u540c\u6837\uff0creceiver_persons\u662f\u6536\u4ef6\u65b9\uff0c\u5373Basler Rheinschiffahrt A.-G.\uff0c\u6240\u4ee5\u586b\u8fd9\u4e2a\u3002\\n\\nletter_title\u6ca1\u6709\uff0c\u6240\u4ee5null\u3002\\n\\nsend_date\u662f1922-12-16\u3002\\n\\n\u56e0\u6b64\uff0c\u6700\u7ec8\u7684JSON\u5e94\u8be5\u662f\uff1a\\n\\n{\\n  \\\"metadata\\\": {\\n    \\\"letter_title\\\": null,\\n    \\\"send_date\\\": [\\\"1922-12-16\\\"],\\n    \\\"sender_persons\\\": [\\\"Basler Personenschiffahrtsgesellschaft\\\"],\\n    \\\"receiver_persons\\\": [\\\"Basler Rheinschiffahrt A.-G.\\\"]\\n  }\\n}\\n\\n\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b26\u5408\u7528\u6237\u7684\u8981\u6c42\u3002\u4f8b\u5982\uff0c\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u4f46\u8fd9\u91cc\u53ef\u80fd\u5141\u8bb8\u516c\u53f8\u540d\u79f0\u3002\u6216\u8005\uff0c\u53ef\u80fd\u7528\u6237\u5e0c\u671bsender_persons\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u5982\u679c\u6ca1\u6709\u5177\u4f53\u540d\u5b57\uff0c\u8bbe\u4e3anull\u3002\u4f46\u6839\u636e\u95ee\u9898\u4e2d\u7684\u63cf\u8ff0\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u8bbe\u4e3anull\u3002\u4f46\u53d1\u4ef6\u65b9\u5b58\u5728\uff0c\u53ea\u662f\u6ca1\u6709\u5177\u4f53\u4eba\u540d\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\\n\\n\u6216\u8005\uff0c\u53ef\u80fd\u7528\u6237\u5e0c\u671bsender_persons\u662f\u5177\u4f53\u7684\u4eba\u540d\uff0c\u800c\u8fd9\u91cc\u6ca1\u6709\uff0c\u6240\u4ee5\u8bbe\u4e3anull\u3002\u4f46\u6839\u636e\u5386\u53f2\u4fe1\u4ef6\u7684\u5904\u7406\uff0c\u516c\u53f8\u4f5c\u4e3a\u53d1\u4ef6\u65b9\uff0c\u53ef\u80fd\u7528\u516c\u53f8\u540d\u79f0\u3002\\n\\n\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u53c2\u8003\u7c7b\u4f3c\u7684\u5386\u53f2\u4fe1\u4ef6\u5904\u7406\u65b9\u5f0f\u3002\u4f8b\u5982\uff0c\u5728\u745e\u58eb\u768420\u4e16\u7eaa\u5386\u53f2\u4fe1\u4ef6\u4e2d\uff0c\u516c\u53f8\u4fe1\u4ef6\u901a\u5e38\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u51fa\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u4e3a\u516c\u53f8\u540d\u79f0\u3002\u56e0\u6b64\uff0c\u6b63\u786e\u7684\u5904\u7406\u662f\u586b\u516c\u53f8\u540d\u79f0\u3002\\n\\n\u56e0\u6b64\uff0c\u6700\u7ec8\u7684JSON\u5e94\u8be5\u662f\u4e0a\u8ff0\u5185\u5bb9\u3002\",\"reasoning_details\":[{\"type\":\"reasoning.text\",\"text\":\"\uff0c\u6211\u73b0\u5728\u9700\u8981\u5904\u7406\u7528\u6237\u63d0\u4f9b\u7684\u8fd9\u4e2a\u5386\u53f2\u4fe1\u4ef6\u56fe\u7247\uff0c\u5e76\u63d0\u53d6\u51fa\u6307\u5b9a\u7684\u4fe1\u606f\u3002\u9996\u5148\uff0c\u7528\u6237\u8981\u6c42\u63d0\u53d6\u56db\u4e2a\u5b57\u6bb5\uff1aletter_title\u3001sender_persons\u3001send_date\u548creceiver_persons\uff0c\u6bcf\u4e2a\u5b57\u6bb5\u90fd\u662f\u5217\u8868\u5f62\u5f0f\uff0c\u5373\u4f7f\u53ea\u6709\u4e00\u4e2a\u503c\u3002\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u5c31\u8bbe\u4e3anull\u3002\\n\\n\u9996\u5148\uff0c\u6211\u9700\u8981\u4ed4\u7ec6\u67e5\u770b\u56fe\u7247\u4e2d\u7684\u5185\u5bb9\u3002\u4fe1\u4ef6\u7684\u9876\u90e8\u6709\u201cBASLER PERSONENSCHIFFAHRTSGESELLSCHAFT\u201d\uff0c\u8fd9\u5e94\u8be5\u662f\u53d1\u4ef6\u65b9\u7684\u540d\u79f0\uff0c\u4e5f\u5c31\u662fBasler Passenger Shipping Company\u3002\u65e5\u671f\u90e8\u5206\u5199\u7740\u201cBasel, den 16. Dezember 1922.\u201d\uff0c\u6240\u4ee5\u53d1\u9001\u65e5\u671f\u5e94\u8be5\u662f1922\u5e7412\u670816\u65e5\uff0c\u8f6c\u6362\u6210ISO\u683c\u5f0f\u5c31\u662f1922-12-16\u3002\\n\\n\u63a5\u4e0b\u6765\u662f\u6536\u4ef6\u4eba\u4fe1\u606f\uff0c\u4fe1\u4ef6\u5f00\u5934\u662f\u201cAn die Basler Rheinschiffahrt A.-G.-\u201d\uff0c\u5730\u5740\u662fMarktgasse 5, Basel\u3002\u6240\u4ee5\u6536\u4ef6\u4eba\u5e94\u8be5\u662fBasler Rheinschiffahrt A.-G.\uff0c\u4e5f\u5c31\u662fBasler Rhine Shipping Company\u3002\u8fd9\u91cc\u9700\u8981\u6ce8\u610f\uff0c\u867d\u7136\u5730\u5740\u662fBasel\uff0c\u4f46\u6536\u4ef6\u4eba\u540d\u79f0\u662f\u516c\u53f8\uff0c\u6240\u4ee5receiver_persons\u5e94\u8be5\u586b\u8fd9\u4e2a\u516c\u53f8\u540d\u3002\\n\\n\u5173\u4e8e\u53d1\u4ef6\u4eba\uff0c\u4fe1\u4ef6\u672b\u5c3e\u6709\u201cBasler Personenschiffahrtsgesellschaft\u201d\u4ee5\u53ca\u201cDer Pr\u00e4sident\u201d\u548c\u201cDer Gesch\u00e4ftsf\u00fchrer\u201d\u7684\u7b7e\u540d\u4f4d\u7f6e\uff0c\u4f46\u5177\u4f53\u540d\u5b57\u6ca1\u6709\u663e\u793a\u3002\u56e0\u6b64\uff0csender_persons\u53ef\u80fd\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4eba\u540d\uff0c\u53ea\u80fd\u586b\u516c\u53f8\u540d\u79f0\u3002\u4e0d\u8fc7\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u5982\u679c\u53d1\u4ef6\u4eba\u662f\u7ec4\u7ec7\uff0c\u53ef\u80fd\u9700\u8981\u7528\u7ec4\u7ec7\u540d\u79f0\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender_persons\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u6bd4\u5982Lisa Simpson\u3002\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5224\u65ad\u662f\u5426\u5e94\u8be5\u7528\u516c\u53f8\u540d\u79f0\u8fd8\u662f\u7559\u7a7a\u3002\u4f46\u6839\u636e\u4fe1\u4ef6\u5185\u5bb9\uff0c\u53d1\u4ef6\u65b9\u662fBasler Personenschiffahrtsgesellschaft\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u8fd9\u4e2a\u4f5c\u4e3asender_persons\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2dsender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u3002\u4e0d\u8fc7\u6839\u636e\u95ee\u9898\u63cf\u8ff0\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\u5c31\u586bnull\uff0c\u4f46\u8fd9\u91cc\u53d1\u4ef6\u65b9\u660e\u786e\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\u4e0d\u8fc7\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u770b\u662f\u5426\u6709\u5177\u4f53\u4eba\u540d\u3002\u4f46\u4fe1\u4ef6\u672b\u5c3e\u7684\u7b7e\u540d\u90e8\u5206\u6ca1\u6709\u5177\u4f53\u540d\u5b57\uff0c\u53ea\u6709\u804c\u4f4d\uff0c\u6240\u4ee5\u53ef\u80fd\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4eba\u540d\uff0c\u56e0\u6b64sender_persons\u53ef\u80fd\u4e3anull\uff1f\u6216\u8005\u7528\u516c\u53f8\u540d\u79f0\uff1f\\n\\n\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u8fdb\u4e00\u6b65\u5206\u6790\u3002\u901a\u5e38\uff0c\u5728\u6b63\u5f0f\u4fe1\u4ef6\u4e2d\uff0c\u53d1\u4ef6\u65b9\u5982\u679c\u662f\u516c\u53f8\uff0c\u53ef\u80fd\u4f1a\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\uff0c\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\u3002\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684\u4f8b\u5b50\uff0c\u6bd4\u5982Lisa Simpson\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u8fd9\u91cc\u9700\u8981\u5177\u4f53\u4eba\u540d\u3002\u4f46\u4fe1\u4ef6\u4e2d\u6ca1\u6709\u5177\u4f53\u4eba\u540d\uff0c\u53ea\u6709\u516c\u53f8\u540d\u79f0\u548c\u804c\u4f4d\uff0c\u6240\u4ee5\u53ef\u80fdsender_persons\u5e94\u8be5\u4e3anull\uff1f\u6216\u8005\u662f\u5426\u5e94\u8be5\u5c06\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\uff1f\\n\\n\u6839\u636e\u95ee\u9898\u63cf\u8ff0\uff0c\u5982\u679c\u4fe1\u606f\u4e0d\u5b58\u5728\uff0c\u8bbe\u4e3anull\u3002\u4f46\u53d1\u4ef6\u65b9\u660e\u786e\u662fBasler Personenschiffahrtsgesellschaft\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u8fd9\u4e2a\u4f5c\u4e3asender_persons\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u786e\u8ba4\u3002\u4e0d\u8fc7\u6839\u636e\u95ee\u9898\u4e2d\u7684\u8981\u6c42\uff0csender_persons\u662f\u5199\u4fe1\u7684\u4eba\uff0c\u5982\u679c\u662f\u516c\u53f8\uff0c\u53ef\u80fd\u5e94\u8be5\u7528\u516c\u53f8\u540d\u79f0\u3002\u4f8b\u5982\uff0c\u5982\u679c\u4fe1\u4ef6\u662f\u516c\u53f8\u53d1\u51fa\u7684\uff0c\u90a3\u4e48sender_persons\u53ef\u80fd\u5305\u62ec\u516c\u53f8\u4ee3\u8868\uff0c\u4f46\u5982\u679c\u6ca1\u6709\u5177\u4f53\u540d\u5b57\uff0c\u53ef\u80fd\u53ea\u80fd\u586b\u516c\u53f8\u540d\u79f0\u3002\u4f46\u6839\u636e\u7528\u6237\u793a\u4f8b\uff0c\u53ef\u80fd\u671f\u671b\u7684\u662f\u4e2a\u4eba\u540d\u5b57\uff0c\u6240\u4ee5\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u5224\u65ad\u3002\\n\\n\u518d\u4ed4\u7ec6\u770b\u4fe1\u4ef6\u5185\u5bb9\uff0c\u672b\u5c3e\u6709\u201cDer Pr\u00e4sident\u201d\u548c\u201cDer Gesch\u00e4ftsf\u00fchrer\u201d\uff0c\u4f46\u540d\u5b57\u88ab\u6a21\u7cca\u5904\u7406\u4e86\uff0c\u65e0\u6cd5\u8fa8\u8ba4\u3002\u56e0\u6b64\uff0c\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u7684\u4e2a\u4eba\u540d\u5b57\uff0c\u6240\u4ee5sender_persons\u53ef\u80fd\u5e94\u8be5\u8bbe\u4e3anull\uff1f\u6216\u8005\u662f\u5426\u5e94\u8be5\u7528\u516c\u53f8\u540d\u79f0\uff1f\\n\\n\u6839\u636e\u95ee\u9898\u4e2d\u7684\u4f8b\u5b50\uff0c\u6bd4\u5982sender_persons\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u5982\u679c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u4f46\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4eba\u540d\u7684\u8bdd\uff0c\u53ef\u80fd\u5e94\u8be5\u8bbe\u4e3anull\u3002\u4f46\u6709\u65f6\u5019\uff0c\u516c\u53f8\u4f5c\u4e3a\u53d1\u4ef6\u65b9\uff0c\u53ef\u80fd\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender\u3002\u4f8b\u5982\uff0c\u5728\u5546\u4e1a\u4fe1\u51fd\u4e2d\uff0c\u53d1\u4ef6\u65b9\u901a\u5e38\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u6839\u636e\u60c5\u51b5\u5224\u65ad\u3002\\n\\n\u8fd9\u91cc\u53ef\u80fd\u9700\u8981\u53c2\u8003\u5386\u53f2\u4fe1\u4ef6\u7684\u60ef\u4f8b\u3002\u572820\u4e16\u7eaa\u521d\u7684\u745e\u58eb\uff0c\u516c\u53f8\u4fe1\u4ef6\u901a\u5e38\u4ee5\u516c\u53f8\u540d\u4e49\u53d1\u51fa\uff0c\u7b7e\u540d\u5904\u53ef\u80fd\u6709\u804c\u4f4d\u4f46\u65e0\u5177\u4f53\u540d\u5b57\uff0c\u6240\u4ee5\u53ef\u80fdsender_persons\u5e94\u4e3a\u516c\u53f8\u540d\u79f0\u3002\u4f46\u6839\u636e\u7528\u6237\u63d0\u4f9b\u7684schema\uff0csender_persons\u662f\u4eba\u5458\u540d\u79f0\uff0c\u6240\u4ee5\u5982\u679c\u662f\u516c\u53f8\uff0c\u53ef\u80fd\u5e94\u8be5\u7528\u516c\u53f8\u540d\u79f0\u4f5c\u4e3asender_persons\u7684\u5143\u7d20\u3002\u4f8b\u5982\uff0c[\\\"Basler Personenschiffahrtsgesellschaft\\\"]\u3002\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u7b26\u5408\u7528\u6237\u7684\u8981\u6c42\u3002\\n\\n\u53e6\u5916\uff0cletter_title\u5728\u4fe1\u4ef6\u4e2d\u6ca1\u6709\u660e\u786e\u7684\u6807\u9898\uff0c\u901a\u5e38\u6b63\u5f0f\u4fe1\u4ef6\u53ef\u80fd\u6ca1\u6709\u6807\u9898\uff0c\u6240\u4ee5letter_title\u5e94\u4e3anull\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684letter_title\u662f\u5b58\u5728\u7684\uff0c\u6bd4\u5982\u201cPetition for Environmental Protection\u201d\u3002\u4f46\u5728\u8fd9\u4e2a\u4fe1\u4ef6\u4e2d\uff0c\u6ca1\u6709\u6807\u9898\uff0c\u6240\u4ee5\u5e94\u8be5\u8bbe\u4e3anull\u3002\\n\\n\u603b\u7ed3\uff1a\\n\\n- letter_title: \u6ca1\u6709\u6807\u9898\uff0c\u6240\u4ee5null\u3002\\n- send_date: 1922-12-16\u3002\\n- sender_persons: \u516c\u53f8\u540d\u79f0Basler Personenschiffahrtsgesellschaft\uff0c\u4f46\u9700\u8981\u786e\u8ba4\u662f\u5426\u4f5c\u4e3a\u4eba\u5458\u3002\u6216\u8005\u56e0\u4e3a\u7b7e\u540d\u5904\u6ca1\u6709\u5177\u4f53\u4eba\u540d\uff0c\u6240\u4ee5\u8bbe\u4e3anull\uff1f\\n- receiver_persons: Basler Rheinschiffahrt A.-G.\\n\\n\u4f46\u6839\u636e\u95ee\u9898\u4e2d\u7684\u4f8b\u5b50\uff0csender_persons\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u5982\u679c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u4f46\u65e0\u6cd5\u786e\u5b9a\u5177\u4f53\u4eba\u540d\u7684\u8bdd\uff0c\u53ef\u80fd\u5e94\u8be5\u8bbe\u4e3anull\u3002\u4f46\u6709\u65f6\u5019\uff0c\u516c\u53f8\u4f5c\u4e3a\u53d1\u4ef6\u65b9\uff0c\u53ef\u80fd\u7528\u516c\u53f8\u540d\u79f0\u3002\u4f8b\u5982\uff0c\u5728\u5546\u4e1a\u4fe1\u51fd\u4e2d\uff0c\u53d1\u4ef6\u65b9\u662f\u516c\u53f8\uff0c\u6240\u4ee5\u53ef\u80fd\u5e94\u8be5\u586b\u516c\u53f8\u540d\u79f0\u3002\u4f46\u7528\u6237\u793a\u4f8b\u4e2d\u7684sender\u662f\u4e2a\u4eba\uff0c\u6240\u4ee5\u53ef\u80fd\u9700\u8981\u770b\u5177\u4f53\u60c5\u51b5\u3002\\n\\n\u518d\u4ed4\u7ec6\u770b\u4